[?2004l[?2004h> def get_pdb_sequence(pdb_id):
[?2004l[?2004h>     # We can fetch via https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1
[?2004l[?2004h>     # or via fasta from https://www.rcsb.org/fasta/entry/{pdb_id}
[?2004l[?2004h>     url = f"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1"
[?2004l[?2004h>     try:
[?2004l[?2004h>         req = urllib.request.urlopen(url)
[?2004l[?2004h>         res = json.loads(req.read().decode())
[?2004l[?2004h>         # The sequence is under entity_poly.pdbx_seq_one_letter_code
[?2004l[?2004h>         seq = res.get("entity_poly", {}).get("pdbx_seq_one_letter_code", "")
[?2004l[?2004h>         return seq
[?2004l[?2004h>     except Exception as e:
[?2004l[?2004h>         return f"Error: {e}"
[?2004l[?2004h> 
