[?2004l[?2004h>             break
[?2004l[?2004h>     print("RID:", rid)
[?2004l[?2004h>     if rid:
[?2004l[?2004h>         # Poll for results
[?2004l[?2004h>         while True:
[?2004l[?2004h>             time.sleep(5)
[?2004l[?2004h>             check_url = f"https://blast.ncbi.nlm.nih.gov/Blast.cgi?CMD=Get&FORMAT_OBJECT=SearchInfo&RID={rid}"
[?2004l[?2004h>             check_req = urllib.request.urlopen(check_url)
[?2004l[?2004h>             check_res = check_req.read().decode()
[?2004l[?2004h>             if "Status=WAITING" in check_res:
[?2004l[?2004h>                 print("Waiting...")
[?2004l[?2004h>                 continue
[?2004l[?2004h>             elif "Status=FAILED" in check_res:
[?2004l[?2004h>                 print("Failed")
[?2004l[?2004h>                 break
[?2004l[?2004h>             elif "Status=UNKNOWN" in check_res:
[?2004l[?2004h>                 print("Unknown")
[?2004l[?2004h>                 break
[?2004l[?2004h>             elif "Status=READY" in check_res:
[?2004l[?2004h>                 print("Ready!")
[?2004l[?2004h>                 if "ThereAreHits=yes" in check_res:
[?2004l[?2004h>                     # Get hits
