[?2004hroot@12447c16b972:/app# cat << 'EOF' > get_fpbase.py
[?2004l[?2004h> import urllib.request
[?2004l[?2004h> import json
[?2004l[?2004h> 
[?2004l[?2004h> # Let's search fpbase. The FPBase API is GraphQL or we can do REST?
[?2004l[?2004h> # Let's see if we can query FPBase via its REST API (e.g. https://www.fpbase.org/api/proteins/) or similar.
[?2004l[?2004h> # Let's check what endpoints FPBase has. Often, https://www.fpbase.org/api/proteins/ gives a list of proteins.
[?2004l[?2004h> # Or we can search for names or look at pdb IDs in FPBase.
[?2004l[?2004h> 
[?2004l[?2004h> url = "https://www.fpbase.org/api/proteins/?format=json"
[?2004l[?2004h> try:
[?2004l[?2004h>     req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
[?2004l[?2004h>     with urllib.request.urlopen(req) as res:
[?2004l[?2004h>         data = json.loads(res.read().decode())
[?2004l[?2004h>         print(f"Found {len(data)} proteins")
[?2004l[?2004h>         # Let's save the data to a file for parsing
[?2004l[?2004h>         with open("fpbase_proteins.json", "w") as f:
[?2004l[?2004h>             json.dump(data, f, indent=2)
[?2004l[?2004h> except Exception as e:
[?2004l[?2004h>     print("Error:", e)
[?2004l[?2004h> EOF
[?2004l[?2004hroot@12447c16b972:/app# python3 get_fpbase.py
[?2004lFound 1041 proteins
[?2004hroot@12447c16b972:/app# cat << 'EOF' > parse_fps.py
[?2004l[?2004h> import json
[?2004l[?2004h> 
[?2004l[?2004h> pdb_ids = set(open("/app/data/pdb_ids.txt").read().split())
[?2004l[?2004h> 
[?2004l[?2004h> with open("fpbase_proteins.json") as f:
[?2004l[?2004h>     fps = json.load(f)
[?2004l[?2004h> 
[?2004l[?2004h> for fp in fps:
[?2004l[?2004h>     # check if any pdb matches
[?2004l[?2004h>     fp_pdbs = fp.get("pdbs", [])
[?2004l[?2004h>     matched_pdbs = [p for p in fp_pdbs if p.upper() in pdb_ids]
[?2004l[?2004h>     if matched_pdbs or fp.get("name") in ["Clover", "mCherry", "TagRFP", "Dendra2", "mKO", "Gamillus", "Azami-Green"]:
[?2004l[?2004h>         # Let's print name, pdbs, ex, em
[?2004l[?2004h>         # In FPBase REST API response, let's see how ex (excitation) and em (emission) peaks are structured.
[?2004l[?2004h>         # Often there is an array of states, or keys like "ex_max", "em_max"
[?2004l[?2004h>         states = fp.get("states", [])
[?2004l[?2004h>         for s in states:
[?2004l[?2004h>             ex = s.get("ex_max")
[?2004l[?2004h>             em = s.get("em_max")
[?2004l[?2004h>             print(f"Name: {fp.get('name')}, PDBs: {fp_pdbs}, State: {s.get('name')}, Ex: {ex}, Em: {em}")
[?2004l[?2004h> EOF
