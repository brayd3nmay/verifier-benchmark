[403.259763, "i", "cat << 'EOF' > translate.py\nCODON_TABLE = {\n    'ATA':'I', 'ATC':'I', 'ATT':'I', 'ATG':'M',\n    'ACA':'T', 'ACC':'T', 'ACG':'T', 'ACT':'T',\n    'AAC':'N', 'AAT':'N', 'AAA':'K', 'AAG':'K',\n    'AGC':'S', 'AGT':'S', 'AGA':'R', 'AGG':'R',\n    'CTA':'L', 'CTC':'L', 'CTG':'L', 'CTT':'L',\n    'CCA':'P', 'CCC':'P', 'CCG':'P', 'CCT':'P',\n    'CAC':'H', 'CAT':'H', 'CAA':'Q', 'CAG':'Q',\n    'CGA':'R', 'CGC':'R', 'CGG':'R', 'CGT':'R',\n    'GTA':'V', 'GTC':'V', 'GTG':'V', 'GTT':'V',\n    'GCA':'A', 'GCC':'A', 'GCG':'A', 'GCT':'A',\n    'GAC':'D', 'GAT':'D', 'GAA':'E', 'GAG':'E',\n    'GGA':'G', 'GGC':'G', 'GGG':'G', 'GGT':'G',\n    'TCA':'S', 'TCC':'S', 'TCG':'S', 'TCT':'S',\n    'TTC':'F', 'TTT':'F', 'TTA':'L', 'TTG':'L',\n    'TAC':'Y', 'TAT':'Y', 'TAA':'*','TAG':'*',\n    'TGC':'C', 'TGT':'C', 'TGA':'*','TGG':'W',\n}\n\ndef translate(dna):\n    dna = dna.upper()\n    protein = []\n    for i in range(0, len(dna) - 2, 3):\n        codon = dna[i:i+3]\n        protein.append(CODON_TABLE.get(codon, 'X'))\n    return \"\".join(protein)\n\nprint(\"Translation:\", translate(\"ATGGTG\"))\nEOF\npython3 translate.py\n"]
[403.261988, "o", "cat << 'EOF' > translate.py\r\n\u001b[?2004l\r\u001b[?2004h> CODON_TABLE = {\r\n\u001b[?2004l\r\u001b[?2004h>     'ATA':'I', 'ATC':'I', 'ATT':'I', 'ATG':'M',\r\n\u001b[?2004l\r\u001b[?2004h>     'ACA':'T', 'ACC':'T', 'ACG':'T', 'ACT':'T',\r\n\u001b[?2004l\r\u001b[?2004h>     'AAC':'N', 'AAT':'N', 'AAA':'K', 'AAG':'K',\r\n\u001b[?2004l\r\u001b[?2004h>     'AGC':'S', 'AGT':'S', 'AGA':'R', 'AGG':'R',\r\n\u001b[?2004l\r\u001b[?2004h>     'CTA':'L', 'CTC':'L', 'CTG':'L', 'CTT':'L',\r\n\u001b[?2004l\r\u001b[?2004h>     'CCA':'P', 'CCC':'P', 'CCG':'P', 'CCT':'P',\r\n\u001b[?2004l\r\u001b[?2004h>     'CAC':'H', 'CAT':'H', 'CAA':'Q', 'CAG':'Q',\r\n\u001b[?2004l\r\u001b[?2004h>     'CGA':'R', 'CGC':'R', 'CGG':'R', 'CGT':'R',\r\n\u001b[?2004l\r\u001b[?2004h>     'GTA':'V', 'GTC':'V', 'GTG':'V', 'GTT':'V',\r\n\u001b[?2004l\r\u001b[?2004h>     'GCA':'A', 'GCC':'A', 'GCG':'A', 'GCT':'A',\r\n\u001b[?2004l\r\u001b[?2004h>     'GAC':'D', 'GAT':'D', 'GAA':'E', 'GAG':'E',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[403.26207, "o", "    'GGA':'G', 'GGC':'G', 'GGG':'G', 'GGT':'G',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[403.262088, "o", "    'TCA':'S', 'TCC':'S', 'TCG':'S', 'TCT':'S',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[403.262611, "o", "    'TTC':'F', 'TTT':'F', 'TTA':'L', 'TTG':'L',\r\n\u001b[?2004l\r\u001b[?2004h>     'TAC':'Y', 'TAT':'Y', 'TAA':'*','TAG':'*',\r\n\u001b[?2004l\r\u001b[?2004h>     'TGC':'C', 'TGT':'C', 'TGA':'*','TGG':'W',\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def translate(dna):\r\n\u001b[?2004l\r\u001b[?2004h>     dna = dna.upper()\r\n\u001b[?2004l\r\u001b[?2004h>     protein = []\r\n\u001b[?2004l\r\u001b[?2004h>     for i in range(0, len(dna) - 2, 3):\r\n\u001b[?2004l\r\u001b[?2004h>         codon = dna[i:i+3]\r\n\u001b[?2004l\r\u001b[?2004h> "]
