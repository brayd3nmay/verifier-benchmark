[53.321917, "i", "cat << 'EOF' > parse_fps.py\nimport json\n\npdb_ids = set(open(\"/app/data/pdb_ids.txt\").read().split())\n\nwith open(\"fpbase_proteins.json\") as f:\n    fps = json.load(f)\n\nfor fp in fps:\n    # check if any pdb matches\n    fp_pdbs = fp.get(\"pdbs\", [])\n    matched_pdbs = [p for p in fp_pdbs if p.upper() in pdb_ids]\n    if matched_pdbs or fp.get(\"name\") in [\"Clover\", \"mCherry\", \"TagRFP\", \"Dendra2\", \"mKO\", \"Gamillus\", \"Azami-Green\"]:\n        # Let's print name, pdbs, ex, em\n        # In FPBase REST API response, let's see how ex (excitation) and em (emission) peaks are structured.\n        # Often there is an array of states, or keys like \"ex_max\", \"em_max\"\n        states = fp.get(\"states\", [])\n        for s in states:\n            ex = s.get(\"ex_max\")\n            em = s.get(\"em_max\")\n            print(f\"Name: {fp.get('name')}, PDBs: {fp_pdbs}, State: {s.get('name')}, Ex: {ex}, Em: {em}\")\nEOF\npython3 parse_fps.py\n"]
[53.32627, "o", "cat << 'EOF' > parse_fps.py\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> pdb_ids = set(open(\"/app/data/pdb_ids.txt\").read().split())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> with open(\"fpbase_proteins.json\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>     fps = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for fp in fps:\r\n\u001b[?2004l\r\u001b[?2004h>     # check if any pdb matches\r\n\u001b[?2004l\r\u001b[?2004h>     fp_pdbs = fp.get(\"pdbs\", [])\r\n\u001b[?2004l\r\u001b[?2004h>     matched_pdbs = [p for p in fp_pdbs if p.upper() in pdb_ids]\r\n\u001b[?2004l\r\u001b[?2004h>     if matched_pdbs or fp.get(\"name\") in [\"Clover\", \"mCherry\", \"TagRFP\", \"Dendra2\", \"mKO\", \"Gamillus\", \"Azami-Green\"]:\r\n\u001b[?2004l\r\u001b[?2004h>         # Let's print name, pdbs, ex, em\r\n\u001b[?2004l\r\u001b[?2004h>         # In FPBase REST API response, let's see how ex (excitation) and em (emission) peaks are structured.\r\n\u001b[?2004l\r\u001b[?2004h>         # Often there is an array of states, or keys like \"ex_max\", \"em_max\"\r\n\u001b[?2004l\r\u001b[?2004h>         states = fp.get(\"states\", [])\r\n\u001b[?2004l\r\u001b[?2004h>         for s in states:\r\n\u001b[?2004l\r\u001b[?2004h>             ex = s.get(\"ex_max\")\r\n\u001b[?2004l\r\u001b[?2004h>             em = s.get(\"em_max\")\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"Name: {fp.get('name')}, PDBs: {fp_pdbs}, State: {s.get('name')}, Ex: {ex}, Em: {em}\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
