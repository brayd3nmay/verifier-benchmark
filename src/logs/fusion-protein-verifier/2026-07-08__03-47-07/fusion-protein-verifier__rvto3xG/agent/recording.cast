[61.193248, "i", "cat << 'EOF' > get_sequences.py\nimport urllib.request\nimport json\n\ndef get_pdb_sequence(pdb_id):\n    # We can fetch via https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\n    # or via fasta from https://www.rcsb.org/fasta/entry/{pdb_id}\n    url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\n    try:\n        req = urllib.request.urlopen(url)\n        res = json.loads(req.read().decode())\n        # The sequence is under entity_poly.pdbx_seq_one_letter_code\n        seq = res.get(\"entity_poly\", {}).get(\"pdbx_seq_one_letter_code\", \"\")\n        return seq\n    except Exception as e:\n        return f\"Error: {e}\"\n\nfor pdb_id in [\"3KZY\", \"5WJ2\", \"2H5Q\"]:\n    print(f\">{pdb_id}\")\n    print(get_pdb_sequence(pdb_id))\nEOF\npython3 get_sequences.py\n"]
[61.197768, "o", "cat << 'EOF' > get_sequences.py\r\n\u001b[?2004l\r\u001b[?2004h> import urllib.request\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_pdb_sequence(pdb_id):\r\n\u001b[?2004l\r\u001b[?2004h>     # We can fetch via https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\r\n\u001b[?2004l\r\u001b[?2004h>     # or via fasta from https://www.rcsb.org/fasta/entry/{pdb_id}\r\n\u001b[?2004l\r\u001b[?2004h>     url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         req = urllib.request.urlopen(url)\r\n\u001b[?2004l\r\u001b[?2004h>         res = json.loads(req.read().decode())\r\n\u001b[?2004l\r\u001b[?2004h>         # The sequence is under entity_poly.pdbx_seq_one_letter_code\r\n\u001b[?2004l\r\u001b[?2004h>         seq = res.get(\"entity_poly\", {}).get(\"pdbx_seq_one_letter_code\", \"\")\r\n\u001b[?2004l\r\u001b[?2004h>         return seq\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         return f\"Error: {e}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for pdb_id in [\"3KZY\", \"5WJ2\", \"2H5Q\"]:\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\">{pdb_id}\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(get_pdb_sequence(pdb_id))\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
