[380.602306, "i", "cat << 'EOF' > print_subproteins.py\nimport json\n\n# 1. Antibody binder\nantibody_binder = \"DYKDDDDK\"\n\n# 2. Donor: Clover from PDB 5WJ2\n# Original PDB 5WJ2 polymer 1 sequence:\n# MGSSHHHHHHSSGENLYFQGHMVSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTF(CR2)VACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK\n# Replace (CR2) with GYG:\nclover_raw = \"MGSSHHHHHHSSGENLYFQGHMVSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK\"\n# Remove N-terminal M:\ndonor = clover_raw[1:]\n\n# 3. DHFR: from plasmid.gb, remove N-terminal M\n# Original DHFR translation:\n# MISLIAALAVDRVIGMENAMPWNLPADLAWFKRNTLNKPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCFEILERR\ndhfr_raw = \"MISLIAALAVDRVIGMENAMPWNLPADLAWFKRNTLNKPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCFEILERR\"\ndhfr = dhfr_raw[1:]\n\n# 4. Acceptor: mCherry from PDB 2H5Q\n# Original PDB 2H5Q sequence:\n# MVSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQF(CH6)SKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK\n# Replace (CH6) with MYG:\nmcherry_raw = \"MVSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQFMYGSKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK\"\n# Remove N-terminal M:\nacceptor = mcherry_raw[1:]\n\n# 5. Molecule binder: SNAP-tag from PDB 3KZY\n# Sequence starts with G, so no N-terminal M to remove\nsnap_raw = \"GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR\"\nmolecule_binder = snap_raw\n\nsubproteins = {\n    \"antibody_binder\": antibody_binder,\n    \"donor\": donor,\n    \"dhfr\": dhfr,\n    \"acceptor\": acceptor,\n    \"molecule_binder\": molecule_binder\n}\n\nwith open(\"/app/verifier/subproteins.json\", \"w\") as f:\n    json.dump(subproteins, f, indent=2)\n\nfor k, v in subproteins.items():\n    print(f\"{k}: {len(v)} AA, starts with {v[:10]}... ends with {v[-10:]}\")\nEOF\npython3 print_subproteins.py\n"]
