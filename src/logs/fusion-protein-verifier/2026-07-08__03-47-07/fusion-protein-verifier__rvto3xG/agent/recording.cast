[423.689662, "o", "            print(f\"Window {i} to {i+50} has invalid GC content: {gc_pct:.1%}\")\r\n\u001b[?2004l\r"]
[423.689693, "o", "\u001b[?2004h> "]
[423.689769, "o", "            with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.689781, "o", "                f.write(\"0\\n\")\r\n"]
[423.689788, "o", "\u001b[?2004l\r"]
[423.689965, "o", "\u001b[?2004h>             return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\ri\u001b[?2004h>     # No start or stop codons\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.690125, "o", "    # First, does the DNA contain any stop codons in-frame?\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.690196, "o", "    # Also, does it have a start codon (ATG) at the beginning?\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.690245, "o", "    # We also check that the translation does not contain '*'\r\n\u001b[?2004l\rrdi\u001b[?2004h> "]
[423.690376, "o", "    # Let's check stop codons in the reading frame of the gBlock (frame 1, index 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.69043, "o", "    for i in range(0, len(seq), 3):\r\n\u001b[?2004l\r"]
[423.690441, "o", "\u001b[?2004h> "]
[423.690472, "o", "        codon = seq[i:i+3]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.690518, "o", "        if codon in ['TAA', 'TAG', 'TGA']:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.690592, "o", "            print(f\"In-frame stop codon {codon} found at position {i}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.690622, "o", "            with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[423.690692, "o", ">                 f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>             return\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.690707, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.690775, "o", "    # Does the gBlock start with a start codon (ATG)?\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.690795, "o", "    if seq.startswith(\"ATG\"):\r\n\u001b[?2004l\r"]
[423.690805, "o", "\u001b[?2004h> "]
[423.690874, "o", "        print(\"gBlock starts with start codon ATG\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.69093, "o", "        with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.690977, "o", "            f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r"]
[423.691033, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[423.691086, "o", "\u001b[?2004h>     # Translate sequence\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.691104, "o", "    translated = translate(seq)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.691135, "o", "    if 'X' in translated:\r\n\u001b[?2004l\r"]
[423.691146, "o", "\u001b[?2004h> "]
[423.691218, "o", "        print(\"Unrecognized codon in sequence\")\r\n\u001b[?2004l\r\u001b[?2004h>         with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r"]
[423.691258, "o", "\u001b[?2004h> "]
[423.691315, "o", "            f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r"]
[423.691373, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.691426, "o", "    # Load subproteins\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r"]
[423.691507, "o", "\u001b[?2004h> "]
[423.691632, "o", "        with open(\"/app/verifier/subproteins.json\") as sf:\r\n\u001b[?2004l\r"]
[423.691647, "o", "\u001b[?2004h> "]
[423.691721, "o", "            subproteins = json.load(sf)\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r"]
[423.691739, "o", "\u001b[?2004h> "]
[423.691813, "o", "        print(\"Failed to load subproteins list:\", e)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.691832, "o", "        with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r"]
[423.691917, "o", "\u001b[?2004h>             f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r"]
[423.691931, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[423.691983, "o", "\u001b[?2004h> "]
[423.692027, "o", "    antibody_binder = subproteins[\"antibody_binder\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.692119, "o", "    donor = subproteins[\"donor\"]\r\n\u001b[?2004l\r\u001b[?2004h>     dhfr = subproteins[\"dhfr\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.692136, "o", "    acceptor = subproteins[\"acceptor\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.692228, "o", "    molecule_binder = subproteins[\"molecule_binder\"]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.692309, "o", "    # Check that it encodes only the 5 subproteins and GS linkers in the correct order\r\n\u001b[?2004l\r"]
[423.692532, "o", "\u001b[?2004h>     # Order: antibody binder — donor — DHFR — acceptor — molecule binder\r\n\u001b[?2004l\r"]
[423.69259, "o", "\u001b[?2004h> "]
[423.692601, "o", "    # No N or C terminal linkers\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.692726, "o", "    if not translated.startswith(antibody_binder):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.692819, "o", "        print(\"Protein does not start with antibody binder\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.692891, "o", "        with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.692906, "o", "            f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.69297, "o", "        return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.693029, "o", "    if not translated.endswith(molecule_binder):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.69308, "o", "        print(\"Protein does not end with molecule binder\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[423.693138, "o", "> "]
[423.693189, "o", "        with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[423.693232, "o", ">             f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[423.693249, "o", ">         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[423.69326, "o", "> "]
[423.693338, "o", "    # Find the positions\r\n\u001b[?2004l\r\u001b[?2004h>     idx_ab = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.69346, "o", "    len_ab = len(antibody_binder)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.693519, "o", "    idx_donor = translated.find(donor, len_ab)\r\n\u001b[?2004l\r\u001b[?2004h>     if idx_donor == -1:"]
[423.693563, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.693617, "o", "        print(\"Donor not found in correct position\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.693709, "o", "        with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>             f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h"]
[423.693726, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.693781, "o", "    linker1 = translated[len_ab : idx_donor]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.693854, "o", "    idx_dhfr = translated.find(dhfr, idx_donor + len(donor))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.6939, "o", "    if idx_dhfr == -1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.693955, "o", "        print(\"DHFR not found in correct position\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.694003, "o", "        with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.694047, "o", "            f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.694057, "o", "        return\r\n\u001b[?2004l\r"]
[423.694103, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.694163, "o", "    linker2 = translated[idx_donor + len(donor) : idx_dhfr]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[423.694196, "o", "\u001b[?2004h> "]
[423.694296, "o", "    idx_acceptor = translated.find(acceptor, idx_dhfr + len(dhfr))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.694378, "o", "    if idx_acceptor == -1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.694445, "o", "        print(\"Acceptor not found in correct position\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.694558, "o", "        with open(verdict_file, \"w\") as f:"]
[423.69459, "o", "\r\n"]
[423.694622, "o", "\u001b[?2004l\r"]
[423.69467, "o", "\u001b[?2004h> "]
[423.694714, "o", "            f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r"]
[423.694792, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.694885, "o", "    linker3 = translated[idx_dhfr + len(dhfr) : idx_acceptor]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.694947, "o", "    idx_mb = translated.find(molecule_binder, idx_acceptor + len(acceptor))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.69496, "o", "    if idx_mb == -1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.695071, "o", "        print(\"Molecule binder not found in correct position\")\r\n\u001b[?2004l\r\u001b[?2004h>         with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.695124, "o", "            f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.695232, "o", "    # Since we already checked endswith(molecule_binder), idx_mb + len(molecule_binder) must be len(translated)\r\n\u001b[?2004l\r\u001b[?2004h"]
[423.69525, "o", "> "]
[423.695345, "o", "    if idx_mb + len(molecule_binder) != len(translated):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.695423, "o", "        print(\"Extra sequence after molecule binder\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[423.69548, "o", "> "]
[423.695491, "o", "        with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r"]
[423.69559, "o", "\u001b[?2004h>             f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.695668, "o", "    linker4 = translated[idx_acceptor + len(acceptor) : idx_mb]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.695722, "o", "    # Check linkers\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.695818, "o", "    linkers = [linker1, linker2, linker3, linker4]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.695882, "o", "    for i, l in enumerate(linkers, 1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.695981, "o", "        # Length between 5 and 20 amino acids\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.69608, "o", "        if len(l) < 5 or len(l) > 20:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.696145, "o", "            print(f\"Linker {i} has invalid length {len(l)}: '{l}'\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.696265, "o", "            with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>                 f.write(\"0\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>             return\r\n\u001b[?2004l\r\u001b[?2004h"]
[423.696325, "o", "> "]
[423.696453, "o", "        # Contains only G and S\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.696496, "o", "        if not all(c in \"GS\" for c in l):\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"Linker {i} contains non-GS amino acids: '{l}'\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.69657, "o", "            with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r"]
[423.696611, "o", "\u001b[?2004h> "]
[423.696702, "o", "                f.write(\"0\\n\")\r\n"]
[423.696719, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[423.69681, "o", "            return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     print(\"All checks passed successfully!\")\r\n\u001b[?2004l\r"]
[423.69687, "o", "\u001b[?2004h>     with open(verdict_file, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.696933, "o", "        f.write(\"1\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[423.696982, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[423.697063, "o", "\u001b[?2004h>     verify()\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[423.701705, "o", "\u001b[?2004hroot@12447c16b972:/app# "]
[427.824921, "i", "head -n 50 /app/verifier/verify.py\n"]
[427.825137, "o", "head -n 50 /app/verifier/verify.py\r\n\u001b[?2004l\r"]
[427.828658, "o", "import os\r\nimport sys\r\nimport json\r\n\r\nCODON_TABLE = {\r\n    'ATA':'I', 'ATC':'I', 'ATT':'I', 'ATG':'M',\r\n    'ACA':'T', 'ACC':'T', 'ACG':'T', 'ACT':'T',\r\n    'AAC':'N', 'AAT':'N', 'AAA':'K', 'AAG':'K',\r\n    'AGC':'S', 'AGT':'S', 'AGA':'R', 'AGG':'R',\r\n    'CTA':'L', 'CTC':'L', 'CTG':'L', 'CTT':'L',\r\n    'CCA':'P', 'CCC':'P', 'CCG':'P', 'CCT':'P',\r\n    'CAC':'H', 'CAT':'H', 'CAA':'Q', 'CAG':'Q',\r\n    'CGA':'R', 'CGC':'R', 'CGG':'R', 'CGT':'R',\r\n    'GTA':'V', 'GTC':'V', 'GTG':'V', 'GTT':'V',\r\n    'GCA':'A', 'GCC':'A', 'GCG':'A', 'GCT':'A',\r\n    'GAC':'D', 'GAT':'D', 'GAA':'E', 'GAG':'E',\r\n    'GGA':'G', 'GGC':'G', 'GGG':'G', 'GGT':'G',\r\n    'TCA':'S', 'TCC':'S', 'TCG':'S', 'TCT':'S',\r\n    'TTC':'F', 'TTT':'F', 'TTA':'L', 'TTG':'L',\r\n    'TAC':'Y', 'TAT':'Y', 'TAA':'*','TAG':'*',\r\n    'TGC':'C', 'TGT':'C', 'TGA':'*','TGG':'W',\r\n}\r\n\r\ndef translate(dna):\r\n    protein = []\r\n    for i in range(0, len(dna) - 2, 3):\r\n        codon = dna[i:i+3]\r\n        protein.append(CODON_TABLE.get(codon, 'X'))\r\n    return \"\".join(protein)\r\n\r\ndef verify():\r\n    solution_dir = os.environ.get(\"SOLUTION_DIR\", \"/app\")\r\n    verdict_file = os.environ.get(\"VERDICT_FILE\", \"/logs/verifier/reward.txt\")\r\n\r\n    # Ensure the directory of verdict file exists\r\n    verdict_dir = os.path.dirname(verdict_file)\r\n    if verdict_dir and not os.path.exists(verdict_dir):\r\n        os.makedirs(verdict_dir, exist_ok=True)\r\n\r\n    gblock_path = os.path.join(solution_dir, \"gblock.txt\")\r\n    if not os.path.exists(gblock_path):\r\n        print(f\"gblock.txt not found at {gblock_path}\")\r\n        with open(verdict_file, \"w\") as f:\r\n            f.write(\"0\\n\")\r\n        return\r\n\r\n    try:\r\n        with open(gblock_path, \"r\") as f:\r\n            lines = f.readlines()\r\n    except Exception as e:\r\n"]
[427.829014, "o", "\u001b[?2004hroot@12447c16b972:/app# "]
[428.312444, "i", "tail -n 50 /app/verifier/verify.py\n"]
[428.314474, "o", "tail -n 50 /app/verifier/verify.py\r\n\u001b[?2004l\r"]
[428.319646, "o", "\r\n    linker2 = translated[idx_donor + len(donor) : idx_dhfr]\r\n\r\n    idx_acceptor = translated.find(acceptor, idx_dhfr + len(dhfr))\r\n    if idx_acceptor == -1:\r\n        print(\"Acceptor not found in correct position\")\r\n        with open(verdict_file, \"w\") as f:\r\n            f.write(\"0\\n\")\r\n        return\r\n\r\n    linker3 = translated[idx_dhfr + len(dhfr) : idx_acceptor]\r\n\r\n    idx_mb = translated.find(molecule_binder, idx_acceptor + len(acceptor))\r\n    if idx_mb == -1:\r\n        print(\"Molecule binder not found in correct position\")\r\n        with open(verdict_file, \"w\") as f:\r\n            f.write(\"0\\n\")\r\n        return\r\n\r\n    # Since we already checked endswith(molecule_binder), idx_mb + len(molecule_binder) must be len(translated)\r\n    if idx_mb + len(molecule_binder) != len(translated):\r\n        print(\"Extra sequence after molecule binder\")\r\n        with open(verdict_file, \"w\") as f:\r\n            f.write(\"0\\n\")\r\n        return\r\n\r\n    linker4 = translated[idx_acceptor + len(acceptor) : idx_mb]\r\n\r\n    # Check linkers\r\n    linkers = [linker1, linker2, linker3, linker4]\r\n    for i, l in enumerate(linkers, 1):\r\n        # Length between 5 and 20 amino acids\r\n        if len(l) < 5 or len(l) > 20:\r\n            print(f\"Linker {i} has invalid length {len(l)}: '{l}'\")\r\n            with open(verdict_file, \"w\") as f:\r\n                f.write(\"0\\n\")\r\n            return\r\n        # Contains only G and S\r\n"]
[428.319911, "o", "        if not all(c in \"GS\" for c in l):\r\n            print(f\"Linker {i} contains non-GS amino acids: '{l}'\")\r\n            with open(verdict_file, \"w\") as f:\r\n                f.write(\"0\\n\")\r\n            return\r\n\r\n    print(\"All checks passed successfully!\")\r\n    with open(verdict_file, \"w\") as f:\r\n        f.write(\"1\\n\")\r\n\r\nif __name__ == \"__main__\":\r\n    verify()\r\n"]
[428.319957, "o", "\u001b[?2004hroot@12447c16b972:/app# "]
[430.925985, "i", "wc -l /app/verifier/verify.py\n"]
[430.926525, "o", "wc -l /app/verifier/verify.py\r\n\u001b[?2004l\r"]
[430.930337, "o", "245 /app/verifier/verify.py\r\n"]
