[86.165162, "i", "cat << 'EOF' > get_chromophore_details.py\nimport urllib.request\nimport json\n\n# Let's check the polymer entity info or get the sequence from PDB API\n# Under rcsb_polymer_entity_container_identifiers, is there reference to uniprot?\n# Let's fetch https://data.rcsb.org/rest/v1/core/polymer_entity/5WJ2/1\n# and https://data.rcsb.org/rest/v1/core/polymer_entity/2H5Q/1\n\nfor pdb_id in [\"5WJ2\", \"2H5Q\"]:\n    url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\n    try:\n        req = urllib.request.urlopen(url)\n        data = json.loads(req.read().decode())\n        print(f\"=== {pdb_id} ===\")\n        print(\"uniprot ids:\", data.get(\"rcsb_polymer_entity_container_identifiers\", {}).get(\"uniprot_ids\"))\n        print(\"one_letter_code:\", data.get(\"entity_poly\", {}).get(\"pdbx_seq_one_letter_code\"))\n        print(\"one_letter_code_can:\", data.get(\"entity_poly\", {}).get(\"pdbx_seq_one_letter_code_can\"))\n    except Exception as e:\n        print(pdb_id, e)\nEOF\npython3 get_chromophore_details.py\n"]
[86.176815, "o", "cat << 'EOF' > get_chromophore_details.py\r\n\u001b[?2004l\r\u001b[?2004h> import urllib.request\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's check the polymer entity info or get the sequence from PDB API\r\n\u001b[?2004l\r\u001b[?2004h> # Under rcsb_polymer_entity_container_identifiers, is there reference to uniprot?\r\n\u001b[?2004l\r\u001b[?2004h> # Let's fetch https://data.rcsb.org/rest/v1/core/polymer_entity/5WJ2/1\r\n\u001b[?2004l\r\u001b[?2004h> # and https://data.rcsb.org/rest/v1/core/polymer_entity/2H5Q/1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for pdb_id in [\"5WJ2\", \"2H5Q\"]:\r\n\u001b[?2004l\r\u001b[?2004h>     url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         req = urllib.request.urlopen(url)\r\n\u001b[?2004l\r\u001b[?2004h>         data = json.loads(req.read().decode())\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"=== {pdb_id} ===\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"uniprot ids:\", data.get(\"rcsb_polymer_entity_container_identifiers\", {}).get(\"uniprot_ids\"))\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"one_letter_code:\", data.get(\"entity_poly\", {}).get(\"pdbx_seq_one_letter_code\"))\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"one_letter_code_can:\", data.get(\"entity_poly\", {}).get(\"pdbx_seq_one_letter_code_can\"))\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         print(pdb_id, e)\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
