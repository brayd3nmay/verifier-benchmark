[316.058263, "o", "<?xml version=\"1.0\" encoding=\"US-ASCII\"?>\r\n<!DOCTYPE BlastOutput PUBLIC \"-//NCBI//NCBI BlastOutput/EN\" \"http://www.ncbi.nlm.nih.gov/dtd/NCBI_BlastOutput.dtd\">\r\n<BlastOutput>\r\n  <BlastOutput_program>blastp</BlastOutput_program>\r\n  <BlastOutput_version>BLASTP 2.17.0+</BlastOutput_version>\r\n  <BlastOutput_reference>Stephen F. Altschul, Thomas L. Madden, Alejandro A. Sch&amp;auml;ffer, Jinghui Zhang, Zheng Zhang, Webb Miller, and David J. Lipman (1997), &quot;Gapped BLAST and PSI-BLAST: a new generation of protein database search programs&quot;, Nucleic Acids Res. 25:3389-3402.</BlastOutput_reference>\r\n  <BlastOutput_db>nr</BlastOutput_db>\r\n  <BlastOutput_query-ID>Query_2444995</BlastOutput_query-ID>\r\n  <BlastOutput_query-def>unnamed protein product</BlastOutput_query-def>\r\n  <BlastOutput_query-len>117</BlastOutput_query-len>\r\n  <BlastOutput_param>\r\n    <Parameters>\r\n      <Parameters_matrix>BLOSUM62</Parameters_matrix>\r\n      <Parameters_expect>10</Parameters_expect>\r\n      <Parameters_gap-open>11</Parameters_gap-open>\r\n      <Parameters_gap-extend>1</Parameters_gap-extend>\r\n      <Parameters_filter>F</Parameters_filter>\r\n    </Parameters>\r\n  </BlastOutput_param>\r\n<BlastOutput_iterations>\r\n<Iteration>\r\n  <Iteration_iter-num>1</Iteration_iter-num>\r\n  <Iteration_query-ID>Query_2444995</Iteration_query-ID>\r\n  <Iteration_query-def>unnamed protein product</Iteration_query-def>\r\n  <Iteration_query-len>117</Iteration_query-len>\r\n<Iteration_hits>\r\n<Hit>\r\n  <Hit_num>1</Hit_num>\r\n  <Hit_id>pdb|7BG1|H</Hit_id>\r\n  <Hit_def>Chain H, anti-FLAG M2 heavy chain [Mus musculus]</Hit_def>\r\n  <Hit_accession>7BG1_H</Hit_accession>\r\n  <Hit_len>222</Hit_len>\r\n  <Hit_hsps>\r\n    <Hsp>\r\n      <Hsp_num>1</Hsp_num>\r\n      <Hsp_bit-score>244.973</Hsp_bit-score>\r\n      <Hsp_score>624</Hsp_score>\r\n      <Hsp_evalue>8.7562e-80</Hsp_evalue>\r\n      <Hsp_query-from>1</Hsp_query-from>\r\n      <Hsp_query