[467.829177, "o", "    f.write(\"ATG\" + orig_dna[3:] + \"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> verdict, out = run_verify()\r\n\u001b[?2004l\r\u001b[?2004h> assert verdict == \"0\", f\"Expected 0, got {verdict}. Output: {out}\"\r\n\u001b[?2004l\r\u001b[?2004h> print(\"PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Test 4: gblock with stop codon in-frame\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Test 4: Stop codon...\", end=\" \")\r\n\u001b[?2004l\r\u001b[?2004h> with open(\"/app/gblock.txt\", \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>     # Replace first codon (GAC/GAT) with TAA\r\n\u001b[?2004l\r\u001b[?2004h>     f.write(\"TAA\" + orig_dna[3:] + \"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> verdict, out = run_verify()\r\n\u001b[?2004l\r\u001b[?2004h> assert verdict == \"0\", f\"Expected 0, got {verdict}. Output: {out}\"\r\n\u001b[?2004l\r\u001b[?2004h> print(\"PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Restore original gblock\r\n\u001b[?2004l\r\u001b[?2004h> with open(\"/app/gblock.txt\", \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>     f.write(orig_dna + \"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Test suite completed successfully!\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
