[448.192002, "i", "cat << 'EOF' > generate_test_gblock.py\nimport json\nimport random\n\n# Standard codon table (excluding stop codons unless needed, but we don't need stop codons)\n# We can select codons with ~50% GC content to keep GC content within 30-70%.\nCODON_MAP = {\n    'A': ['GCT', 'GCC', 'GCA', 'GCG'],\n    'C': ['TGT', 'TGC'],\n    'D': ['GAT', 'GAC'],\n    'E': ['GAA', 'GAG'],\n    'F': ['TTT', 'TTC'],\n    'G': ['GGT', 'GGC', 'GGA', 'GGG'],\n    'H': ['CAT', 'CAC'],\n    'I': ['ATT', 'ATC', 'ATA'],\n    'K': ['AAA', 'AAG'],\n    'L': ['TTA', 'TTG', 'CTT', 'CTC', 'CTA', 'CTG'],\n    'M': ['ATG'],\n    'N': ['AAT', 'AAC'],\n    'P': ['CCT', 'CCC', 'CCA', 'CCG'],\n    'Q': ['CAA', 'CAG'],\n    'R': ['CGT', 'CGC', 'CGA', 'CGG', 'AGA', 'AGG'],\n    'S': ['TCT', 'TCC', 'TCA', 'TCG', 'AGT', 'AGC'],\n    'T': ['ACT', 'ACC', 'ACA', 'ACG'],\n    'V': ['GTT', 'GTC', 'GTA', 'GTG'],\n    'W': ['TGG'],\n    'Y': ['TAT', 'TAC'],\n}\n\nwith open(\"/app/verifier/subproteins.json\") as f:\n    subproteins = json.load(f)\n\n# Let's create a fusion protein sequence\n# Antibody binder - linker1 - donor - linker2 - DHFR - linker3 - acceptor - linker4 - molecule binder\nlinker1 = \"GSGSGSGSGS\"\nlinker2 = \"GSGSGSGSGS\"\nlinker3 = \"GSGSGSGSGS\"\nlinker4 = \"GSGSGSGSGS\"\n\nfusion_protein = (\n    subproteins[\"antibody_binder\"] +\n    linker1 +\n    subproteins[\"donor\"] +\n    linker2 +\n    subproteins[\"dhfr\"] +\n    linker3 +\n    subproteins[\"acceptor\"] +\n    linker4 +\n    subproteins[\"molecule_binder\"]\n)\n\n# Let's back-translate using a simple codon choice\n# We'll choose codons that balance GC content.\n# Let's write a simple deterministic or randomized selection.\ndna_list = []\nfor aa in fusion_protein:\n    codons = CODON_MAP.get(aa)\n    if not codons:\n        raise ValueError(f\"Unknown amino acid {aa}\")\n    # Pick a codon with balanced GC content\n    # For GC optimization, we can pick a codon whose GC count is closer to 1.5 out of 3\n    best_codon = codons[0]\n    best_diff = 100\n    for codon in codons:\n        gc = codon.count('G') + codon.count('C')\n        diff = abs(gc - 1.5)\n        if diff < best_diff:\n            best_diff = diff\n            best_codon = codon\n    dna_list.append(best_codon)\n\ndna_seq = \"\".join(dna_list)\nprint(\"Generated DNA of length:\", len(dna_seq))\n\n# Check GC content of every 50 nt window\nvalid = True\nfor i in range(len(dna_seq) - 49):\n    window = dna_seq[i:i+50]\n    gc = window.count('G') + window.count('C')\n    pct = gc / 50.0\n    if pct < 0.30 or pct > 0.70:\n        print(f\"Invalid window {i}: {pct:.1%}\")\n        valid = False\n\nif valid:\n    print(\"GC content is valid!\")\n\nwith open(\"/app/gblock.txt\", \"w\") as f:\n    f.write(dna_seq + \"\\n\")\n\nprint(\"Written to /app/gblock.txt\")\nEOF\npython3 generate_test_gblock.py\n"]
