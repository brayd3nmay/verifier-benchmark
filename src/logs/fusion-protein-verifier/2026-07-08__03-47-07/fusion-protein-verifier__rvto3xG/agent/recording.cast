[26.893101, "i", "cat << 'EOF' > get_pdbs.py\nimport urllib.request\nimport json\nimport sys\n\npdb_ids = open(\"/app/data/pdb_ids.txt\").read().split()\nfor pdb_id in pdb_ids:\n    url = f\"https://data.rcsb.org/rest/v1/core/entry/{pdb_id}\"\n    try:\n        req = urllib.request.urlopen(url)\n        res = json.loads(req.read().decode())\n        title = res.get(\"struct\", {}).get(\"title\", \"No title\")\n        print(f\"{pdb_id}: {title}\")\n    except Exception as e:\n        print(f\"{pdb_id}: Error: {e}\")\nEOF\npython3 get_pdbs.py\n"]
[26.900934, "o", "cat << 'EOF' > get_pdbs.py\r\n\u001b[?2004l\r\u001b[?2004h> import urllib.request\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> import sys\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> pdb_ids = open(\"/app/data/pdb_ids.txt\").read().split()\r\n\u001b[?2004l\r\u001b[?2004h> for pdb_id in pdb_ids:\r\n\u001b[?2004l\r\u001b[?2004h>     url = f\"https://data.rcsb.org/rest/v1/core/entry/{pdb_id}\"\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         req = urllib.request.urlopen(url)\r\n\u001b[?2004l\r\u001b[?2004h>         res = json.loads(req.read().decode())\r\n\u001b[?2004l\r\u001b[?2004h>         title = res.get(\"struct\", {}).get(\"title\", \"No title\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"{pdb_id}: {title}\")\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"{pdb_id}: Error: {e}\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[26.905441, "o", "\u001b[?2004hroot@12447c16b972:/app# python3 get_pdbs.py\r\n\u001b[?2004l\r"]
