[40.564712, "i", "cat << 'EOF' > get_fpbase.py\nimport urllib.request\nimport json\n\n# Let's search fpbase. The FPBase API is GraphQL or we can do REST?\n# Let's see if we can query FPBase via its REST API (e.g. https://www.fpbase.org/api/proteins/) or similar.\n# Let's check what endpoints FPBase has. Often, https://www.fpbase.org/api/proteins/ gives a list of proteins.\n# Or we can search for names or look at pdb IDs in FPBase.\n\nurl = \"https://www.fpbase.org/api/proteins/?format=json\"\ntry:\n    req = urllib.request.Request(url, headers={\"User-Agent\": \"Mozilla/5.0\"})\n    with urllib.request.urlopen(req) as res:\n        data = json.loads(res.read().decode())\n        print(f\"Found {len(data)} proteins\")\n        # Let's save the data to a file for parsing\n        with open(\"fpbase_proteins.json\", \"w\") as f:\n            json.dump(data, f, indent=2)\nexcept Exception as e:\n    print(\"Error:\", e)\nEOF\npython3 get_fpbase.py\n"]
[40.567158, "o", "cat << 'EOF' > get_fpbase.py\r\n\u001b[?2004l\r\u001b[?2004h> import urllib.request\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's search fpbase. The FPBase API is GraphQL or we can do REST?\r\n\u001b[?2004l\r\u001b[?2004h> # Let's see if we can query FPBase via its REST API (e.g. https://www.fpbase.org/api/proteins/) or similar.\r\n\u001b[?2004l\r\u001b[?2004h> # Let's check what endpoints FPBase has. Often, https://www.fpbase.org/api/proteins/ gives a list of proteins.\r\n\u001b[?2004l\r\u001b[?2004h> # Or we can search for names or look at pdb IDs in FPBase.\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[40.567201, "o", "\u001b[?2004h> "]
[40.56754, "o", "url = \"https://www.fpbase.org/api/proteins/?format=json\"\r\n\u001b[?2004l\r\u001b[?2004h> try:\r\n\u001b[?2004l\r\u001b[?2004h>     req = urllib.request.Request(url, headers={\"User-Agent\": \"Mozilla/5.0\"})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.567625, "o", "    with urllib.request.urlopen(req) as res:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.567719, "o", "        data = json.loads(res.read().decode())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.568021, "o", "        print(f\"Found {len(data)} proteins\")\r\n\u001b[?2004l\r\u001b[?2004h>         # Let's save the data to a file for parsing\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.568054, "o", "        with open(\"fpbase_proteins.json\", \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.568333, "o", "            json.dump(data, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.568376, "o", "except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"Error:\", e)\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
