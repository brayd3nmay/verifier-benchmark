[113.446608, "i", "cat << 'EOF' > search_antibody.py\nimport urllib.request\nimport json\nimport xml.etree.ElementTree as ET\nimport time\n\n# Let's use NCBI BLAST API to blast the heavy chain sequence or light chain sequence.\n# Sequence:\nheavy = \"QVQLQQSAAELARPGASVKMSCKASGYSFTTYTIHWVKQRPGQGLEWIGYINPSSGYAAYNQNFKDETTLTADPSSSTAYMELNSLTSEDSAVYYCAREKFYGYDYWGQGATLTVSS\"\n\n# We submit a BLAST job\nurl = f\"https://blast.ncbi.nlm.nih.gov/Blast.cgi?CMD=Put&DATABASE=nr&PROGRAM=blastp&QUERY={heavy}\"\ntry:\n    req = urllib.request.urlopen(url)\n    res = req.read().decode()\n    # We need to extract the RID\n    rid = \"\"\n    for line in res.splitlines():\n        if \"RID =\" in line:\n            rid = line.split(\"=\")[1].strip()\n            break\n    print(\"RID:\", rid)\n    if rid:\n        # Poll for results\n        while True:\n            time.sleep(5)\n            check_url = f\"https://blast.ncbi.nlm.nih.gov/Blast.cgi?CMD=Get&FORMAT_OBJECT=SearchInfo&RID={rid}\"\n            check_req = urllib.request.urlopen(check_url)\n            check_res = check_req.read().decode()\n            if \"Status=WAITING\" in check_res:\n                print(\"Waiting...\")\n                continue\n            elif \"Status=FAILED\" in check_res:\n                print(\"Failed\")\n                break\n            elif \"Status=UNKNOWN\" in check_res:\n                print(\"Unknown\")\n                break\n            elif \"Status=READY\" in check_res:\n                print(\"Ready!\")\n                if \"ThereAreHits=yes\" in check_res:\n                    # Get hits\n                    hits_url = f\"https://blast.ncbi.nlm.nih.gov/Blast.cgi?CMD=Get&FORMAT_TYPE=XML&RID={rid}\"\n                    hits_req = urllib.request.urlopen(hits_url)\n                    hits_res = hits_req.read().decode()\n                    # Let's parse XML or print a part of it\n                    print(hits_res[:2000])\n                else:\n                    print(\"No hits\")\n                break\nexcept Exception as e:\n    print(\"Error:\", e)\nEOF\npython3 search_antibody.py\n"]
[113.450961, "o", "cat << 'EOF' > search_antibody.py\r\n\u001b[?2004l\r"]
[113.452331, "o", "\u001b[?2004h> import urllib.request\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> import xml.etree.ElementTree as ET\r\n\u001b[?2004l\r\u001b[?2004h> import time\r\n"]
[113.453741, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[113.454725, "o", "# Let's use NCBI BLAST API to blast the heavy chain sequence or light chain sequence.\r\n\u001b[?2004l\r\u001b[?2004h> # Sequence:\r\n\u001b[?2004l\r\u001b[?2004h> heavy = \"QVQLQQSAAELARPGASVKMSCKASGYSFTTYTIHWVKQRPGQGLEWIGYINPSSGYAAYNQNFKDETTLTADPSSSTAYMELNSLTSEDSAVYYCAREKFYGYDYWGQGATLTVSS\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # We submit a BLAST job\r\n\u001b[?2004l\r\u001b[?2004h> url = f\"https://blast.ncbi.nlm.nih.gov/Blast.cgi?CMD=Put&DATABASE=nr&PROGRAM=blastp&QUERY={heavy}\"\r\n\u001b[?2004l\r\u001b[?2004h> try:\r\n\u001b[?2004l\r\u001b[?2004h>     req = urllib.request.urlopen(url)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[113.455609, "o", "    res = req.read().decode()\r\n\u001b[?2004l\r\u001b[?2004h>     # We need to extract the RID\r\n\u001b[?2004l\r"]
[113.455963, "o", "\u001b[?2004h>     rid = \"\"\r\n\u001b[?2004l\r\u001b[?2004h>     for line in res.splitlines():\r\n\u001b[?2004l\r\u001b[?2004h>         if \"RID =\" in line:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[113.456071, "o", "            rid = line.split(\"=\")[1].strip()\r\n\u001b[?2004l\r\u001b[?2004h>             break\r\n\u001b[?2004l\r"]
[113.456613, "o", "\u001b[?2004h> "]
[113.457058, "o", "    print(\"RID:\", rid)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[113.457336, "o", "    if rid:\r\n\u001b[?2004l\r\u001b[?2004h"]
[113.457479, "o", ">         # Poll for results\r\n\u001b[?2004l\r\u001b[?2004h>         while True:\r\n"]
[113.45763, "o", "\u001b[?2004l\r\u001b[?2004h>             time.sleep(5)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[113.457851, "o", "            check_url = f\"https://blast.ncbi.nlm.nih.gov/Blast.cgi?CMD=Get&FORMAT_OBJECT=SearchInfo&RID={rid}\"\r\n\u001b[?2004l\r\u001b[?2004h>             check_req = urllib.request.urlopen(check_url)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[113.458042, "o", "            check_res = check_req.read().decode()\r\n\u001b[?2004l\r\u001b[?2004h>             if \"Status=WAITING\" in check_res:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[113.458955, "o", "                print(\"Waiting...\")\r\n\u001b[?2004l\r\u001b[?2004h>                 continue\r\n\u001b[?2004l\r\u001b[?2004h>             elif \"Status=FAILED\" in check_res:\r\n\u001b[?2004l\r\u001b[?2004h>                 print(\"Failed\")\r\n\u001b[?2004l\r\u001b[?2004h>                 break\r\n\u001b[?2004l\r\u001b[?2004h>             elif \"Status=UNKNOWN\" in check_res:\r\n\u001b[?2004l\r\u001b[?2004h>                 print(\"Unknown\")\r\n\u001b[?2004l\r\u001b[?2004h>                 break\r\n\u001b[?2004l\r\u001b[?2004h>             elif \"Status=READY\" in check_res:\r\n\u001b[?2004l\r\u001b[?2004h>                 print(\"Ready!\")\r\n\u001b[?2004l\r\u001b[?2004h>                 if \"ThereAreHits=yes\" in check_res:\r\n\u001b[?2004l\r\u001b[?2004h"]
[113.459481, "o", ">                     # Get hits\r\n\u001b[?2004l\r\u001b[?2004h>                     hits_url = f\"https://blast.ncbi.nlm.nih.gov/Blast.cgi?CMD=Get&FORMAT_TYPE=XML&RID={rid}\"\r\n\u001b[?2004l\r\u001b[?2004h>                     hits_req = urllib.request.urlopen(hits_url)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[113.45986, "o", "                    hits_res = hits_req.read().decode()\r\n\u001b[?2004l\r\u001b[?2004h>                     # Let's parse XML or print a part of it\r\n\u001b[?2004l\r\u001b[?2004h>                     print(hits_res[:2000])\r\n\u001b[?2004l\r\u001b[?2004h>                 else:\r\n\u001b[?2004l\r\u001b[?2004h>                     print(\"No hits\")\r\n\u001b[?2004l\r\u001b[?2004h>                 break\r\n\u001b[?2004l\r"]
[113.459878, "o", "\u001b[?2004h> except Exception as e:\r\n\u001b[?2004l\r"]
