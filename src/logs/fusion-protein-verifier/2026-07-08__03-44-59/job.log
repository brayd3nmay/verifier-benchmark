Sending keys: ["cat << 'EOF' > /app/blast_antibody.py\nimport requests\nimport time\nwith open('/app/data/antibody.fasta', 'r') as f:\n    lines = f.read().split('>')[1:]\nheavy_seq = ''\nlight_seq = ''\nfor part in lines:\n    sublines = part.strip().split('\\n')\n    header = sublines[0]\n    seq = ''.join(sublines[1:])\n    if 'heavy' in header.lower():\n        heavy_seq = seq\n    elif 'light' in header.lower():\n        light_seq = seq\nprint('Heavy len:', len(heavy_seq))\nprint('Light len:', len(light_seq))\ndef blast_query(seq):\n    url = 'https://blast.ncbi.nlm.nih.gov/Blast.cgi'\n    params = {'CMD': 'Put', 'DATABASE': 'nr', 'PROGRAM': 'blastp', 'QUERY': seq}\n    r = requests.post(url, data=params)\n    rid = ''\n    for line in r.text.split('\\n'):\n        if 'RID =' in line:\n            rid = line.split('RID =')[1].strip()\n            break\n    if not rid:\n        return None\n    print('RID:', rid)\n    while True:\n        r_check = requests.get(url, params={'CMD': 'Get', 'RID': rid, 'FORMAT_OBJECT': 'SearchInfo'})\n        if 'Status=WAITING' in r_check.text:\n            time.sleep(5)\n            continue\n        break\n    r_res = requests.get(url, params={'CMD': 'Get', 'RID': rid, 'FORMAT_TYPE': 'XML'})\n    return r_res.text\nxml_res = blast_query(heavy_seq)\nif xml_res:\n    with open('/app/blast_heavy.xml', 'w') as f:\n        f.write(xml_res)\n    print('Saved')\nEOF\npython3 /app/blast_antibody.py\n"] min_timeout_sec: 10.0 max_timeout_sec: 180.0
