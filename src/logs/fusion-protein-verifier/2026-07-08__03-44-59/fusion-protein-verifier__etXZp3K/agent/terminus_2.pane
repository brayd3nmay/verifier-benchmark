[?2004l[?2004h> print('Light len:', len(light_seq))
[?2004l[?2004h> def blast_query(seq):
[?2004l[?2004h>     url = 'https://blast.ncbi.nlm.nih.gov/Blast.cgi'
[?2004l[?2004h>     params = {'CMD': 'Put', 'DATABASE': 'nr', 'PROGRAM': 'blastp', 'QUERY': seq}
[?2004l[?2004h>     r = requests.post(url, data=params)
[?2004l[?2004h>     rid = ''
[?2004l[?2004h>     for line in r.text.split('\n'):
[?2004l[?2004h>         if 'RID =' in line:
[?2004l[?2004h>             rid = line.split('RID =')[1].strip()
[?2004l[?2004h>             break
[?2004l[?2004h>     if not rid:
[?2004l[?2004h>         return None
[?2004l[?2004h>     print('RID:', rid)
[?2004l[?2004h>     while True:
[?2004l[?2004h>         r_check = requests.get(url, params={'CMD': 'Get', 'RID': rid, 'FORMAT_OBJECT': 'SearchInfo'})
[?2004l[?2004h>         if 'Status=WAITING' in r_check.text:
[?2004l[?2004h>             time.sleep(5)
[?2004l[?2004h>             continue
[?2004l[?2004h>         break
[?2004l[?2004h>     r_res = requests.get(url, params={'CMD': 'Get', 'RID': rid, 'FORMAT_TYPE': 'XML'})
[?2004l[?2004h>     return r_res.text
[?2004l[?2004h> xml_res = blast_query(heavy_seq)
[?2004l[?2004h> if xml_res:
[?2004l[?2004h>     with open('/app/blast_heavy.xml', 'w') as f:
