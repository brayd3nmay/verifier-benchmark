[?2004l[?2004h>     header = sublines[0]
[?2004l[?2004h>     seq = ''.join(sublines[1:])
[?2004l[?2004h>     if 'heavy' in header.lower():
[?2004l[?2004h>         heavy_seq = seq
[?2004l[?2004h>     elif 'light' in header.lower():
[?2004l[?2004h>         light_seq = seq
