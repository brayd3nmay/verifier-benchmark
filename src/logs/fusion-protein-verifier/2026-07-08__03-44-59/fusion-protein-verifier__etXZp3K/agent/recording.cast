[590.304977, "o", "\u001b[?2004h> "]
[590.305342, "o", "import os\r\n\u001b[?2004l\r\u001b[?2004h> import sys\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> CODON_MAP = {\r\n\u001b[?2004l\r\u001b[?2004h>     'ATA':'I', 'ATC':'I', 'ATT':'I', 'ATG':'M',\r\n\u001b[?2004l\r\u001b[?2004h>     'ACA':'T', 'ACC':'T', 'ACG':'T', 'ACT':'T',\r\n\u001b[?2004l\rv"]
[590.305365, "o", "\u001b[?2004h> "]
[590.305751, "o", "    'AAC':'N', 'AAT':'N', 'AAA':'K', 'AAG':'K',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.305815, "o", "    'AGC':'S', 'AGT':'S', 'AGA':'R', 'AGG':'R',\r\n\u001b[?2004l\rk_path = os.p\u001b[?2004h> "]
[590.306104, "o", "    'CTA':'L', 'CTC':'L', 'CTG':'L', 'CTT':'L',\r\n\u001b[?2004l\r\u001b[?2004h>     'CCA':'P', 'CCC':'P', 'CCG':'P', 'CCT':'P',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.306362, "o", "    'CAC':'H', 'CAT':'H', 'CAA':'Q', 'CAG':'Q',\r\n\u001b[?2004l\rdi\u001b[?2004h>     'CGA':'R', 'CGC':'R', 'CGG':'R', 'CGT':'R',\r\n\u001b[?2004l\rk=True)"]
[590.306543, "o", "\u001b[?2004h>     'GTA':'V', 'GTC':'V', 'GTG':'V', 'GTT':'V',\r\n\u001b[?2004l\r\u001b[?2004h>     'GCA':'A', 'GCC':'A', 'GCG':'A', 'GCT':'A',\r\n\u001b[?2004l\r  f.write(str(verdict))\r\nEOF\r\n"]
[590.306836, "o", "\u001b[?2004h>     'GAC':'D', 'GAT':'D', 'GAA':'E', 'GAG':'E',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.306926, "o", "    'GGA':'G', 'GGC':'G', 'GGG':'G', 'GGT':'G',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.307126, "o", "    'TCA':'S', 'TCC':'S', 'TCG':'S', 'TCT':'S',\r\n\u001b[?2004l\r\u001b[?2004h>     'TTC':'F', 'TTT':'F', 'TTA':'L', 'TTG':'L',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.307254, "o", "    'TAC':'Y', 'TAT':'Y', 'TAA':'*', 'TAG':'*',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.307288, "o", "    'TGC':'C', 'TGT':'C', 'TGA':'*', 'TGG':'W',\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[590.307399, "o", "> def translate(dna):\r\n\u001b[?2004l\r\u001b[?2004h"]
[590.307525, "o", ">     return ''.join([CODON_MAP.get(dna[i:i+3], '?') for i in range(0, len(dna), 3)])\r\n\u001b[?2004l\r\u001b[?2004h"]
[590.307731, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.307916, "o", "def check_gblock(gblock_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.308228, "o", "    if not os.path.exists(gblock_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.308354, "o", "        return 0, \"File not found\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.308385, "o", "    with open(gblock_path, 'rb') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.308473, "o", "        raw = f.read()\r\n\u001b[?2004l\r"]
[590.308775, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     text = raw.decode('utf-8', errors='ignore')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.308873, "o", "    raw_lines = text.splitlines()\r\n\u001b[?2004l\r\u001b[?2004h>     non_empty = [l for l in raw_lines if l.strip()]\r\n\u001b[?2004l\r\u001b[?2004h>     if len(non_empty) != 1:\r\n\u001b[?2004l\r\u001b[?2004h"]
[590.308889, "o", "> "]
[590.309065, "o", "        return 0, f\"Expected 1 non-empty line, found {len(non_empty)}\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Check single line with no other empty lines\r\n\u001b[?2004l\r\u001b[?2004h>     if b'\\n' in raw:\r\n\u001b[?2004l\r"]
[590.309187, "o", "\u001b[?2004h>         first_nl = raw.index(b'\\n')\r\n\u001b[?2004l\r\u001b[?2004h>         if first_nl < len(raw) - 1:\r\n\u001b[?2004l\r\u001b[?2004h"]
[590.309288, "o", "> "]
[590.30948, "o", "            remaining = raw[first_nl+1:]\r\n\u001b[?2004l\r\u001b[?2004h>             if remaining.strip() or remaining.count(b'\\n') > 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.309608, "o", "                return 0, \"Contains multiple lines\"\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.309728, "o", "    gblock_seq = non_empty[0].strip().upper()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.309747, "o", "    if not all(c in 'ATCG' for c in gblock_seq):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.309906, "o", "        return 0, \"Contains non-ATCG\"\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.309932, "o", "    if len(gblock_seq) > 3000:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.310047, "o", "        return 0, \"Length > 3000\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.310294, "o", "    if len(gblock_seq) % 3 != 0:\r\n\u001b[?2004l\r\u001b[?2004h>         return 0, \"Length not multiple of 3\"\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>     for i in range(len(gblock_seq) - 49):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.310443, "o", "        window = gblock_seq[i:i+50]\r\n\u001b[?2004l\r\u001b[?2004h>         gc = sum(1 for c in window if c in 'GC')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.310545, "o", "        if not (15 <= gc <= 35):\r\n\u001b[?2004l\r\u001b[?2004h>             return 0, f\"GC window failed at {i}\"\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.310669, "o", "    protein = translate(gblock_seq)\r\n\u001b[?2004l\r\u001b[?2004h>     if '*' in protein:\r\n\u001b[?2004l\r"]
[590.310915, "o", "\u001b[?2004h>         return 0, \"Contains stop codon\"\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>     sub1 = \"DYKDDDDK\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.311262, "o", "    sub2 = \"GSSHHHHHHSSGENLYFQGHMVSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK\"\r\n\u001b[?2004l\r"]
[590.311385, "o", "\u001b[?2004h> "]
[590.311509, "o", "    sub3 = \"ISLIAALAVDRVIGMENAMPWNLPADLAWFKRNTLNKPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCFEILERR\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[590.311678, "o", "> "]
[590.311899, "o", "    sub4 = \"VSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQMYGSKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK\"\r\n\u001b[?2004l\r"]
[590.312044, "o", "\u001b[?2004h> "]
[590.312183, "o", "    sub5 = \"GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.312351, "o", "    if not protein.startswith(sub1):\r\n\u001b[?2004l\r\u001b[?2004h>         return 0, \"No sub1 start\"\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[590.312366, "o", "\u001b[?2004h> "]
[590.312448, "o", "    idx2 = protein.find(sub2)\r\n\u001b[?2004l\r\u001b[?2004h>     if idx2 == -1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.312578, "o", "        return 0, \"sub2 not found\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.312666, "o", "    linker1 = protein[len(sub1):idx2]\r\n\u001b[?2004l\r"]
[590.312687, "o", "\u001b[?2004h"]
[590.312884, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h>     idx3 = protein.find(sub3, idx2 + len(sub2))\r\n\u001b[?2004l\r\u001b[?2004h>     if idx3 == -1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.312922, "o", "        return 0, \"sub3 not found\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.313021, "o", "    linker2 = protein[idx2 + len(sub2):idx3]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.313133, "o", "    idx4 = protein.find(sub4, idx3 + len(sub3))\r\n\u001b[?2004l\r\u001b[?2004h"]
[590.313181, "o", ">     if idx4 == -1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.313337, "o", "        return 0, \"sub4 not found\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.313408, "o", "    linker3 = protein[idx3 + len(sub3):idx4]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.313427, "o", "    if not protein.endswith(sub5):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.313502, "o", "        return 0, \"No sub5 end\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.313576, "o", "    linker4 = protein[idx4 + len(sub4):len(protein)-len(sub5)]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[590.313593, "o", "> "]
[590.313702, "o", "    for i, l in enumerate([linker1, linker2, linker3, linker4], 1):\r\n\u001b[?2004l\r\u001b[?2004h>         if not (5 <= len(l) <= 20):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[590.313778, "o", "            return 0, f\"Linker {i} len {len(l)} not between 5 and 20\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
