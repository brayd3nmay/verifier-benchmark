[386.743872, "i", "cat << 'EOF' > /app/get_entity_details.py\nimport requests\nfor pdb_id in ['3KZY', '5WJ2', '2H5Q']:\n    url = f'https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1'\n    r = requests.get(url)\n    if r.status_code == 200:\n        data = r.json()\n        poly = data.get('entity_poly', {})\n        print(pdb_id)\n        print('  code:', poly.get('pdbx_seq_one_letter_code'))\n        print('  can:', poly.get('pdbx_seq_one_letter_code_can'))\n    else:\n        print(pdb_id, 'Error', r.status_code)\nEOF\npython3 /app/get_entity_details.py\n"]
[386.750184, "o", "cat << 'EOF' > /app/get_entity_details.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> for pdb_id in ['3KZY', '5WJ2', '2H5Q']:\r\n\u001b[?2004l\r\u001b[?2004h>     url = f'https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1'\r\n\u001b[?2004l\r\u001b[?2004h>     r = requests.get(url)\r\n\u001b[?2004l\r\u001b[?2004h>     if r.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>         data = r.json()\r\n\u001b[?2004l\r\u001b[?2004h>         poly = data.get('entity_poly', {})\r\n\u001b[?2004l\r\u001b[?2004h>         print(pdb_id)\r\n\u001b[?2004l\r\u001b[?2004h>         print('  code:', poly.get('pdbx_seq_one_letter_code'))\r\n\u001b[?2004l\r\u001b[?2004h>         print('  can:', poly.get('pdbx_seq_one_letter_code_can'))\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         print(pdb_id, 'Error', r.status_code)\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
