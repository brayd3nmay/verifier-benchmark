[635.609342, "i", "cat << 'EOF' > /app/test_dynamic_derive.py\nimport requests\nimport os\n\ndef derive_references():\n    res_molecule = \"GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR\"\n    res_donor = \"GSSHHHHHHSSGENLYFQGHMVSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK\"\n    res_acceptor = \"VSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQMYGSKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK\"\n    pdb_ids_path = '/app/data/pdb_ids.txt'\n    if not os.path.exists(pdb_ids_path):\n        return res_molecule, res_donor, res_acceptor\n    with open(pdb_ids_path, 'r') as f:\n        pdb_ids = [line.strip().upper() for line in f if line.strip()]\n    try:\n        print('Fetching FPBase...')\n        r_fp = requests.get('https://www.fpbase.org/api/proteins/?format=json', timeout=10)\n        if r_fp.status_code == 200:\n            fps = r_fp.json()\n            donor_names = []\n            acceptor_names = []\n            for fp in fps:\n                states = fp.get('states', [])\n                for st in states:\n                    if st.get('ex_max') == 505:\n                        donor_names.append(fp.get('name').lower())\n                    if st.get('em_max') == 610:\n                        acceptor_names.append(fp.get('name').lower())\n            print('FPBase donor names:', donor_names)\n            print('FPBase acceptor names:', acceptor_names)\n    except Exception as e:\n        print('FPBase fetch error:', e)\n    return res_molecule, res_donor, res_acceptor\nderive_references()\nEOF\npython3 /app/test_dynamic_derive.py\n"]
[635.614685, "o", "cat << 'EOF' > /app/test_dynamic_derive.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> import os\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def derive_references():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[635.615506, "o", "    res_molecule = \"GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR\"\r\n\u001b[?2004l\r\u001b[?2004h>     res_donor = \"GSSHHHHHHSSGENLYFQGHMVSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK\"\r\n\u001b[?2004l\r\u001b[?2004h>     res_acceptor = \"VSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQMYGSKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK\"\r\n\u001b[?2004l\r\u001b[?2004h>     pdb_ids_path = '/app/data/pdb_ids.txt'\r\n\u001b[?2004l\r\u001b[?2004h>     if not os.path.exists(pdb_ids_path):\r\n\u001b[?2004l\r\u001b[?2004h>         return res_molecule, res_donor, res_acceptor\r\n\u001b[?2004l\r\u001b[?2004h>     with open(pdb_ids_path, 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h>         pdb_ids = [line.strip().upper() for line in f if line.strip()]\r\n\u001b[?2004l\r"]
[635.622055, "o", "\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         print('Fetching FPBase...')\r\n\u001b[?2004l\r\u001b[?2004h>         r_fp = requests.get('https://www.fpbase.org/api/proteins/?format=json', timeout=10)\r\n\u001b[?2004l\r\u001b[?2004h>         if r_fp.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>             fps = r_fp.json()\r\n\u001b[?2004l\r\u001b[?2004h>             donor_names = []\r\n\u001b[?2004l\r\u001b[?2004h>             acceptor_names = []\r\n\u001b[?2004l\r\u001b[?2004h>             for fp in fps:\r\n\u001b[?2004l\r\u001b[?2004h>                 states = fp.get('states', [])\r\n\u001b[?2004l\r\u001b[?2004h>                 for st in states:\r\n\u001b[?2004l\r\u001b[?2004h>                     if st.get('ex_max') == 505:\r\n\u001b[?2004l\r\u001b[?2004h>                         donor_names.append(fp.get('name').lower())\r\n\u001b[?2004l\r\u001b[?2004h>                     if st.get('em_max') == 610:\r\n\u001b[?2004l\r\u001b[?2004h>                         acceptor_names.append(fp.get('name').lower())\r\n\u001b[?2004l\r\u001b[?2004h>             print('FPBase donor names:', donor_names)\r\n\u001b[?2004l\r\u001b[?2004h>             print('FPBase acceptor names:', acceptor_names)\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         print('FPBase fetch error:', e)\r\n\u001b[?2004l\r\u001b[?2004h>     return res_molecule, res_donor, res_acceptor\r\n\u001b[?2004l\r\u001b[?2004h> derive_references()\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
