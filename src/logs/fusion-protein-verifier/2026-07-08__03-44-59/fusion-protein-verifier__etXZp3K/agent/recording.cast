[326.520671, "i", "cat << 'EOF' > /app/get_light_blast_res.py\nimport requests\nrid = '4W098S7E014'\nurl = 'https://blast.ncbi.nlm.nih.gov/Blast.cgi'\nr = requests.get(url, params={'CMD': 'Get', 'RID': rid, 'FORMAT_TYPE': 'Text'})\nwith open('/app/blast_light_res.txt', 'w') as f:\n    f.write(r.text)\nlines = r.text.split('\\n')\nfor l in lines[:50]:\n    print(l)\nEOF\npython3 /app/get_light_blast_res.py\n"]
