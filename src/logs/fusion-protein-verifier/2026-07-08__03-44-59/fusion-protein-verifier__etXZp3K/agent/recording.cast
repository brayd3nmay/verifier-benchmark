[130.482728, "o", "    pdb_list = ['2IB5','4KGE','4Q7T','5JZL','6AA7','3ADF','5WJ2','3M22','2H5Q','3MGF','5Y01','2VZX','4CQH','1YZW','1H6R']\r\n\u001b[?2004l\r\u001b[?2004h> "]
