[213.198355, "i", "cat << 'EOF' > /app/get_blast_text.py\nimport requests\nrid = '4W05HNJN014'\nurl = 'https://blast.ncbi.nlm.nih.gov/Blast.cgi'\nr = requests.get(url, params={'CMD': 'Get', 'RID': rid, 'FORMAT_TYPE': 'Text'})\nwith open('/app/blast_res.txt', 'w') as f:\n    f.write(r.text)\nlines = r.text.split('\\n')\nfor l in lines[:50]:\n    print(l)\nEOF\npython3 /app/get_blast_text.py\n"]
