[120.845314, "i", "cat << 'EOF' > /app/test_fpbase.py\nimport requests\nurl = 'https://www.fpbase.org/api/proteins/?format=json'\ntry:\n    r = requests.get(url)\n    if r.status_code == 200:\n        data = r.json()\n        print('Fetched', len(data), 'proteins')\n        for fp in data:\n            name = fp.get('name')\n            ex = fp.get('ex_max')\n            em = fp.get('em_max')\n            pdbs = fp.get('pdb', [])\n            if ex == 505:\n                print('Excitation 505:', name, 'PDBs:', pdbs)\n            if em == 610:\n                print('Emission 610:', name, 'PDBs:', pdbs)\n    else:\n        print('FPBase HTTP', r.status_code)\nexcept Exception as e:\n    print('FPBase error', e)\nEOF\npython3 /app/test_fpbase.py\n"]
[120.85207, "o", "cat << 'EOF' > /app/test_fpbase.py"]
