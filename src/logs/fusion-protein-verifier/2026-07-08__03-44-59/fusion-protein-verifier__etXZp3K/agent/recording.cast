[468.271553, "i", "cat << 'EOF' > /app/check_lengths.py\nimport requests\nfor p in ['5WJ2', '2H5Q']:\n    res = requests.get(f'https://www.rcsb.org/fasta/entry/{p}')\n    lines = res.text.split('\\n')\n    seq = ''.join([l.strip() for l in lines[1:] if l.strip()])\n    print(p, 'FASTA len:', len(seq), 'seq:', seq)\nEOF\npython3 /app/check_lengths.py\n"]
