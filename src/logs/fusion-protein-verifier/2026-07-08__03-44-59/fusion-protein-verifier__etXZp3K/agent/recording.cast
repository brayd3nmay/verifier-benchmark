[99.989499, "i", "cat << 'EOF' > /app/test_pdb.py\nimport requests\nimport json\npdb_ids = ['2IB5','4KGE','4Q7T','1KFD','5JZL','6AA7','3ADF','5WJ2','3M22','2H5Q','3MGF','5Y01','2VZX','4CQH','1YZW','2CHA','3KZY','1AK4','5P21','1H6R']\nfor p in pdb_ids:\n    url = f'https://data.rcsb.org/rest/v1/core/entry/{p}'\n    try:\n        res = requests.get(url)\n        if res.status_code == 200:\n            data = res.json()\n            title = data.get('struct', {}).get('title', '')\n            print(f'{p}: {title}')\n        else:\n            print(f'{p}: HTTP {res.status_code}')\n    except Exception as e:\n        print(f'{p}: Error {e}')\nEOF\npython3 /app/test_pdb.py\n"]
[100.005972, "o", "cat << 'EOF' > /app/test_pdb.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> pdb_ids = ['2IB5','4KGE','4Q7T','1KFD','5JZL','6AA7','3ADF','5WJ2','3M22','2H5Q','3MGF','5Y01','2VZX','4CQH','1YZW','2CHA','3KZY','1AK4','5P21','1H6R']\r\n\u001b[?2004l\r\u001b[?2004h> for p in pdb_ids:\r\n\u001b[?2004l\r\u001b[?2004h>     url = f'https://data.rcsb.org/rest/v1/core/entry/{p}'\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         res = requests.get(url)\r\n\u001b[?2004l\r\u001b[?2004h>         if res.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>             data = res.json()\r\n\u001b[?2004l\r\u001b[?2004h>             title = data.get('struct', {}).get('title', '')\r\n\u001b[?2004l\r\u001b[?2004h>             print(f'{p}: {title}')\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(f'{p}: HTTP {res.status_code}')\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f'{p}: Error {e}')\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
