[130.478906, "i", "cat << 'EOF' > /app/inspect_fp.py\nimport requests\nurl = 'https://www.fpbase.org/api/proteins/?format=json'\nr = requests.get(url)\nif r.status_code == 200:\n    data = r.json()\n    print('Sample entry keys:', list(data[0].keys()))\n    # Let's search for entries whose PDB contains any in our list\n    pdb_list = ['2IB5','4KGE','4Q7T','5JZL','6AA7','3ADF','5WJ2','3M22','2H5Q','3MGF','5Y01','2VZX','4CQH','1YZW','1H6R']\n    pdb_set = set(pdb_list)\n    for fp in data:\n        pdbs = fp.get('pdb', [])\n        if not isinstance(pdbs, list):\n            pdbs = [pdbs]\n        # pdbs might be uppercase/lowercase or contain the string\n        matched = []\n        for p in pdbs:\n            if str(p).upper() in pdb_set:\n                matched.append(p)\n        if matched:\n            print('Matched FP:', fp.get('name'), 'PDB:', matched, 'ex:', fp.get('ex_max'), 'em:', fp.get('em_max'), 'states:', fp.get('states'))\nEOF\npython3 /app/inspect_fp.py\n"]
[130.4813, "o", "cat << 'EOF' > /app/inspect_fp.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> url = 'https://www.fpbase.org/api/proteins/?format=json'\r\n\u001b[?2004l\r\u001b[?2004h> r = requests.get(url)\r\n\u001b[?2004l\r\u001b[?2004h> if r.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.481353, "o", "    data = r.json()\r\n\u001b[?2004l\r"]
