[270.984238, "i", "cat << 'EOF' > /app/get_light_blast.py\nimport requests\nimport time\nwith open('/app/data/antibody.fasta', 'r') as f:\n    lines = f.read().split('>')\nlight_seq = ''\nfor part in lines:\n    if not part.strip(): continue\n    sublines = part.strip().split('\\n')\n    header = sublines[0]\n    seq = ''.join(sublines[1:])\n    if 'light' in header.lower():\n        light_seq = seq\n        break\nprint('Light seq:', light_seq[:30])\nurl = 'https://blast.ncbi.nlm.nih.gov/Blast.cgi'\nparams = {'CMD': 'Put', 'DATABASE': 'nr', 'PROGRAM': 'blastp', 'QUERY': light_seq}\nr = requests.post(url, data=params)\nrid = ''\nfor line in r.text.split('\\n'):\n    if 'RID =' in line:\n        rid = line.split('RID =')[1].strip()\n        break\nprint('RID:', rid)\nwhile True:\n    r_check = requests.get(url, params={'CMD': 'Get', 'RID': rid, 'FORMAT_OBJECT': 'SearchInfo'})\n    if 'Status=WAITING' in r_check.text:\n        time.sleep(5)\n        continue\n    break\nr_res = requests.get(url, params={'CMD': 'Get', 'RID': rid, 'FORMAT_TYPE': 'Text'})\nwith open('/app/blast_light_res.txt', 'w') as f:\n    f.write(r_res.text)\nlines = r_res.text.split('\\n')\nfor l in lines[:50]:\n    print(l)\nEOF\npython3 /app/get_light_blast.py\n"]
