[450.968427, "i", "cat << 'EOF' > /app/get_poly_seqs.py\nimport requests\nfor pdb_id in ['5WJ2', '2H5Q']:\n    url = f'https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1'\n    r = requests.get(url)\n    if r.status_code == 200:\n        data = r.json()\n        poly = data.get('entity_poly', {})\n        print(pdb_id, 'keys:', list(poly.keys()))\n        for k, v in poly.items():\n            if 'seq' in k or 'code' in k:\n                print(f'  {k}: {str(v)[:100]}...')\nEOF\npython3 /app/get_poly_seqs.py\n"]
