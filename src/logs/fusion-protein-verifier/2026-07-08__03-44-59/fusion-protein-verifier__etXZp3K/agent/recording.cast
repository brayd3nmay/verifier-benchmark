[620.786539, "i", "cat << 'EOF' > /app/test_parse_gb.py\ndef parse_dhfr_from_gb(path):\n    with open(path, 'r') as f:\n        content = f.read()\n    idx = content.find('dihydrofolate reductase (DHFR)')\n    if idx == -1:\n        idx = content.find('folA')\n    if idx == -1:\n        return None\n    t_idx = content.find('/translation=\"', idx)\n    if t_idx == -1:\n        return None\n    t_start = t_idx + len('/translation=\"')\n    t_end = content.find('\"', t_start)\n    raw_seq = content[t_start:t_end]\n    seq = ''.join(raw_seq.split())\n    return seq\nprint('DHFR:', parse_dhfr_from_gb('/app/data/plasmid.gb'))\nEOF\npython3 /app/test_parse_gb.py\n"]
[620.791368, "o", "cat << 'EOF' > /app/test_parse_gb.py\r\n\u001b[?2004l\r\u001b[?2004h> def parse_dhfr_from_gb(path):\r\n\u001b[?2004l\r\u001b[?2004h>     with open(path, 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h>         content = f.read()\r\n\u001b[?2004l\r\u001b[?2004h>     idx = content.find('dihydrofolate reductase (DHFR)')\r\n\u001b[?2004l\r\u001b[?2004h>     if idx == -1:\r\n\u001b[?2004l\r\u001b[?2004h>         idx = content.find('folA')\r\n\u001b[?2004l\r\u001b[?2004h>     if idx == -1:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h>     t_idx = content.find('/translation=\"', idx)\r\n\u001b[?2004l\r\u001b[?2004h>     if t_idx == -1:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h>     t_start = t_idx + len('/translation=\"')\r\n\u001b[?2004l\r\u001b[?2004h>     t_end = content.find('\"', t_start)\r\n\u001b[?2004l\r\u001b[?2004h>     raw_seq = content[t_start:t_end]\r\n\u001b[?2004l\r\u001b[?2004h>     seq = ''.join(raw_seq.split())\r\n\u001b[?2004l\r\u001b[?2004h>     return seq\r\n\u001b[?2004l\r\u001b[?2004h> print('DHFR:', parse_dhfr_from_gb('/app/data/plasmid.gb'))\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
