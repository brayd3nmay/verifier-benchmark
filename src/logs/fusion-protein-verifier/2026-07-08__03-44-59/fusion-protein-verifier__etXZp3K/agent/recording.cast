[200.795051, "i", "cat << 'EOF' > /app/get_blast.py\nimport requests\nimport xml.etree.ElementTree as ET\nrid = '4W05HNJN014'\nurl = 'https://blast.ncbi.nlm.nih.gov/Blast.cgi'\nprint('Checking status of', rid)\nr = requests.get(url, params={'CMD': 'Get', 'RID': rid, 'FORMAT_OBJECT': 'SearchInfo'})\nprint(r.text)\nif 'Status=READY' in r.text:\n    print('Ready! Fetching XML...')\n    r_res = requests.get(url, params={'CMD': 'Get', 'RID': rid, 'FORMAT_TYPE': 'XML'})\n    with open('/app/blast_heavy.xml', 'w') as f:\n        f.write(r_res.text)\n    print('Saved /app/blast_heavy.xml')\nEOF\npython3 /app/get_blast.py\n"]
