[366.368153, "i", "cat << 'EOF' > /app/get_pdb_seqs.py\nimport requests\ndef get_pdb_seq(pdb_id):\n    r_fasta = requests.get(f'https://www.rcsb.org/fasta/entry/{pdb_id}')\n    if r_fasta.status_code == 200:\n        print(f'{pdb_id} FASTA:')\n        print(r_fasta.text)\n    else:\n        print(f'Error {pdb_id}')\nfor p in ['3KZY', '5WJ2', '2H5Q']:\n    get_pdb_seq(p)\nEOF\npython3 /app/get_pdb_seqs.py\n"]
[366.376422, "o", "cat << 'EOF' > /app/get_pdb_seqs.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> def get_pdb_seq(pdb_id):\r\n\u001b[?2004l\r\u001b[?2004h>     r_fasta = requests.get(f'https://www.rcsb.org/fasta/entry/{pdb_id}')\r\n\u001b[?2004l\r\u001b[?2004h>     if r_fasta.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f'{pdb_id} FASTA:')\r\n\u001b[?2004l\r\u001b[?2004h>         print(r_fasta.text)\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f'Error {pdb_id}')\r\n\u001b[?2004l\r\u001b[?2004h> for p in ['3KZY', '5WJ2', '2H5Q']:\r\n\u001b[?2004l\r\u001b[?2004h>     get_pdb_seq(p)\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
