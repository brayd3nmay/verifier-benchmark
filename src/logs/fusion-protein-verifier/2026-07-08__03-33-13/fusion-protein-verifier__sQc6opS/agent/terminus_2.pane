[?2004hroot@1120f1c9a9fd:/app# which blastp
[?2004l[?2004hroot@1120f1c9a9fd:/app# cat << 'EOF' > /app/blast_antibody.py
[?2004l[?2004h> from Bio.Blast import NCBIWWW
[?2004l[?2004h> from Bio import SeqIO
[?2004l[?2004h> 
[?2004l[?2004h> # Read the light chain or heavy chain
[?2004l[?2004h> records = list(SeqIO.parse("/app/data/antibody.fasta", "fasta"))
[?2004l[?2004h> for r in records:
[?2004l[?2004h>     print(f"BLASTing {r.id}...")
[?2004l[?2004h>     # We can do a quick blastp search on NCBI
[?2004l[?2004h>     result_handle = NCBIWWW.qblast("blastp", "nr", r.seq, hitlist_size=10)
[?2004l[?2004h>     with open(f"/app/{r.id.replace(' ', '_')}_blast.xml", "w") as out_f:
[?2004l[?2004h>         out_f.write(result_handle.read())
[?2004l[?2004h>     print(f"Done BLASTing {r.id}.")
[?2004l[?2004h> EOF
