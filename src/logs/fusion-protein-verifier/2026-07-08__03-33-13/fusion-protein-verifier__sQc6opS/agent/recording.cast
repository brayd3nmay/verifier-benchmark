[29.158946, "i", "cat << 'EOF' > /app/get_fpbase_info.py\nimport requests\n\n# Let's search the GraphQL API of FPBase\n# The endpoint is https://www.fpbase.org/graphql/\nurl = \"https://www.fpbase.org/graphql/\"\n\nquery = \"\"\"\nquery {\n  allProteins {\n    name\n    slug\n    seq\n    primaryPdb\n    exMax\n    emMax\n  }\n}\n\"\"\"\n\nr = requests.post(url, json={'query': query})\nif r.status_code == 200:\n    data = r.json()\n    proteins = data.get(\"data\", {}).get(\"allProteins\", [])\n    print(f\"Found {len(proteins)} proteins in FPBase\")\n    for p in proteins:\n        pdb = p.get(\"primaryPdb\")\n        ex = p.get(\"exMax\")\n        em = p.get(\"emMax\")\n        if pdb:\n            print(f\"{p['name']} ({pdb}): ex={ex}, em={em}\")\n        # Also print if ex is 505 or em is 610\n        if ex == 505 or em == 610:\n            print(f\"MATCH: {p['name']} ({pdb}): ex={ex}, em={em}, slug={p['slug']}\")\nelse:\n    print(\"GraphQL failed, status:\", r.status_code, r.text)\nEOF\npython3 /app/get_fpbase_info.py\n"]
[29.1633, "o", "cat << 'EOF' > /app/get_fpbase_info.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's search the GraphQL API of FPBase\r\n\u001b[?2004l\r\u001b[?2004h> # The endpoint is https://www.fpbase.org/graphql/\r\n\u001b[?2004l\r\u001b[?2004h> url = \"https://www.fpbase.org/graphql/\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> query = \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> query {\r\n\u001b[?2004l\r\u001b[?2004h>   allProteins {\r\n\u001b[?2004l\r\u001b[?2004h>     name\r\n\u001b[?2004l\r\u001b[?2004h>     slug\r\n\u001b[?2004l\r\u001b[?2004h>     seq\r\n\u001b[?2004l\r\u001b[?2004h>     primaryPdb\r\n\u001b[?2004l\r\u001b[?2004h>     exMax\r\n\u001b[?2004l\r\u001b[?2004h>     emMax\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> r = requests.post(url, json={'query': query})\r\n\u001b[?2004l\r\u001b[?2004h> if r.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>     data = r.json()\r\n\u001b[?2004l\r\u001b[?2004h>     proteins = data.get(\"data\", {}).get(\"allProteins\", [])\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Found {len(proteins)} proteins in FPBase\")\r\n\u001b[?2004l\r\u001b[?2004h>     for p in proteins:\r\n\u001b[?2004l\r\u001b[?2004h>         pdb = p.get(\"primaryPdb\")\r\n\u001b[?2004l\r\u001b[?2004h>         ex = p.get(\"exMax\")\r\n\u001b[?2004l\r\u001b[?2004h>         em = p.get(\"emMax\")\r\n\u001b[?2004l\r\u001b[?2004h>         if pdb:\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"{p['name']} ({pdb}): ex={ex}, em={em}\")\r\n\u001b[?2004l\r\u001b[?2004h>         # Also print if ex is 505 or em is 610\r\n\u001b[?2004l\r\u001b[?2004h>         if ex == 505 or em == 610:\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"MATCH: {p['name']} ({pdb}): ex={ex}, em={em}, slug={p['slug']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[29.163346, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
