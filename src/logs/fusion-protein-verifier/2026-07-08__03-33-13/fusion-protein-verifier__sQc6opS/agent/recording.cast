[55.268078, "i", "cat << 'EOF' > /app/get_fpbase_rest.py\nimport requests\nres = requests.get(\"https://www.fpbase.org/api/proteins/?format=json\")\nif res.status_code == 200:\n    data = res.json()\n    print(\"Parsed\", len(data), \"proteins\")\n    # Let's print the first protein's states to see the structure\n    if data:\n        print(\"First protein states structure:\", data[0]['states'])\n    \n    for p in data:\n        name = p.get(\"name\")\n        slug = p.get(\"slug\")\n        pdb_list = p.get(\"pdb\", [])\n        seq = p.get(\"seq\", \"\")\n        for state in p.get(\"states\", []):\n            ex = state.get(\"ex_max\")\n            em = state.get(\"em_max\")\n            if ex == 505:\n                print(f\"EX MATCH (505): {name} ({slug}) | pdb: {pdb_list} | ex={ex}, em={em} | seq len={len(seq)}\")\n            if em == 610:\n                print(f\"EM MATCH (610): {name} ({slug}) | pdb: {pdb_list} | ex={ex}, em={em} | seq len={len(seq)}\")\nelse:\n    print(\"REST failed:\", res.status_code)\nEOF\npython3 /app/get_fpbase_rest.py\n"]
