[232.351526, "i", "cat << 'EOF' > /app/get_antibody_pdb_info.py\nimport requests\n\nfor pdb_id in ['8RMO', '7BG1']:\n    url = f\"https://data.rcsb.org/rest/v1/core/entry/{pdb_id}\"\n    r = requests.get(url)\n    if r.status_code == 200:\n        data = r.json()\n        title = data.get(\"struct\", {}).get(\"title\", \"\")\n        print(f\"{pdb_id}: {title}\")\n        # Let's see the polymer entities to see what else is in this structure\n        entity_ids = data.get(\"rcsb_entry_container_identifiers\", {}).get(\"polymer_entity_ids\", [])\n        print(f\"  Polymer entity IDs: {entity_ids}\")\n        for ent in entity_ids:\n            ent_url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/{ent}\"\n            er = requests.get(ent_url)\n            if er.status_code == 200:\n                edata = er.json()\n                desc = edata.get(\"rcsb_polymer_entity\", {}).get(\"pdbx_description\", \"\")\n                print(f\"    Entity {ent}: {desc}\")\n            else:\n                print(f\"    Entity {ent} fetch failed\")\n    else:\n        print(f\"{pdb_id} fetch failed\")\nEOF\npython3 /app/get_antibody_pdb_info.py\n"]
[232.355077, "o", "cat << 'EOF' > /app/get_antibody_pdb_info.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for pdb_id in ['8RMO', '7BG1']:\r\n\u001b[?2004l\r\u001b[?2004h>     url = f\"https://data.rcsb.org/rest/v1/core/entry/{pdb_id}\"\r\n\u001b[?2004l\r\u001b[?2004h>     r = requests.get(url)\r\n\u001b[?2004l\r\u001b[?2004h>     if r.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>         data = r.json()\r\n\u001b[?2004l\r\u001b[?2004h>         title = data.get(\"struct\", {}).get(\"title\", \"\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"{pdb_id}: {title}\")\r\n\u001b[?2004l\r\u001b[?2004h>         # Let's see the polymer entities to see what else is in this structure\r\n\u001b[?2004l\r\u001b[?2004h>         entity_ids = data.get(\"rcsb_entry_container_identifiers\", {}).get(\"polymer_entity_ids\", [])\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"  Polymer entity IDs: {entity_ids}\")\r\n\u001b[?2004l\r\u001b[?2004h>         for ent in entity_ids:\r\n\u001b[?2004l\r\u001b[?2004h>             ent_url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/{ent}\"\r\n\u001b[?2004l\r\u001b[?2004h>             er = requests.get(ent_url)\r\n\u001b[?2004l\r\u001b[?2004h>             if er.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>                 edata = er.json()\r\n\u001b[?2004l\r\u001b[?2004h>                 desc = edata.get(\"rcsb_polymer_entity\", {}).get(\"pdbx_description\", \"\")\r\n\u001b[?2004l\r\u001b[?2004h>                 print(f\"    Entity {ent}: {desc}\")\r\n\u001b[?2004l\r\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h>                 print(f\"    Entity {ent} fetch failed\")\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"{pdb_id} fetch failed\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
