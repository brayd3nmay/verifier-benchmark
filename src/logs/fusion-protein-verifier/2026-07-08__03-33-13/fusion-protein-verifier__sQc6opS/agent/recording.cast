[244.704332, "i", "cat << 'EOF' > /app/get_flag_seq.py\nimport requests\nurl = \"https://data.rcsb.org/rest/v1/core/polymer_entity/8RMO/1\"\nr = requests.get(url)\nif r.status_code == 200:\n    data = r.json()\n    seq = data.get(\"entity_poly\", {}).get(\"pdbx_seq_one_letter_code\", \"\")\n    print(\"FLAG-tag sequence in 8RMO:\", seq)\nelse:\n    print(\"Failed to fetch 8RMO Entity 1\")\nEOF\npython3 /app/get_flag_seq.py\n"]
