[322.261151, "o", "    # SNAP-tag options:\r\n\u001b[?2004l\r\u001b[?2004h>     # Option 1: PDB sequence of 3KZY entity 1 (N-term M removed, but starts with G so no change)\r\n\u001b[?2004l\r\u001b[?2004h>     snap_pdb = \"GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR\"\r\n\u001b[?2004l\r\u001b[?2004h>     molecule_options = [snap_pdb]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # 8. Check if FPBase peaks match filter cube exactly:\r\n\u001b[?2004l\r\u001b[?2004h>     # donor's peak excitation: 505 nm, acceptor's peak emission: 610 nm.\r\n\u001b[?2004l\r\u001b[?2004h>     # Let's perform a query to FPBase to verify this, but have local variables ready.\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         # Query FPBase API\r\n\u001b[?2004l\r\u001b[?2004h>         # Let's verify clover\r\n\u001b[?2004l\r\u001b[?2004h>         r_clover = requests.get(\"https://www.fpbase.org/api/proteins/clover/?format=json\")\r\n\u001b[?2004l\r\u001b[?2004h>         if r_clover.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>             c_data = r_clover.json()\r\n\u001b[?2004l\rS\" for\u001b[?2004h>             ex_max = None\r\n\u001b[?2004l\r \u001b[?2004h> "]
[322.262088, "o", "            for state in c_data.get(\"states\", []):\r\n\u001b[?2004l\r\u001b[?2004h>                 if state.get(\"ex_max\") is not None:\r\n\u001b[?2004l\r\u001b[?2004h>                     ex_max = state.get(\"ex_max\")\r\n\u001b[?2004l\r\u001b[?2004h>                     break\r\n\u001b[?2004l\r\u001b[?2004h>             if ex_max != 505:\r\n\u001b[?2004l\r\u001b[?2004h>                 log(f\"Error: Clover excitation peak from FPBase is {ex_max} nm, expected 505 nm.\")\r\n\u001b[?2004l\r\u001b[?2004h>                 write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>                 return\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             log(\"Warning: Could not fetch Clover from FPBase API, using cached peaks.\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         # Let's verify mcherry\r\n\u001b[?2004l\r\u001b[?2004h>         r_mcherry = requests.get(\"https://www.fpbase.org/api/proteins/mcherry/?format=json\")\r\n\u001b[?2004l\r\u001b[?2004h>         if r_mcherry.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>             m_data = r_mcherry.json()\r\n\u001b[?2004l\r\u001b[?2004h>             em_max = None\r\n\u001b[?2004l\r\u001b[?2004h>             for state in m_data.get(\"states\", []):\r\n\u001b[?2004l\r\u001b[?2004h>                 if state.get(\"em_max\") is not None:\r\n\u001b[?2004l\r\u001b[?2004h>                     em_max = state.get(\"em_max\")\r\n\u001b[?2004l\r\u001b[?2004h>                     break\r\n\u001b[?2004l\r\u001b[?2004h>             if em_max != 610:\r\n\u001b[?2004l\r\u001b[?2004h>                 log(f\"Error: mCherry emission peak from FPBase is {em_max} nm, expected 610 nm.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[322.263961, "o", "                write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>                 return\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             log(\"Warning: Could not fetch mCherry from FPBase API, using cached peaks.\")\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         log(f\"Warning during FPBase verification: {e}. Proceeding with cached peaks (Clover=505nm, mCherry=610nm).\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # 9. Match subproteins and linkers\r\n\u001b[?2004l\r\u001b[?2004h>     # We need to find the 5 subproteins in the translated sequence, in order, separated by GS linkers.\r\n\u001b[?2004l\r\u001b[?2004h>     # Subprotein order: antibody_binder -> donor -> DHFR -> acceptor -> molecule_binder\r\n\u001b[?2004l\r\u001b[?2004h>     # Let's write a parsing/matching function.\r\n\u001b[?2004l\r\u001b[?2004h>     # Since linkers must contain only 'G' and 'S' and be between 5 and 20 AA long,\r\n\u001b[?2004l\r\u001b[?2004h>     # and the subprotein sequences are known (some have a few options),\r\n\u001b[?2004l\r\u001b[?2004h>     # we can do a search or check if the translated sequence fits this template.\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     found_match = False\r\n\u001b[?2004l\r\u001b[?2004h>     for donor in donor_options:\r\n\u001b[?2004l\r\u001b[?2004h>         for acceptor in acceptor_options:\r\n\u001b[?2004l\r\u001b[?2004h>             for molecule in molecule_options:\r\n\u001b[?2004l\r\u001b[?2004h>                 # Let's check if translated_seq matches:\r\n\u001b[?2004l\r\u001b[?2004h>                 # antibody_binder + L1 + donor + L2 + DHFR + L3 + acceptor + L4 + molecule\r\n\u001b[?2004l\ru\u001b[?2004h>                 # Let's do this by splitting or sliding.\r\n\u001b[?2004l\r_L1_"]
[322.264525, "o", "\u001b[?2004h>                 # Since antibody_binder, donor, DHFR, acceptor, molecule are fixed, we can determine the exact linker positions!\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h>                 # Let's check if the translated sequence starts with antibody_binder\r\n\u001b[?2004l\r\u001b[?2004h>                 if not translated_seq.startswith(antibody_binder_ref):\r\n\u001b[?2004l\r\u001b[?2004h>                     continue\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h>                 # Linker 1 starts after antibody_binder\r\n\u001b[?2004l\r\u001b[?2004h>                 idx1 = len(antibody_binder_ref)\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h> "]
[322.265184, "o", "                # We find donor sequence after Linker 1. Since Linker 1 length is between 5 and 20,\r\n\u001b[?2004l\r\u001b[?2004h>                 # donor must start at some index `idx1 + len_L1` where 5 <= len_L1 <= 20.\r\n\u001b[?2004l\r\u001b[?2004h>                 # Let's search for donor in that range.\r\n\u001b[?2004l\r\u001b[?2004h>                 donor_idx = -1\r\n\u001b[?2004l\r\u001b[?2004h>                 for len_L1 in range(5, 21):\r\n\u001b[?2004l\r\u001b[?2004h>                     test_idx = idx1 + len_L1\r\n\u001b[?2004l\r\u001b[?2004h>                     if translated_seq[test_idx:test_idx + len(donor)] == donor:\r\n\u001b[?2004l\r\u001b[?2004h>                         # Check if the linker contains only G and S\r\n\u001b[?2004l\r\u001b[?2004h"]
