[540.926734, "i", "cat << 'EOF' > /app/test_ver.py\nimport os\nimport subprocess\n\nab_ref = 'DYKDDDDK'\ndonor_ref = 'VSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK'\ndhfr_ref = 'ISLIAALAVDRVIGMENAMPWNLPADLAWFKRNTLNKPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCFEILERR'\nmcherry_ref = 'VSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQFMYGSKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK'\nsnap_ref = 'GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR'\n\nl1 = 'GSGSG'\nl2 = 'GSGSG'\nl3 = 'GSGSG'\nl4 = 'GSGSG'\n\nfull_protein = ab_ref + l1 + donor_ref + l2 + dhfr_ref + l3 + mcherry_ref + l4 + snap_ref\nprint(\"Full protein length:\", len(full_protein))\n\n# Standard codon table (excluding stop codons)\ncodons_by_aa = {\n    'A': ['GCT', 'GCC', 'GCA', 'GCG'],\n    'C': ['TGT', 'TGC'],\n    'D': ['GAT', 'GAC'],\n    'E': ['GAA', 'GAG'],\n    'F': ['TTT', 'TTC'],\n    'G': ['GGT', 'GGC', 'GGA', 'GGG'],\n    'H': ['CAT', 'CAC'],\n    'I': ['ATT', 'ATC', 'ATA'],\n    'K': ['AAA', 'AAG'],\n    'L': ['TTA', 'TTG', 'CTT', 'CTC', 'CTA', 'CTG'],\n    'M': ['ATG'],\n    'N': ['AAT', 'AAC'],\n    'P': ['CCT', 'CCC', 'CCA', 'CCG'],\n    'Q': ['CAA', 'CAG'],\n    'R': ['CGT', 'CGC', 'CGA', 'CGG', 'AGA', 'AGG'],\n    'S': ['TCT', 'TCC', 'TCA', 'TCG', 'AGT', 'AGC'],\n    'T': ['ACT', 'ACC', 'ACA', 'ACG'],\n    'V': ['GTT', 'GTC', 'GTA', 'GTG'],\n    'W': ['TGG'],\n    'Y': ['TAT', 'TAC']\n}\n\ndef get_gc_count(codon):\n    return sum(1 for c in codon if c in 'GC')\n\n# Initialize with medium-GC codons\ncurrent_codons = []\nfor aa in full_protein:\n    # choose a codon with medium GC content\n    opts = sorted(codons_by_aa[aa], key=get_gc_count)\n    # pick the middle one\n    current_codons.append(opts[len(opts)//2])\n\n# Iterative optimizer\nfor iteration in range(2000):\n    # Reconstruct DNA sequence\n    dna_list = list(\"\".join(current_codons))\n    dna = \"\".join(dna_list)\n    \n    # Find failing windows\n    fail_idx = -1\n    fail_type = \"\"\n    for i in range(len(dna) - 49):\n        w = dna[i:i+50]\n        gc = sum(1 for c in w if c in 'GC') / 50.0\n        if gc < 0.30:\n            fail_idx = i\n            fail_type = \"low\"\n            break\n        elif gc > 0.70:\n            fail_idx = i\n            fail_type = \"high\"\n            break\n            \n    if fail_idx == -1:\n        print(f\"Optimized successfully in {iteration} iterations!\")\n        break\n        \n    # Try to fix the failing window starting at fail_idx\n    # We want to change a codon that completely lies inside this 50-nt window\n    # First codon index entirely in window:\n    first_codon_idx = (fail_idx + 2) // 3\n    last_codon_idx = (fail_idx + 50) // 3 - 1\n    \n    fixed = False\n    for codon_pos in range(first_codon_idx, last_codon_idx + 1):\n        aa = full_protein[codon_pos]\n        old_codon = current_codons[codon_pos]\n        old_gc = get_gc_count(old_codon)\n        \n        # Filter alternative codons\n        if fail_type == \"high\":\n            # find a codon with LESS GC than old_codon\n            better_codons = [c for c in codons_by_aa[aa] if get_gc_count(c) < old_gc]\n        else:\n            # find a codon with MORE GC than old_codon\n            better_codons = [c for c in codons_by_aa[aa] if get_gc_count(c) > old_gc]\n            \n        if better_codons:\n            current_codons[codon_pos] = better_codons[0]\n            fixed = True\n            break\n            \n    if not fixed:\n        # if no codon entirely in the window could be optimized, try any overlapping codon\n        overlapping_start = fail_idx // 3\n        overlapping_end = (fail_idx + 49) // 3\n        for codon_pos in range(overlapping_start, overl"]
[540.933015, "i", "apping_end + 1):\n            aa = full_protein[codon_pos]\n            old_codon = current_codons[codon_pos]\n            old_gc = get_gc_count(old_codon)\n            if fail_type == \"high\":\n                better_codons = [c for c in codons_by_aa[aa] if get_gc_count(c) < old_gc]\n            else:\n                better_codons = [c for c in codons_by_aa[aa] if get_gc_count(c) > old_gc]\n            if better_codons:\n                current_codons[codon_pos] = better_codons[0]\n                fixed = True\n                break\n                \n    if not fixed:\n        print(f\"Stuck at iteration {iteration} on window {fail_idx} ({fail_type} GC)!\")\n        break\n\ndna = \"\".join(current_codons)\nfailed_windows = 0\nfor i in range(len(dna) - 49):\n    w = dna[i:i+50]\n    gc = sum(1 for c in w if c in 'GC') / 50.0\n    if gc < 0.3 or gc > 0.7:\n        failed_windows += 1\nprint(\"Final failed GC windows:\", failed_windows)\n\n# Write to /app/gblock.txt\nwith open(\"/app/gblock.txt\", \"w\") as f:\n    f.write(dna + \"\\n\")\n\n# Run verifier\nos.environ[\"SOLUTION_DIR\"] = \"/app\"\nos.environ[\"VERDICT_FILE\"] = \"/app/verdict_test.txt\"\nsubprocess.run([\"/app/verifier/verify.sh\"])\n\nwith open(\"/app/verdict_test.txt\") as f:\n    print(\"Verifier Verdict:\", f.read().strip())\nEOF\npython3 /app/test_ver.py\n"]
