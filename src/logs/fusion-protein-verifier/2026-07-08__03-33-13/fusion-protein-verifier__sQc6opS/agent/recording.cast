[64.953243, "i", "cat << 'EOF' > /app/check_smiles.py\nimport requests\nimport json\n# Let's search PubChem by SMILES to get the name of the compound\nsmiles = \"Nc3nc(OCc1ccccc1)c2nc[nH]c2n3\"\nurl = f\"https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/smiles/{smiles}/property/IUPACName,Title/json\"\nr = requests.get(url)\nif r.status_code == 200:\n    print(r.json())\nelse:\n    print(\"Pubchem lookup failed\")\nEOF\npython3 /app/check_smiles.py\n"]
[64.955801, "o", "cat << 'EOF' > /app/check_smiles.py\r\n\u001b[?2004l\r"]
