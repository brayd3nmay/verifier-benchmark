[89.229262, "i", "cat << 'EOF' > /app/get_pdb_fasta.py\nimport requests\n\nfor pdb_id in ['3KZY', '5WJ2', '2H5Q']:\n    url = f\"https://www.rcsb.org/fasta/entry/{pdb_id}\"\n    r = requests.get(url)\n    if r.status_code == 200:\n        print(f\">>> {pdb_id}\")\n        print(r.text)\n    else:\n        print(f\"{pdb_id} fasta fetch failed\")\nEOF\npython3 /app/get_pdb_fasta.py\n"]
