[37.094976, "i", "cat << 'EOF' > /app/get_fpbase_info.py\nimport requests\n\nurl = \"https://www.fpbase.org/graphql/\"\n\nquery = \"\"\"\nquery {\n  allProteins {\n    edges {\n      node {\n        name\n        slug\n        seq\n        primaryPdb\n        exMax\n        emMax\n      }\n    }\n  }\n}\n\"\"\"\n\nr = requests.post(url, json={'query': query})\nif r.status_code == 200:\n    data = r.json()\n    edges = data.get(\"data\", {}).get(\"allProteins\", {}).get(\"edges\", [])\n    print(f\"Found {len(edges)} proteins in FPBase\")\n    for edge in edges:\n        p = edge[\"node\"]\n        pdb = p.get(\"primaryPdb\")\n        ex = p.get(\"exMax\")\n        em = p.get(\"emMax\")\n        # if pdb:\n        #    print(f\"{p['name']} ({pdb}): ex={ex}, em={em}\")\n        if ex == 505 or em == 610:\n            print(f\"MATCH: {p['name']} ({pdb}): ex={ex}, em={em}, slug={p['slug']}\")\nelse:\n    print(\"GraphQL failed, status:\", r.status_code, r.text)\nEOF\npython3 /app/get_fpbase_info.py\n"]
