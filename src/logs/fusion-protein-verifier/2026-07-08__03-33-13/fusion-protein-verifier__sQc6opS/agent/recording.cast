[222.659429, "i", "cat << 'EOF' > /app/search_pdb_seq.py\nimport requests\n\n# RCSB PDB sequence search API utilizes a POST request\n# Endpoint: https://search.rcsb.org/rcsbsearch/v2/query\n\nheavy = \"QVQLQQSAAELARPGASVKMSCKASGYSFTTYTIHWVKQRPGQGLEWIGYINPSSGYAAYNQNFKDETTLTADPSSSTAYMELNSLTSEDSAVYYCAREKFYGYDYWGQGATLTVSSASTTPPSVYPLAPGSAAQTNSMVTLGCLVKGYFPEPVTVTWNSGSLSSGVHTFPAVLQSDLYTLSSSVTVPSSTWPSQTVTCNVAHPASSTKVDKKIVPRAAAHHHHHHHH\"\nlight = \"DVLMTQIPLSLPVSLGDQASISCRSSQSIVHRNGNTYLEWYLLKPGQSPKLLIYKVSNRFSGVPDRFSGSGSGTDFTLKISRVEAEDLGVYYCFQGSHVPYTFGGGTKLEIRRADAAPTVSIFPPSSEQLTSGGASVVCFLNNFYPKDINVKWKIDGSERQNGVLNSWTDQDSKDSTYSMSSTLTLTKDEYERHNSYTCEATHKTSTSPIVKSFNRNQC\"\n\ndef search_sequence(seq):\n    payload = {\n        \"query\": {\n            \"type\": \"terminal\",\n            \"service\": \"sequence\",\n            \"parameters\": {\n                \"evalue_cutoff\": 1e-5,\n                \"identity_cutoff\": 0.9,\n                \"sequence_type\": \"protein\",\n                \"value\": seq\n            }\n        },\n        \"return_type\": \"polymer_entity\"\n    }\n    r = requests.post(\"https://search.rcsb.org/rcsbsearch/v2/query\", json=payload)\n    if r.status_code == 200:\n        return r.json()\n    else:\n        return f\"Error {r.status_code}: {r.text}\"\n\nprint(\"Searching heavy chain...\")\nprint(search_sequence(heavy))\nprint(\"Searching light chain...\")\nprint(search_sequence(light))\nEOF\npython3 /app/search_pdb_seq.py\n"]
