[477.352276, "o", "\u001b[?2004hroot@1120f1c9a9fd:/app# "]
[493.901208, "i", "cat << 'EOF' > /app/test_ver.py\nimport os\nimport subprocess\nfrom Bio.Seq import Seq\n\n# Reference protein sequence we want to encode:\nab_ref = 'DYKDDDDK'\n# Let's use clover_f option\ndonor_ref = 'VSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK'\ndhfr_ref = 'ISLIAALAVDRVIGMENAMPWNLPADLAWFKRNTLNKPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCFEILERR'\nmcherry_ref = 'VSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQFMYGSKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK'\nsnap_ref = 'GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR'\n\n# Linkers (5 AA long, GS only)\nl1 = 'GSGSG'\nl2 = 'GSGSG'\nl3 = 'GSGSG'\nl4 = 'GSGSG'\n\nfull_protein = ab_ref + l1 + donor_ref + l2 + dhfr_ref + l3 + mcherry_ref + l4 + snap_ref\nprint(\"Full protein length:\", len(full_protein))\n\n# Let's reverse-translate. To make GC content simple and close to 50%,\n# we can choose codons that have balanced GC content, or map amino acids to codons\n# with medium GC.\ncodon_map = {\n    'A': 'GCT', 'C': 'TGT', 'D': 'GAT', 'E': 'GAG', 'F': 'TTT',\n    'G': 'GGT', 'H': 'CAT', 'I': 'ATT', 'K': 'AAA', 'L': 'CTG',\n    'M': 'ATG', 'N': 'AAC', 'P': 'CCG', 'Q': 'CAG', 'R': 'CGT',\n    'S': 'TCT', 'T': 'ACT', 'V': 'GTT', 'Y': 'TAT', 'W': 'TGG'\n}\n\n# Let's refine codon map to ensure 50-nt window GC is strictly between 30% and 70%\n# A: GCT (2/3 GC = 66.7%)\n# C: TGC (2/3 GC)\n# D: GAT (1/3 GC = 33.3%)\n# E: GAG (2/3 GC)\n# F: TTC (2/3 GC)\n# G: GGC (2/3 GC)\n# H: CAC (2/3 GC)\n# I: ATC (2/3 GC)\n# K: AAG (2/3 GC)\n# L: CTG (2/3 GC)\n# M: ATG (1/3 GC)\n# N: AAC (2/3 GC)\n# P: CCC (3/3 GC) -> let's use CCT (2/3 GC)\n# Q: CAG (2/3 GC)\n# R: CGC (2/3 GC)\n# S: AGC (2/3 GC)\n# T: ACC (2/3 GC)\n# V: GTG (2/3 GC)\n# Y: TAC (2/3 GC)\n# W: TGG (2/3 GC)\n\n# Let's do a simple reverse-translation using a robust medium-GC codon map\ncodon_map = {\n    'A': 'GCC', 'C': 'TGC', 'D': 'GAC', 'E': 'GAG', 'F': 'TTC',\n    'G': 'GGC', 'H': 'CAC', 'I': 'ATC', 'K': 'AAG', 'L': 'CTG',\n    'M': 'ATG', 'N': 'AAC', 'P': 'CCC', 'Q': 'CAG', 'R': 'CGC',\n    'S': 'AGC', 'T': 'ACC', 'V': 'GTG', 'Y': 'TAC', 'W': 'TGG'\n}\n\ndna = \"\".join(codon_map[aa] for aa in full_protein)\nprint(\"DNA length:\", len(dna))\n\n# Check GC content of sliding windows of size 50\nfailed_windows = 0\nfor i in range(len(dna) - 49):\n    w = dna[i:i+50]\n    gc = sum(1 for c in w if c in 'GC') / 50.0\n    if gc < 0.3 or gc > 0.7:\n        failed_windows += 1\n\nprint(\"Failed GC windows:\", failed_windows)\n\n# If any window failed, let's adjust the codons of that window\n# Since failed_windows is likely 0 or very small, let's check.\nif failed_windows > 0:\n    # We can use a smarter algorithm to pick codons\n    # but with the above map, GC content of almost every codon is exactly 2/3 (66.7%), except M/D (33.3%).\n    # So average GC content will be around 60%, which is well within 30-70% range!\n    pass\n\n# Write to /app/gblock.txt\nwith open(\"/app/gblock.txt\", \"w\") as f:\n    f.write(dna + \"\\n\")\n\n# Run verifier\nos.environ[\"SOLUTION_DIR\"] = \"/app\"\nos.environ[\"VERDICT_FILE\"] = \"/app/verdict_test.txt\"\nsubprocess.run([\"/app/verifier/verify.sh\"])\n\nwith open(\"/app/verdict_test.txt\") as f:\n    print(\"Verdict:\", f.read().strip())\nEOF\npython3 /app/test_ver.py\n"]
