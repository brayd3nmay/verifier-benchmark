[100.845256, "i", "cat << 'EOF' > /app/get_pdb_canon.py\nimport requests\n\nfor pdb_id in ['5WJ2', '2H5Q']:\n    url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\n    r = requests.get(url)\n    if r.status_code == 200:\n        data = r.json()\n        entity_poly = data.get(\"entity_poly\", {})\n        print(f\"=== {pdb_id} ===\")\n        for k in ['pdbx_seq_one_letter_code', 'pdbx_seq_one_letter_code_can', 'seq_one_letter_code']:\n            print(f\"{k}: {entity_poly.get(k, 'N/A')}\")\nEOF\npython3 /app/get_pdb_canon.py\n"]
