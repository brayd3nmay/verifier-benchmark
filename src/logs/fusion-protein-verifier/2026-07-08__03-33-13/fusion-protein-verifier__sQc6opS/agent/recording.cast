[322.223573, "i", "cat << 'EOF' > /app/verifier/verify.py\nimport os\nimport sys\nimport requests\nfrom Bio import SeqIO\n\n# Helper to print logs to stderr\ndef log(msg):\n    print(msg, file=sys.stderr)\n\ndef main():\n    # Get paths from env or defaults\n    solution_dir = os.environ.get(\"SOLUTION_DIR\", \"/app\")\n    verdict_file = os.environ.get(\"VERDICT_FILE\", \"/logs/verifier/reward.txt\")\n    \n    # Ensure output dir exists\n    os.makedirs(os.path.dirname(verdict_file), exist_ok=True)\n    \n    gblock_path = os.path.join(solution_dir, \"gblock.txt\")\n    \n    if not os.path.exists(gblock_path):\n        log(f\"Error: {gblock_path} does not exist.\")\n        write_verdict(verdict_file, 0)\n        return\n\n    # 1. Read gblock.txt\n    try:\n        with open(gblock_path, \"rb\") as f:\n            content_bytes = f.read()\n    except Exception as e:\n        log(f\"Error reading {gblock_path}: {e}\")\n        write_verdict(verdict_file, 0)\n        return\n\n    # Check if file has exactly one line\n    # It contains only the gBlock sequence, on a single line — nothing else, no empty lines.\n    # Let's decode as ascii/utf-8\n    try:\n        content = content_bytes.decode(\"utf-8\")\n    except Exception as e:\n        log(f\"Error decoding content as UTF-8: {e}\")\n        write_verdict(verdict_file, 0)\n        return\n\n    # Split by newline\n    lines = content.splitlines(keepends=True)\n    if len(lines) == 0:\n        log(\"Error: gblock.txt is empty.\")\n        write_verdict(verdict_file, 0)\n        return\n    \n    # If there's more than 1 line of text, or empty lines\n    # A single line of text can have a trailing newline. content.splitlines() removes it.\n    # Let's check how many lines there are when splitting by '\n':\n    nl_split = content.split(\"\\n\")\n    # If content is \"ATCG\\n\", nl_split is [\"ATCG\", \"\"]\n    # If content is \"ATCG\", nl_split is [\"ATCG\"]\n    # Any other case is invalid (e.g. \"ATCG\\n\\n\", \"ATCG\\nATCG\")\n    if len(nl_split) > 2 or (len(nl_split) == 2 and nl_split[1] != \"\"):\n        log(f\"Error: gblock.txt must contain exactly one line. Found split parts: {nl_split}\")\n        write_verdict(verdict_file, 0)\n        return\n\n    gblock_seq = nl_split[0].strip().upper()\n    if not gblock_seq:\n        log(\"Error: gblock sequence is empty.\")\n        write_verdict(verdict_file, 0)\n        return\n\n    # 2. Check DNA bases\n    if not all(c in \"ATCG\" for c in gblock_seq):\n        log(\"Error: gblock sequence contains non-ATCG bases.\")\n        write_verdict(verdict_file, 0)\n        return\n\n    # 3. Check length\n    if len(gblock_seq) > 3000:\n        log(f\"Error: gblock sequence length {len(gblock_seq)} exceeds 3000.\")\n        write_verdict(verdict_file, 0)\n        return\n\n    if len(gblock_seq) % 3 != 0:\n        log(f\"Error: gblock sequence length {len(gblock_seq)} is not a multiple of 3.\")\n        write_verdict(verdict_file, 0)\n        return\n\n    # 4. GC content sliding window\n    # Every 50-nucleotide window has GC content between 30% and 70%\n    if len(gblock_seq) < 50:\n        log(\"Error: gblock sequence is less than 50 nucleotides.\")\n        write_verdict(verdict_file, 0)\n        return\n\n    for i in range(len(gblock_seq) - 49):\n        window = gblock_seq[i:i+50]\n        gc_count = sum(1 for c in window if c in \"GC\")\n        gc_pct = gc_count / 50.0\n        if gc_pct < 0.30 or gc_pct > 0.70:\n            log(f\"Error: 50-nt window at index {i} ({window}) has GC content {gc_pct:.1%}, which is outside [30%, 70%].\")\n            write_verdict(verdict_file, 0)\n            return\n\n    # 5. Translate the sequence\n    # Standard genetic code\n    from Bio.Seq import Seq\n    translated_seq = str(Seq(gblock_seq).translate())\n    log(f\"Translated protein (len={len(translated_seq)}): {translated_seq[:100]}...\")\n\n    # 6. Check for stop codons in the translated sequence\n    if \"*\" in translated_seq:\n        log(\"Error: Stop codon '*' found in the translated sequence.\")\n        write_verdict(verdict_file, 0)\n        return\n\n    # 7. Define correct subproteins\n    # Antibody binder (FLAG-tag)\n    antibody_binder_ref = \"DYKDDDDK\"\n    \n    # DHFR from plasmid.gb (without N-term M)\n "]
[322.235559, "i", "   # Let's extract it from /app/data/plasmid.gb dynamically, with a fallback to the hardcoded sequence\n    dhfr_ref = \"\"\n    plasmid_path = \"/app/data/plasmid.gb\"\n    if os.path.exists(plasmid_path):\n        try:\n            for record in SeqIO.parse(plasmid_path, \"genbank\"):\n                for feature in record.features:\n                    if feature.type == \"CDS\":\n                        translation = feature.qualifiers.get(\"translation\", [\"\"])[0]\n                        if translation.startswith(\"MISLIA\"):\n                            dhfr_ref = translation[1:] # remove N-terminal M\n                            break\n        except Exception as e:\n            log(f\"Warning reading plasmid.gb: {e}\")\n    \n    if not dhfr_ref:\n        dhfr_ref = \"ISLIAALAVDRVIGMENAMPWNLPADLAWFKRNTLNKPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCFEILERR\"\n    \n    # Donor (Clover, PDB: 5WJ2)\n    # Acceptor (mCherry, PDB: 2H5Q)\n    # Molecule binder (SNAP-tag, PDB: 3KZY)\n    # We will support both PDB sequence and a canonical version or FPBase version just in case.\n    # Let's construct the lists of valid sequences for each\n    \n    # Clover options:\n    # Option 1: PDB sequence of 5WJ2 entity 1 (with (CR2)/X replaced by GYG, N-term M removed)\n    clover_pdb = \"GSSHHHHHHSSGENLYFQGHMVSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK\"\n    # Option 2: FPBase clover sequence (N-term M removed)\n    clover_fpbase = \"VSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK\"\n    donor_options = [clover_pdb, clover_fpbase]\n\n    # mCherry options:\n    # Option 1: PDB sequence of 2H5Q entity 1 (with (CH6)/X replaced by MYG, N-term M removed)\n    mcherry_pdb = \"VSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQFMYGSKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK\"\n    acceptor_options = [mcherry_pdb]\n\n    # SNAP-tag options:\n    # Option 1: PDB sequence of 3KZY entity 1 (N-term M removed, but starts with G so no change)\n    snap_pdb = \"GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR\"\n    molecule_options = [snap_pdb]\n\n    # 8. Check if FPBase peaks match filter cube exactly:\n    # donor's peak excitation: 505 nm, acceptor's peak emission: 610 nm.\n    # Let's perform a query to FPBase to verify this, but have local variables ready.\n    try:\n        # Query FPBase API\n        # Let's verify clover\n        r_clover = requests.get(\"https://www.fpbase.org/api/proteins/clover/?format=json\")\n        if r_clover.status_code == 200:\n            c_data = r_clover.json()\n            ex_max = None\n            for state in c_data.get(\"states\", []):\n                if state.get(\"ex_max\") is not None:\n                    ex_max = state.get(\"ex_max\")\n                    break\n            if ex_max != 505:\n                log(f\"Error: Clover excitation peak from FPBase is {ex_max} nm, expected 505 nm.\")\n                write_verdict(verdict_file, 0)\n                return\n        else:\n            log(\"Warning: Could not fetch Clover from FPBase API, using cached peaks.\")\n\n        # Let's verify mcherry\n        r_mcherry = requests.get(\"https://www.fpbase.org/api/proteins/mcherry/?format=json\")\n        if r_mcherry.status_code == 200:\n            m_data = r_mcherry.json()\n            em_max = None\n            for state in m_data.get(\"states\", []):\n                if state.get(\"em_max\") is not None:\n                    em_max = state.get(\"em_max\")\n                    break\n    "]
[322.235768, "i", "        if em_max != 610:\n                log(f\"Error: mCherry emission peak from FPBase is {em_max} nm, expected 610 nm.\")\n                write_verdict(verdict_file, 0)\n                return\n        else:\n            log(\"Warning: Could not fetch mCherry from FPBase API, using cached peaks.\")\n    except Exception as e:\n        log(f\"Warning during FPBase verification: {e}. Proceeding with cached peaks (Clover=505nm, mCherry=610nm).\")\n\n    # 9. Match subproteins and linkers\n    # We need to find the 5 subproteins in the translated sequence, in order, separated by GS linkers.\n    # Subprotein order: antibody_binder -> donor -> DHFR -> acceptor -> molecule_binder\n    # Let's write a parsing/matching function.\n    # Since linkers must contain only 'G' and 'S' and be between 5 and 20 AA long,\n    # and the subprotein sequences are known (some have a few options),\n    # we can do a search or check if the translated sequence fits this template.\n    \n    found_match = False\n    for donor in donor_options:\n        for acceptor in acceptor_options:\n            for molecule in molecule_options:\n                # Let's check if translated_seq matches:\n                # antibody_binder + L1 + donor + L2 + DHFR + L3 + acceptor + L4 + molecule\n                # Let's do this by splitting or sliding.\n                # Since antibody_binder, donor, DHFR, acceptor, molecule are fixed, we can determine the exact linker positions!\n                \n                # Let's check if the translated sequence starts with antibody_binder\n                if not translated_seq.startswith(antibody_binder_ref):\n                    continue\n                \n                # Linker 1 starts after antibody_binder\n                idx1 = len(antibody_binder_ref)\n                \n                # We find donor sequence after Linker 1. Since Linker 1 length is between 5 and 20,\n                # donor must start at some index `idx1 + len_L1` where 5 <= len_L1 <= 20.\n                # Let's search for donor in that range.\n                donor_idx = -1\n                for len_L1 in range(5, 21):\n                    test_idx = idx1 + len_L1\n                    if translated_seq[test_idx:test_idx + len(donor)] == donor:\n                        # Check if the linker contains only G and S\n                        linker1 = translated_seq[idx1:test_idx]\n                        if all(c in \"GS\" for c in linker1):\n                            donor_idx = test_idx\n                            len_L1_actual = len_L1\n                            break\n                if donor_idx == -1:\n                    continue\n                \n                # Linker 2 starts after donor\n                idx2 = donor_idx + len(donor)\n                \n                # We find DHFR sequence after Linker 2.\n                dhfr_idx = -1\n                for len_L2 in range(5, 21):\n                    test_idx = idx2 + len_L2\n                    if translated_seq[test_idx:test_idx + len(dhfr_ref)] == dhfr_ref:\n                        # Check if the linker contains only G and S\n                        linker2 = translated_seq[idx2:test_idx]\n                        if all(c in \"GS\" for c in linker2):\n                            dhfr_idx = test_idx\n                            len_L2_actual = len_L2\n                            break\n                if dhfr_idx == -1:\n                    continue\n                \n                # Linker 3 starts after DHFR\n                idx3 = dhfr_idx + len(dhfr_ref)\n                \n                # We find acceptor sequence after Linker 3.\n                acceptor_idx = -1\n                for len_L3 in range(5, 21):\n                    test_idx = idx3 + len_L3\n                    if translated_seq[test_idx:test_idx + len(acceptor)] == acceptor:\n                        # Check if the linker contains only G and S\n                        linker3 = translated_seq[idx3:test_idx]\n                        if all(c in \"GS\" for c in linker3):\n                            acceptor_idx = test_idx\n                            len_L3_actual = len_L3\n             "]
[322.237313, "i", "               break\n                if acceptor_idx == -1:\n                    continue\n                \n                # Linker 4 starts after acceptor\n                idx4 = acceptor_idx + len(acceptor)\n                \n                # We find molecule sequence after Linker 4.\n                molecule_idx = -1\n                for len_L4 in range(5, 21):\n                    test_idx = idx4 + len_L4\n                    if translated_seq[test_idx:test_idx + len(molecule)] == molecule:\n                        # Check if the linker contains only G and S\n                        linker4 = translated_seq[idx4:test_idx]\n                        if all(c in \"GS\" for c in linker4):\n                            molecule_idx = test_idx\n                            len_L4_actual = len_L4\n                            break\n                if molecule_idx == -1:\n                    continue\n                \n                # Finally, check if the translated sequence ends exactly after molecule sequence\n                if molecule_idx + len(molecule) == len(translated_seq):\n                    found_match = True\n                    log(f\"Found successful match with donor (len={len(donor)}), acceptor (len={len(acceptor)}), molecule (len={len(molecule)}).\")\n                    log(f\"Linker 1 (len={len_L1_actual}): {translated_seq[idx1:donor_idx]}\")\n                    log(f\"Linker 2 (len={len_L2_actual}): {translated_seq[idx2:dhfr_idx]}\")\n                    log(f\"Linker 3 (len={len_L3_actual}): {translated_seq[idx3:acceptor_idx]}\")\n                    log(f\"Linker 4 (len={len_L4_actual}): {translated_seq[idx4:molecule_idx]}\")\n                    break\n            if found_match:\n                break\n        if found_match:\n            break\n\n    if not found_match:\n        log(\"Error: Translated sequence does not match the 5 subproteins and GS linkers in the correct order and length.\")\n        write_verdict(verdict_file, 0)\n        return\n\n    # All checks passed!\n    log(\"Success! All gBlock verification checks passed.\")\n    write_verdict(verdict_file, 1)\n\ndef write_verdict(verdict_file, val):\n    try:\n        with open(verdict_file, \"w\") as f:\n            f.write(str(val))\n        log(f\"Wrote verdict {val} to {verdict_file}\")\n    except Exception as e:\n        log(f\"Error writing verdict to {verdict_file}: {e}\")\n\nif __name__ == \"__main__\":\n    main()\nEOF\n"]
