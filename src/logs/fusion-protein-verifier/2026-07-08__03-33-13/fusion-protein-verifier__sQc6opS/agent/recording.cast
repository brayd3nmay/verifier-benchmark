[109.640807, "i", "cat << 'EOF' > /app/get_fpbase_seqs.py\nimport requests\nres = requests.get(\"https://www.fpbase.org/api/proteins/?format=json\")\nif res.status_code == 200:\n    data = res.json()\n    for p in data:\n        slug = p.get(\"slug\")\n        if slug in ['clover', 'mcherry']:\n            print(f\"FPBase sequence for {slug}: len={len(p.get('seq', ''))}\")\n            print(p.get('seq'))\nEOF\npython3 /app/get_fpbase_seqs.py\n"]
[109.643456, "o", "cat << 'EOF' > /app/get_fpbase_seqs.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> res = requests.get(\"https://www.fpbase.org/api/proteins/?format=json\")\r\n\u001b[?2004l\r\u001b[?2004h> if res.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>     data = res.json()\r\n\u001b[?2004l\r\u001b[?2004h>     for p in data:\r\n\u001b[?2004l\r\u001b[?2004h>         slug = p.get(\"slug\")\r\n\u001b[?2004l\r\u001b[?2004h>         if slug in ['clover', 'mcherry']:\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"FPBase sequence for {slug}: len={len(p.get('seq', ''))}\")\r\n\u001b[?2004l\r\u001b[?2004h>             print(p.get('seq'))\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
