[146.683709, "i", "cat << 'EOF' > /app/blast_antibody.py\nfrom Bio.Blast import NCBIWWW\nfrom Bio import SeqIO\n\n# Read the light chain or heavy chain\nrecords = list(SeqIO.parse(\"/app/data/antibody.fasta\", \"fasta\"))\nfor r in records:\n    print(f\"BLASTing {r.id}...\")\n    # We can do a quick blastp search on NCBI\n    result_handle = NCBIWWW.qblast(\"blastp\", \"nr\", r.seq, hitlist_size=10)\n    with open(f\"/app/{r.id.replace(' ', '_')}_blast.xml\", \"w\") as out_f:\n        out_f.write(result_handle.read())\n    print(f\"Done BLASTing {r.id}.\")\nEOF\n# Let's run it in the background or just check if we can run it on the heavy chain first\npython3 /app/blast_antibody.py &\n"]
[146.68453, "o", "cat << 'EOF' > /app/blast_antibody.py\r\n\u001b[?2004l\r\u001b[?2004h> from Bio.Blast import NCBIWWW\r\n\u001b[?2004l\r\u001b[?2004h> from Bio import SeqIO\r\n\u001b[?2004l\r"]
[146.68494, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Read the light chain or heavy chain\r\n\u001b[?2004l\r\u001b[?2004h> "]
