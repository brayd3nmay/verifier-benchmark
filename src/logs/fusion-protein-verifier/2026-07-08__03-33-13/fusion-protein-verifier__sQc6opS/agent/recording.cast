[20.086603, "i", "cat << 'EOF' > /app/get_pdb_info.py\nimport requests\nimport json\n\npdb_ids = []\nwith open(\"/app/data/pdb_ids.txt\") as f:\n    for line in f:\n        line = line.strip()\n        if line:\n            pdb_ids.append(line.upper())\n\nprint(\"PDB IDs:\", pdb_ids)\n\n# Query RCSB PDB API\n# We want to get the title, description, and polymer entities (sequences)\n# and chemical components/ligands\nfor pdb_id in pdb_ids:\n    url = f\"https://data.rcsb.org/rest/v1/core/entry/{pdb_id}\"\n    r = requests.get(url)\n    if r.status_code == 200:\n        data = r.json()\n        title = data.get(\"struct\", {}).get(\"title\", \"\")\n        print(f\"{pdb_id}: {title[:80]}\")\n    else:\n        print(f\"{pdb_id}: failed to get info\")\nEOF\npython3 /app/get_pdb_info.py\n"]
