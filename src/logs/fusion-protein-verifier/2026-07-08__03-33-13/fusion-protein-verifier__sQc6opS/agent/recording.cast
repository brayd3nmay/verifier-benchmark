[344.906768, "i", "cat << 'EOF' > /app/write_verify.py\nimport base64\n\ncode = \"\"\"import os\nimport sys\nimport requests\nfrom Bio import SeqIO\n\ndef log(msg):\n    print(msg, file=sys.stderr)\n\ndef write_verdict(verdict_file, val):\n    try:\n        with open(verdict_file, 'w') as f:\n            f.write(str(val))\n        log(f'Wrote verdict {val} to {verdict_file}')\n    except Exception as e:\n        log(f'Error writing verdict to {verdict_file}: {e}')\n\ndef main():\n    solution_dir = os.environ.get('SOLUTION_DIR', '/app')\n    verdict_file = os.environ.get('VERDICT_FILE', '/logs/verifier/reward.txt')\n    os.makedirs(os.path.dirname(verdict_file), exist_ok=True)\n    \n    gblock_path = os.path.join(solution_dir, 'gblock.txt')\n    if not os.path.exists(gblock_path):\n        log(f'Error: {gblock_path} does not exist.')\n        write_verdict(verdict_file, 0)\n        return\n\n    try:\n        with open(gblock_path, 'rb') as f:\n            content_bytes = f.read()\n    except Exception as e:\n        log(f'Error reading {gblock_path}: {e}')\n        write_verdict(verdict_file, 0)\n        return\n\n    try:\n        content = content_bytes.decode('utf-8')\n    except Exception as e:\n        log(f'Error decoding content: {e}')\n        write_verdict(verdict_file, 0)\n        return\n\n    # Strict check on single-line constraint\n    nl_split = content.split('\\n')\n    if len(nl_split) > 2 or (len(nl_split) == 2 and nl_split[1] != ''):\n        log(f'Error: gblock.txt must contain exactly one line.')\n        write_verdict(verdict_file, 0)\n        return\n\n    gblock_seq = nl_split[0].strip().upper()\n    if not gblock_seq:\n        log('Error: empty gblock sequence.')\n        write_verdict(verdict_file, 0)\n        return\n\n    if not all(c in 'ATCG' for c in gblock_seq):\n        log('Error: non-ATCG bases.')\n        write_verdict(verdict_file, 0)\n        return\n\n    if len(gblock_seq) > 3000:\n        log(f'Error: sequence length {len(gblock_seq)} exceeds 3000.')\n        write_verdict(verdict_file, 0)\n        return\n\n    if len(gblock_seq) % 3 != 0:\n        log('Error: length not multiple of 3.')\n        write_verdict(verdict_file, 0)\n        return\n\n    if len(gblock_seq) < 50:\n        log('Error: sequence < 50 nt.')\n        write_verdict(verdict_file, 0)\n        return\n\n    # GC content sliding window\n    for i in range(len(gblock_seq) - 49):\n        window = gblock_seq[i:i+50]\n        gc_count = sum(1 for c in window if c in 'GC')\n        gc_pct = gc_count / 50.0\n        if gc_pct < 0.30 or gc_pct > 0.70:\n            log(f'Error: window at {i} has GC content {gc_pct:.1%}')\n            write_verdict(verdict_file, 0)\n            return\n\n    from Bio.Seq import Seq\n    translated_seq = str(Seq(gblock_seq).translate())\n    log(f'Translated: {translated_seq[:100]}...')\n\n    if '*' in translated_seq:\n        log('Error: stop codon found.')\n        write_verdict(verdict_file, 0)\n        return\n\n    antibody_binder_ref = 'DYKDDDDK'\n    \n    dhfr_ref = ''\n    plasmid_path = '/app/data/plasmid.gb'\n    if os.path.exists(plasmid_path):\n        try:\n            for record in SeqIO.parse(plasmid_path, 'genbank'):\n                for feature in record.features:\n                    if feature.type == 'CDS':\n                        translation = feature.qualifiers.get('translation', [''])[0]\n                        if translation.startswith('MISLIA'):\n                            dhfr_ref = translation[1:]\n                            break\n        except Exception as e:\n            log(f'Warning reading plasmid.gb: {e}')\n\n    if not dhfr_ref:\n        dhfr_ref = 'ISLIAALAVDRVIGMENAMPWNLPADLAWFKRNTLNKPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCFEILERR'\n\n    clover_pdb = 'GSSHHHHHHSSGENLYFQGHMVSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK'\n    clover_fpbase = 'VSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDH"]
[344.910732, "i", "MKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK'\n    donor_options = [clover_pdb, clover_fpbase]\n\n    mcherry_pdb = 'VSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQFMYGSKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK'\n    acceptor_options = [mcherry_pdb]\n\n    snap_pdb = 'GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR'\n    molecule_options = [snap_pdb]\n\n    try:\n        r_clover = requests.get('https://www.fpbase.org/api/proteins/clover/?format=json')\n        if r_clover.status_code == 200:\n            ex_max = None\n            for state in r_clover.json().get('states', []):\n                if state.get('ex_max') is not None:\n                    ex_max = state.get('ex_max')\n                    break\n            if ex_max != 505:\n                log(f'Error: Clover ex_max from FPBase is {ex_max} != 505')\n                write_verdict(verdict_file, 0)\n                return\n        r_mcherry = requests.get('https://www.fpbase.org/api/proteins/mcherry/?format=json')\n        if r_mcherry.status_code == 200:\n            em_max = None\n            for state in r_mcherry.json().get('states', []):\n                if state.get('em_max') is not None:\n                    em_max = state.get('em_max')\n                    break\n            if em_max != 610:\n                log(f'Error: mCherry em_max from FPBase is {em_max} != 610')\n                write_verdict(verdict_file, 0)\n                return\n    except Exception as e:\n        log(f'Warning: FPBase check failed: {e}. Using cached peaks.')\n\n    found_match = False\n    for donor in donor_options:\n        for acceptor in acceptor_options:\n            for molecule in molecule_options:\n                if not translated_seq.startswith(antibody_binder_ref):\n                    continue\n                idx1 = len(antibody_binder_ref)\n                \n                donor_idx = -1\n                for len_L1 in range(5, 21):\n                    test_idx = idx1 + len_L1\n                    if translated_seq[test_idx:test_idx + len(donor)] == donor:\n                        linker1 = translated_seq[idx1:test_idx]\n                        if all(c in 'GS' for c in linker1):\n                            donor_idx = test_idx\n                            break\n                if donor_idx == -1:\n                    continue\n                \n                idx2 = donor_idx + len(donor)\n                dhfr_idx = -1\n                for len_L2 in range(5, 21):\n                    test_idx = idx2 + len_L2\n                    if translated_seq[test_idx:test_idx + len(dhfr_ref)] == dhfr_ref:\n                        linker2 = translated_seq[idx2:test_idx]\n                        if all(c in 'GS' for c in linker2):\n                            dhfr_idx = test_idx\n                            break\n                if dhfr_idx == -1:\n                    continue\n                \n                idx3 = dhfr_idx + len(dhfr_ref)\n                acceptor_idx = -1\n                for len_L3 in range(5, 21):\n                    test_idx = idx3 + len_L3\n                    if translated_seq[test_idx:test_idx + len(acceptor)] == acceptor:\n                        linker3 = translated_seq[idx3:test_idx]\n                        if all(c in 'GS' for c in linker3):\n                            acceptor_idx = test_idx\n                            break\n                if acceptor_idx == -1:\n                    continue\n                \n                idx4 = acceptor_idx + len(acceptor)\n                molecule_idx = -1\n                for len_L4 in range(5, 21):\n                    test_idx = idx4 + len_L4\n                    if translated_seq[test_idx:test_idx + len(molecule)] == molecule:\n                        linker4 = translated_seq[idx"]
[344.910911, "i", "4:test_idx]\n                        if all(c in 'GS' for c in linker4):\n                            molecule_idx = test_idx\n                            break\n                if molecule_idx == -1:\n                    continue\n                \n                if molecule_idx + len(molecule) == len(translated_seq):\n                    found_match = True\n                    log('Found successful match with subproteins and linkers.')\n                    break\n            if found_match: break\n        if found_match: break\n\n    if not found_match:\n        log('Error: Translated sequence mismatch.')\n        write_verdict(verdict_file, 0)\n        return\n\n    log('Success! All checks passed.')\n    write_verdict(verdict_file, 1)\n\nif __name__ == \"__main__\":\n    main()\"\"\"\n\nwith open(\"/app/verifier/verify.py\", \"w\") as f:\n    f.write(code)\nEOF\npython3 /app/write_verify.py\n"]
