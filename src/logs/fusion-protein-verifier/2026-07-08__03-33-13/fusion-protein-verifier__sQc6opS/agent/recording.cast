[14.911071, "i", "cat << 'EOF' > /app/explore.py\nfrom Bio import SeqIO\nfor record in SeqIO.parse(\"/app/data/plasmid.gb\", \"genbank\"):\n    print(\"Record:\", record.id)\n    for feature in record.features:\n        if feature.type in [\"CDS\", \"gene\", \"misc_feature\"]: \n            print(feature.type, feature.qualifiers.get(\"label\"), feature.qualifiers.get(\"note\"), feature.qualifiers.get(\"translation\"))\nEOF\npython3 /app/explore.py\n"]
