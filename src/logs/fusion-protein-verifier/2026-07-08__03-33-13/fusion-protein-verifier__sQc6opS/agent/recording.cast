[127.704878, "i", "cat << 'EOF' > /app/get_all_pdb_seqs.py\nimport requests\n\nwith open(\"/app/data/pdb_ids.txt\") as f:\n    pdb_ids = [line.strip().upper() for line in f if line.strip()]\n\nfor pdb_id in pdb_ids:\n    url = f\"https://data.rcsb.org/rest/v1/core/entry/{pdb_id}\"\n    r = requests.get(url)\n    if r.status_code == 200:\n        data = r.json()\n        entity_ids = data.get(\"rcsb_entry_container_identifiers\", {}).get(\"polymer_entity_ids\", [])\n        for ent_id in entity_ids:\n            ent_url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/{ent_id}\"\n            er = requests.get(ent_url)\n            if er.status_code == 200:\n                edata = er.json()\n                seq = edata.get(\"entity_poly\", {}).get(\"pdbx_seq_one_letter_code\", \"\")\n                seq_can = edata.get(\"entity_poly\", {}).get(\"pdbx_seq_one_letter_code_can\", \"\")\n                desc = edata.get(\"rcsb_polymer_entity\", {}).get(\"pdbx_description\", \"\")\n                print(f\"{pdb_id} (entity {ent_id}): {desc[:40]}\")\n                print(f\"  seq:     {seq[:100]}...\")\n                print(f\"  seq_can: {seq_can[:100]}...\")\n            else:\n                print(f\"{pdb_id} (entity {ent_id}) fetch failed\")\n    else:\n        print(f\"{pdb_id} fetch failed\")\nEOF\npython3 /app/get_all_pdb_seqs.py\n"]
[127.71206, "o", "cat << 'EOF' > /app/get_all_pdb_seqs.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> with open(\"/app/data/pdb_ids.txt\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>     pdb_ids = [line.strip().upper() for line in f if line.strip()]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for pdb_id in pdb_ids:\r\n\u001b[?2004l\r\u001b[?2004h>     url = f\"https://data.rcsb.org/rest/v1/core/entry/{pdb_id}\"\r\n\u001b[?2004l\r\u001b[?2004h>     r = requests.get(url)\r\n\u001b[?2004l\r\u001b[?2004h>     if r.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>         data = r.json()\r\n\u001b[?2004l\r\u001b[?2004h>         entity_ids = data.get(\"rcsb_entry_container_identifiers\", {}).get(\"polymer_entity_ids\", [])\r\n\u001b[?2004l\r\u001b[?2004h>         for ent_id in entity_ids:\r\n\u001b[?2004l\r\u001b[?2004h> "]
