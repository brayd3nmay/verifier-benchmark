[322.2455, "o", "\u001b[?2004l\r\u001b[?2004h>         with open(gblock_path, \"rb\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>             content_bytes = f.read()\r\n\u001b[?2004l\rRNTLNK\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         log(f\"Error reading {gblock_path}: {e}\")\r\n\u001b[?2004l\r\u001b[?2004h>         write_verdict(verdict_file, 0)\r\n\u001b[?2004l\rPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCF"]
[322.24753, "o", "\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # Check if file has exactly one line\r\n\u001b[?2004l\r\u001b[?2004h>     # It contains only the gBlock sequence, on a single line — nothing else, no empty lines.\r\n\u001b[?2004l\r\u001b[?2004h>     # Let's decode as ascii/utf-8\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         content = content_bytes.decode(\"utf-8\")\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\rase version just in case.\r\n    # Let's construct the lists of valid sequence\u001b[?2004h>         log(f\"Error decoding content as UTF-8: {e}\")\r\n\u001b[?2004l\r\u001b[?2004h>         write_verdict(verdict_file, 0)\r\n\u001b[?2004l\rtion 1: PDB sequence of 5WJ2 entity 1 (with (C\u001b[?2004h>         return\r\n\u001b[?2004l\rd \u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # Split by newline\r\n\u001b[?2004l\r\u001b[?2004h>     lines = content.splitlines(keepends=True)\r\n\u001b[?2004l\r\u001b[?2004h>     if len(lines) == 0:\r\n\u001b[?2004l\r\u001b[?2004h>         log(\"Error: gblock.txt is empty.\")\r\n\u001b[?2004l\r\u001b[?2004h>         write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\rK\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # If there's more than 1 line of text, or empty lines\r\n\u001b[?2004l\r\u001b[?2004h>     # A single line of text can have a trailing newline. content.splitlines() removes it.\r\n\u001b[?2004l\r\u001b[?2004h>     # Let's check how many lines there are when splitting by '\r\n\u001b[?2004l\r\u001b[?2004h> ':\r\n\u001b[?2004l\r\u001b[?2004h>     nl_split = content.split(\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>     # If content is \"ATCG\\n\", nl_split is [\"ATCG\", \"\"]\r\n\u001b[?2004l\r\u001b[?2004h>     # If content is \"ATCG\", nl_split is [\"ATCG\"]\r\n\u001b[?2004l\r\u001b[?2004h>     # Any other case is invalid (e.g. \"ATCG\\n\\n\", \"ATCG\\nATCG\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[322.250215, "o", "    if len(nl_split) > 2 or (len(nl_split) == 2 and nl_split[1] != \"\"):\r\n\u001b[?2004l\r\u001b[?2004h>         log(f\"Error: gblock.txt must contain exactly one line. Found split parts: {nl_split}\")\r\n\u001b[?2004l\r\u001b[?2004h>         write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     gblock_seq = nl_split[0].strip().upper()\r\n\u001b[?2004l\r\u001b[?2004h>     if not gblock_seq:\r\n\u001b[?2004l\r\u001b[?2004h>         log(\"Error: gblock sequence is empty.\")\r\n\u001b[?2004l\r\u001b[?2004h>         write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # 2. Check DNA bases\r\n\u001b[?2004l\r\u001b[?2004h>     if not all(c in \"ATCG\" for c in gblock_seq):\r\n\u001b[?2004l\r\u001b[?2004h>         log(\"Error: gblock sequence contains non-ATCG bases.\")\r\n\u001b[?2004l\r\u001b[?2004h>         write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # 3. Check length\r\n\u001b[?2004l\r\u001b[?2004h>     if len(gblock_seq) > 3000:\r\n\u001b[?2004l\r\u001b[?2004h>         log(f\"Error: gblock sequence length {len(gblock_seq)} exceeds 3000.\")\r\n\u001b[?2004l\r\u001b[?2004h>         write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if len(gblock_seq) % 3 != 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[322.255911, "o", ">         log(f\"Error: gblock sequence length {len(gblock_seq)} is not a multiple of 3.\")\r\n\u001b[?2004l\r\u001b[?2004h>         write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # 4. GC content sliding window\r\n\u001b[?2004l\r\u001b[?2004h>     # Every 50-nucleotide window has GC content between 30% and 70%\r\n\u001b[?2004l\r\u001b[?2004h>     if len(gblock_seq) < 50:\r\n\u001b[?2004l\r\u001b[?2004h>         log(\"Error: gblock sequence is less than 50 nucleotides.\")\r\n\u001b[?2004l\r\u001b[?2004h>         write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for i in range(len(gblock_seq) - 49):\r\n\u001b[?2004l\r\u001b[?2004h>         window = gblock_seq[i:i+50]\r\n\u001b[?2004l\r\u001b[?2004h>         gc_count = sum(1 for c in window if c in \"GC\")\r\n\u001b[?2004l\r\u001b[?2004h>         gc_pct = gc_count / 50.0\r\n\u001b[?2004l\r\u001b[?2004h>         if gc_pct < 0.30 or gc_pct > 0.70:\r\n\u001b[?2004l\r\u001b[?2004h>             log(f\"Error: 50-nt window at index {i} ({window}) has GC content {gc_pct:.1%}, which is outside [30%, 70%].\")\r\n\u001b[?2004l\r\u001b[?2004h>             write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>             return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # 5. Translate the sequence\r\n\u001b[?2004l\r\u001b[?2004h>     # Standard genetic code\r\n\u001b[?2004l\r\u001b[?2004h>     from Bio.Seq import Seq\r\n\u001b[?2004l\r\u001b[?2004h>     translated_seq = str(Seq(gblock_seq).translate())\r\n\u001b[?2004l\r\u001b[?2004h>     log(f\"Translated protein (len={len(translated_seq)}): {translated_seq[:100]}...\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # 6. Check for stop codons in the translated sequence\r\n\u001b[?2004l\r\u001b[?2004h>     if \"*\" in translated_seq:\r\n\u001b[?2004l\r\u001b[?2004h>         log(\"Error: Stop codon '*' found in the translated sequence.\")\r\n\u001b[?2004l\r\u001b[?2004h>         write_verdict(verdict_file, 0)\r\n\u001b[?2004l\r\u001b[?2004h>         return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # 7. Define correct subproteins\r\n\u001b[?2004l\r\u001b[?2004h>     # Antibody binder (FLAG-tag)\r\n\u001b[?2004l\r\u001b[?2004h>     antibody_binder_ref = \"DYKDDDDK\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # DHFR from plasmid.gb (without N-term M)\r\n\u001b[?2004l\r\u001b[?2004h>     # Let's extract it from /app/data/plasmid.gb dynamically, with a fallback to the hardcoded sequence\r\n\u001b[?2004l\r\u001b[?2004h>     dhfr_ref = \"\"\r\n\u001b[?2004l\r\u001b[?2004h>     plasmid_path = \"/app/data/plasmid.gb\"\r\n\u001b[?2004l\r\u001b[?2004h>     if os.path.exists(plasmid_path):\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h>             for record in SeqIO.parse(plasmid_path, \"genbank\"):\r\n\u001b[?2004l\r\u001b[?2004h>                 for feature in record.features:\r\n\u001b[?2004l\r\u001b[?2004h>                     if feature.type == \"CDS\":\r\n\u001b[?2004l\r\u001b[?2004h>                         translation = feature.qualifiers.get(\"translation\", [\"\"])[0]\r\n\u001b[?2004l\r\u001b[?2004h>                         if translation.startswith(\"MISLIA\"):\r\n\u001b[?2004l\r\u001b[?2004h>                             dhfr_ref = translation[1:] # remove N-terminal M\r\n\u001b[?2004l\r\u001b[?2004h>                             break\r\n\u001b[?2004l\r\u001b[?2004h>         except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>             log(f\"Warning reading plasmid.gb: {e}\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     if not dhfr_ref:\r\n\u001b[?2004l\r\u001b[?2004h>         dhfr_ref = \"ISLIAALAVDRVIGMENAMPWNLPADLAWFKRNTLNKPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCFEILERR\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Donor (Clover, PDB: 5WJ2)\r\n\u001b[?2004l\r\u001b[?2004h>     # Acceptor (mCherry, PDB: 2H5Q)\r\n\u001b[?2004l\r\u001b[?2004h>     # Molecule binder (SNAP-tag, PDB: 3KZY)\r\n\u001b[?2004l\r\u001b[?2004h>     # We will support both PDB sequence and a canonical version or FPBase version just in case.\r\n\u001b[?2004l\r\u001b[?2004h>     # Let's construct the lists of valid sequences for each\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Clover options:\r\n\u001b[?2004l\r\u001b[?2004h>     # Option 1: PDB sequence of 5WJ2 entity 1 (with (CR2)/X replaced by GYG, N-term M removed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
