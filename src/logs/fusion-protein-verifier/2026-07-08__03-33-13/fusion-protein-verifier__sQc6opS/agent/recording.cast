[191.205775, "i", "cat << 'EOF' > /app/uniprot_search.py\nimport requests\n\n# Let's search UniProt for the sequence of the heavy chain\n# We can use the UniProt REST API to search\n# Or do a sequence search on UniProt\nprint(\"Searching UniProt...\")\n# We can search with the sequence or try to find matching proteins\n# Let's post a sequence search job to UniProt\n# URL: https://rest.uniprot.org/blast/run\n# params: email, title, program=blastp, database=uniprotkb, sequence=...\nEOF\npython3 /app/uniprot_search.py\n"]
[191.234531, "o", "cat << 'EOF' > /app/uniprot_search.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's search UniProt for the sequence of the heavy chain\r\n\u001b[?2004l\r\u001b[?2004h> # We can use the UniProt REST API to search\r\n\u001b[?2004l\r\u001b[?2004h> # Or do a sequence search on UniProt\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Searching UniProt...\")\r\n\u001b[?2004l\r\u001b[?2004h> # We can search with the sequence or try to find matching proteins\r\n\u001b[?2004l\r\u001b[?2004h> # Let's post a sequence search job to UniProt\r\n\u001b[?2004l\r\u001b[?2004h> # URL: https://rest.uniprot.org/blast/run\r\n\u001b[?2004l\r\u001b[?2004h> # params: email, title, program=blastp, database=uniprotkb, sequence=...\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
