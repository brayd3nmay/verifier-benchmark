[45.863967, "i", "cat << 'EOF' > /app/get_fpbase_rest.py\nimport requests\nres = requests.get(\"https://www.fpbase.org/api/proteins/?format=json\")\nif res.status_code == 200:\n    data = res.json()\n    print(\"Keys in first element:\", list(data[0].keys()) if data else \"No data\")\n    # print some matching ones\n    for p in data:\n        # check keys\n        ex = p.get(\"ex_max\")\n        em = p.get(\"em_max\")\n        pdb = p.get(\"primary_pdb\")\n        name = p.get(\"name\")\n        slug = p.get(\"slug\")\n        if ex == 505 or em == 610:\n            print(f\"MATCH REST: {name} (PDB: {pdb}): ex={ex}, em={em}, slug={slug}\")\nelse:\n    print(\"REST failed:\", res.status_code, res.text[:200])\nEOF\npython3 /app/get_fpbase_rest.py\n"]
[45.871608, "o", "cat << 'EOF' > /app/get_fpbase_rest.py\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> res = requests.get(\"https://www.fpbase.org/api/proteins/?format=json\")\r\n\u001b[?2004l\r\u001b[?2004h> if res.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>     data = res.json()\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"Keys in first element:\", list(data[0].keys()) if data else \"No data\")\r\n\u001b[?2004l\r\u001b[?2004h>     # print some matching ones\r\n\u001b[?2004l\r\u001b[?2004h>     for p in data:\r\n\u001b[?2004l\r\u001b[?2004h>         # check keys\r\n\u001b[?2004l\r\u001b[?2004h>         ex = p.get(\"ex_max\")\r\n\u001b[?2004l\r\u001b[?2004h>         em = p.get(\"em_max\")\r\n\u001b[?2004l\r\u001b[?2004h>         pdb = p.get(\"primary_pdb\")\r\n\u001b[?2004l\r\u001b[?2004h>         name = p.get(\"name\")\r\n\u001b[?2004l\r\u001b[?2004h>         slug = p.get(\"slug\")\r\n\u001b[?2004l\r\u001b[?2004h>         if ex == 505 or em == 610:\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"MATCH REST: {name} (PDB: {pdb}): ex={ex}, em={em}, slug={slug}\")\r\n\u001b[?2004l\r\u001b[?2004h> else:\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"REST failed:\", res.status_code, res.text[:200])\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
