[11.962871, "i", "cat << 'EOF' > /app/explore.py\nimport Bio\nfrom Bio import SeqIO\nfor record in SeqIO.parse(\"/app/data/plasmid.gb\", \"genbank\"):\n    print(record.id)\n    for feature in record.features:\n        if \"DHFR\" in feature.qualifiers.get(\"gene\", []) or \"DHFR\" in feature.qualifiers.get(\"product\", []) or \"dhfr\" in feature.qualifiers.get(\"note\", [\"\"])[0].lower():\n            print(feature)\nEOF\npython3 /app/explore.py\n"]
