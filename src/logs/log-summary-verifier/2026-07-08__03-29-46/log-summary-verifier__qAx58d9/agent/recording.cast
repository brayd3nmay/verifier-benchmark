          counts[p][sev_name] += 1\r\n\u001b[?2004l\r\u001b[?2004h> with open('/app/summary.csv', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     f.write('period,severity,count\\n')\r\n\u001b[?2004l\r\u001b[?2004h> "]
