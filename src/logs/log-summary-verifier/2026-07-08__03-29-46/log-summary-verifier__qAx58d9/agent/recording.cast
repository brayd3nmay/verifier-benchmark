[46.140392, "i", "python3 -c \"\nimport os, re, datetime\n\nref_date = datetime.date(2025, 8, 12)\n\n# Define periods\ntoday_range = (ref_date, ref_date)\nlast_7_days_range = (ref_date - datetime.timedelta(days=6), ref_date)\nlast_30_days_range = (ref_date - datetime.timedelta(days=29), ref_date)\nmonth_to_date_range = (datetime.date(2025, 8, 1), ref_date)\n\ndef in_range(date_str, date_range):\n    d = datetime.datetime.strptime(date_str, '%Y-%m-%d').date()\n    return date_range[0] <= d <= date_range[1]\n\nperiods = ['today', 'last_7_days', 'last_30_days', 'month_to_date', 'total']\nseverities = ['ERROR', 'WARNING', 'INFO']\n\ncounts = {p: {s: 0 for s in severities} for p in periods}\n\nlog_dir = '/app/logs'\nfor f in os.listdir(log_dir):\n    m = re.match('^([0-9]{4}-[0-9]{2}-[0-9]{2})_', f)\n    if not m: continue\n    date_str = m.group(1)\n    \n    # Determine which periods this file falls into\n    file_periods = ['total']\n    if in_range(date_str, today_range): file_periods.append('today')\n    if in_range(date_str, last_7_days_range): file_periods.append('last_7_days')\n    if in_range(date_str, last_30_days_range): file_periods.append('last_30_days')\n    if in_range(date_str, month_to_date_range): file_periods.append('month_to_date')\n    \n    with open(os.path.join(log_dir, f), 'r') as fh:\n        for line in fh:\n            # extract the severity bracketed token\n            # line is like: 2025-07-03 09:24:57 [ERROR] Unhandled exception...\n            # let's split by space\n            parts = line.strip().split(' ', 3)\n            if len(parts) >= 3:\n                sev = parts[2]\n                if sev.startswith('[') and sev.endswith(']'):\n                    sev_name = sev[1:-1]\n                    if sev_name in severities:\n                        for p in file_periods:\n                            counts[p][sev_name] += 1\n\n# Print counts for verification\nfor p in periods:\n    for s in severities:\n        print(f'{p},{s},{counts[p][s]}')\n\"\n"]
[46.164176, "o", "python3 -c \"\r\n\u001b[?2004l\r"]
[46.175672, "o", "\u001b[?2004h> import os, re, datetime\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> ref_date = datetime.date(2025, 8, 12)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Define periods\r\n\u001b[?2004l\r\u001b[?2004h> today_range = (ref_date, ref_date)\r\n\u001b[?2004l\r\u001b[?2004h> last_7_days_range = (ref_date - datetime.timedelta(days=6), ref_date)\r\n\u001b[?2004l\r\u001b[?2004h> last_30_days_range = (ref_date - datetime.timedelta(days=29), ref_date)\r\n\u001b[?2004l\r\u001b[?2004h> month_to_date_range = (datetime.date(2025, 8, 1), ref_date)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def in_range(date_str, date_range):\r\n\u001b[?2004l\r\u001b[?2004h>     d = datetime.datetime.strptime(date_str, '%Y-%m-%d').date()\r\n\u001b[?2004l\r\u001b[?2004h>     return date_range[0] <= d <= date_range[1]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> periods = ['today', 'last_7_days', 'last_30_days', 'month_to_date', 'total']\r\n\u001b[?2004l\r\u001b[?2004h> severities = ['ERROR', 'WARNING', 'INFO']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> counts = {p: {s: 0 for s in severities} for p in periods}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> log_dir = '/app/logs'\r\n\u001b[?2004l\r\u001b[?2004h> for f in os.listdir(log_dir):\r\n\u001b[?2004l\r\u001b[?2004h>     m = re.match('^([0-9]{4}-[0-9]{2}-[0-9]{2})_', f)\r\n\u001b[?2004l\r\u001b[?2004h>     if not m: continue\r\n\u001b[?2004l\r\u001b[?2004h>     date_str = m.group(1)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Determine which periods this file falls into\r\n\u001b[?2004l\r\u001b[?2004h>     file_periods = ['total']\r\n\u001b[?2004l\r\u001b[?2004h>     if in_range(date_str, today_range): file_periods.append('today')\r\n\u001b[?2004l\r\u001b[?2004h>     if in_range(date_str, last_7_days_range): file_periods.append('last_7_days')\r\n\u001b[?2004l\r\u001b[?2004h>     if in_range(date_str, last_30_days_range): file_periods.append('last_30_days')\r\n\u001b[?2004l\r\u001b[?2004h>     if in_range(date_str, month_to_date_range): file_periods.append('month_to_date')\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     with open(os.path.join(log_dir, f), 'r') as fh:\r\n\u001b[?2004l\r\u001b[?2004h>         for line in fh:\r\n\u001b[?2004l\r\u001b[?2004h>             # extract the severity bracketed token\r\n\u001b[?2004l\r\u001b[?2004h>             # line is like: 2025-07-03 09:24:57 [ERROR] Unhandled exception...\r\n\u001b[?2004l\r\u001b[?2004h>             # let's split by space\r\n\u001b[?2004l\r\u001b[?2004h>             parts = line.strip().split(' ', 3)\r\n\u001b[?2004l\r\u001b[?2004h>             if len(parts) >= 3:\r\n\u001b[?2004l\r\u001b[?2004h>                 sev = parts[2]\r\n\u001b[?2004l\r\u001b[?2004h>                 if sev.startswith('[') and sev.endswith(']'):\r\n\u001b[?2004l\r\u001b[?2004h>                     sev_name = sev[1:-1]\r\n\u001b[?2004l\r\u001b[?2004h>                     if sev_name in severities:\r\n\u001b[?2004l\r\u001b[?2004h>                         for p in file_periods:\r\n\u001b[?2004l\r\u001b[?2004h>                             counts[p][sev_name] += 1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Print counts for verification\r\n\u001b[?2004l\r\u001b[?2004h> for p in periods:\r\n\u001b[?2004l\r\u001b[?2004h>     for s in severities:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f'{p},{s},{counts[p][s]}')\r\n\u001b[?2004l\r\u001b[?2004h> \"\r\n\u001b[?2004l\r"]
