[38.828485, "i", "python3 -c \"\nimport os, re\ncount = 0\nfor f in os.listdir('/app/logs'):\n    if not f.endswith('.log'): continue\n    with open(os.path.join('/app/logs', f), 'r') as fh:\n        for line in fh:\n            if not re.match('^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2} \\\\[[A-Z]+\\\\]', line):\n                print('Non-standard:', line.strip())\n                count += 1\n                if count > 10: break\n    if count > 10: break\n\"\n"]
[38.83416, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import os, re\r\n\u001b[?2004l\r\u001b[?2004h> count = 0\r\n\u001b[?2004l\r\u001b[?2004h> for f in os.listdir('/app/logs'):\r\n\u001b[?2004l\r\u001b[?2004h>     if not f.endswith('.log'): continue\r\n\u001b[?2004l\r\u001b[?2004h>     with open(os.path.join('/app/logs', f), 'r') as fh:\r\n\u001b[?2004l\r\u001b[?2004h>         for line in fh:\r\n\u001b[?2004l\r\u001b[?2004h>             if not re.match('^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2} \\\\[[A-Z]+\\\\]', line):\r\n\u001b[?2004l\r\u001b[?2004h>                 print('Non-standard:', line.strip())\r\n\u001b[?2004l\r\u001b[?2004h>                 count += 1\r\n\u001b[?2004l\r\u001b[?2004h>                 if count > 10: break\r\n\u001b[?2004l\r\u001b[?2004h>     if count > 10: break\r\n\u001b[?2004l\r"]
