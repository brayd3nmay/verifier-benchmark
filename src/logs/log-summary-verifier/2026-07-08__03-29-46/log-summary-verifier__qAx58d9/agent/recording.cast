[86.903388, "i", "python3 -c \"\nimport os, re, datetime\nref_date = datetime.date(2025, 8, 12)\ntoday_range = (ref_date, ref_date)\nlast_7_days_range = (ref_date - datetime.timedelta(days=6), ref_date)\nlast_30_days_range = (ref_date - datetime.timedelta(days=29), ref_date)\nmonth_to_date_range = (datetime.date(2025, 8, 1), ref_date)\ndef in_range(date_str, date_range):\n    d = datetime.datetime.strptime(date_str, '%Y-%m-%d').date()\n    return date_range[0] <= d <= date_range[1]\nperiods = ['today', 'last_7_days', 'last_30_days', 'month_to_date', 'total']\nseverities = ['ERROR', 'WARNING', 'INFO']\ncounts = {p: {s: 0 for s in severities} for p in periods}\nlog_dir = '/app/logs'\nfor f in os.listdir(log_dir):\n    m = re.match('^([0-9]{4}-[0-9]{2}-[0-9]{2})_', f)\n    if not m: continue\n    date_str = m.group(1)\n    file_periods = ['total']\n    if in_range(date_str, today_range): file_periods.append('today')\n    if in_range(date_str, last_7_days_range): file_periods.append('last_7_days')\n    if in_range(date_str, last_30_days_range): file_periods.append('last_30_days')\n    if in_range(date_str, month_to_date_range): file_periods.append('month_to_date')\n    with open(os.path.join(log_dir, f), 'r') as fh:\n        for line in fh:\n            parts = line.strip().split(' ', 3)\n            if len(parts) >= 3:\n                sev = parts[2]\n                if sev.startswith('[') and sev.endswith(']'):\n                    sev_name = sev[1:-1]\n                    if sev_name in severities:\n                        for p in file_periods:\n                            counts[p][sev_name] += 1\nwith open('/app/summary.csv', 'w') as f:\n    f.write('period,severity,count\\n')\n    for p in periods:\n        for s in severities:\n            f.write(f'{p},{s},{counts[p][s]}\\n')\n\"\n"]
[86.9233, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import os, re, datetime\r\n\u001b[?2004l\r\u001b[?2004h> ref_date = datetime.date(2025, 8, 12)\r\n\u001b[?2004l\r\u001b[?2004h> today_range = (ref_date, ref_date)\r\n\u001b[?2004l\r\u001b[?2004h> last_7_days_range = (ref_date - datetime.timedelta(days=6), ref_date)\r\n\u001b[?2004l\r\u001b[?2004h> last_30_days_range = (ref_date - datetime.timedelta(days=29), ref_date)\r\n\u001b[?2004l\r\u001b[?2004h> month_to_date_range = (datetime.date(2025, 8, 1), ref_date)\r\n\u001b[?2004l\r\u001b[?2004h> def in_range(date_str, date_range):\r\n\u001b[?2004l\r\u001b[?2004h> "]
