[198.87089, "i", "cat << 'EOF' > /app/verifier/verify.sh\n#!/bin/bash\n\n# Set defaults if not provided\nexport SOLUTION_DIR=\"${SOLUTION_DIR:-/app}\"\nexport VERDICT_FILE=\"${VERDICT_FILE:-/logs/verifier/reward.txt}\"\n\n# Remove any old verdict file to avoid stale results\nrm -f \"$VERDICT_FILE\"\n\n# Run python verifier\npython3 /app/verifier/verify.py\n\n# Fallback if python script crashed or did not produce the verdict file\nif [ ! -f \"$VERDICT_FILE\" ]; then\n    mkdir -p \"$(dirname \"$VERDICT_FILE\")\"\n    echo \"0\" > \"$VERDICT_FILE\"\nfi\nEOF\nchmod +x /app/verifier/verify.sh\n"]
[198.91004, "o", "cat << 'EOF' > /app/verifier/verify.sh\r\n\u001b[?2004l\r\u001b[?2004h> #!/bin/bash\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Set defaults if not provided\r\n\u001b[?2004l\r\u001b[?2004h> export SOLUTION_DIR=\"${SOLUTION_DIR:-/app}\"\r\n\u001b[?2004l\r\u001b[?2004h> export VERDICT_FILE=\"${VERDICT_FILE:-/logs/verifier/reward.txt}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Remove any old verdict file to avoid stale results\r\n\u001b[?2004l\r\u001b[?2004h> rm -f \"$VERDICT_FILE\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Run python verifier\r\n\u001b[?2004l\r\u001b[?2004h> python3 /app/verifier/verify.py\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Fallback if python script crashed or did not produce the verdict file\r\n\u001b[?2004l\r\u001b[?2004h> if [ ! -f \"$VERDICT_FILE\" ]; then\r\n\u001b[?2004l\r\u001b[?2004h>     mkdir -p \"$(dirname \"$VERDICT_FILE\")\"\r\n\u001b[?2004l\r\u001b[?2004h>     echo \"0\" > \"$VERDICT_FILE\"\r\n\u001b[?2004l\r\u001b[?2004h> fi\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
