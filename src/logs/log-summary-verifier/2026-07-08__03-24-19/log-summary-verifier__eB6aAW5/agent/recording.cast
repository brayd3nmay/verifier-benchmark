[43.912279, "i", "python3 -c '\nimport os, re, glob\nlog_dir = \"/app/logs\"\nfor fp in glob.glob(os.path.join(log_dir, \"*.log\")):\n    with open(fp, \"r\", errors=\"ignore\") as f:\n        for line in f:\n            # Let\\'s see if [ERROR], [WARNING] or [INFO] appears in the line, but not as parts[2]\n            parts = line.strip().split(\" \")\n            has_severity_word_in_brackets = any(x in line for x in [\"[ERROR]\", \"[WARNING]\", \"[INFO]\"])\n            is_parts_2_severity = len(parts) >= 3 and parts[2] in (\"[ERROR]\", \"[WARNING]\", \"[INFO]\")\n            if has_severity_word_in_brackets and not is_parts_2_severity:\n                print(f\"Mismatch in {fp}: {line.strip()}\")\n'\n"]
