[184.320577, "o", "     1\timport os\r\n     2\timport re\r\n     3\timport csv\r\n     4\timport sys\r\n     5\timport glob\r\n     6\tfrom datetime import datetime, date\r\n     7\t\r\n     8\t# Get directories from environment or use defaults\r\n     9\tsolution_dir = os.environ.get(\"SOLUTION_DIR\", \"/app\")\r\n    10\tverdict_file = os.environ.get(\"VERDICT_FILE\", \"/logs/verifier/reward.txt\")\r\n    11\tlog_dir = \"/app/logs\"\r\n    12\t\r\n    13\tdef write_verdict(val, msg=\"\"):\r\n    14\t    if msg:\r\n    15\t        sys.stderr.write(msg + \"\\n\")\r\n    16\t    try:\r\n    17\t        os.makedirs(os.path.dirname(verdict_file), exist_ok=True)\r\n    18\t        with open(verdict_file, \"w\") as f:\r\n    19\t            f.write(str(val) + \"\\n\")\r\n    20\t    except Exception as e:\r\n    21\t        sys.stderr.write(f\"Failed to write verdict: {e}\\n\")\r\n    22\t    sys.exit(0)\r\n    23\t\r\n    24\t# 1. Compute ground truth counts\r\n    25\tdef get_ground_truth():\r\n    26\t    ref_date = date(2025, 8, 12)\r\n    27\t    periods = {\r\n    28\t        'today': lambda d: d == date(2025, 8, 12),\r\n    29\t        'last_7_days': lambda d: date(2025, 8, 6) <= d <= date(2025, 8, 12),\r\n    30\t        'last_30_days': lambda d: date(2025, 7, 14) <= d <= date(2025, 8, 12),\r\n    31\t        'month_to_date': lambda d: date(2025, 8, 1) <= d <= date(2025, 8, 12),\r\n    32\t        'total': lambda d: True\r\n    33\t    }\r\n    34\t    \r\n    35\t    counts = {p: {'ERROR': 0, 'WARNING': 0, 'INFO': 0} for p in periods}\r\n    36\t    \r\n    37\t    filepaths = glob.glob(os.path.join(log_dir, \"*.log\"))\r\n    38\t    \r\n    39\t    for fp in filepaths:\r\n    40\t        basename = os.path.basename(fp)\r\n    41\t        match = re.match(r'^([0-9]{4}-[0-9]{2}-[0-9]{2})_', basename)\r\n    42\t        if not match:\r\n    43\t            continue\r\n    44\t        try:\r\n    45\t            d = datetime.strptime(match.group(1), \"%Y-%m-%d\").date()\r\n    46\t        except ValueError:\r\n    47\t            continue\r\n    48\t            \r\n    49\t        with open(fp, 'r', errors='ignore') as f:\r\n    50\t            for line in f:\r\n    51\t                parts = line.strip().split(' ')\r\n    52\t                if len(parts) >= 3:\r\n    53\t                    sev_part = parts[2]\r\n    54\t                    if sev_part in ('[ERROR]', '[WARNING]', '[INFO]'):\r\n    55\t                        sev = sev_part[1:-1]\r\n    56\t                        for p, cond in periods.items():\r\n    57\t                            if cond(d):\r\n    58\t                                counts[p][sev] += 1\r\n    59\t    return counts\r\n    60\t\r\n    61\ttry:\r\n    62\t    ground_truth = get_ground_truth()\r\n    63\texcept Exception as e:\r\n    64\t    write_verdict(0, f\"Error computing ground truth: {e}\")\r\n    65\t\r\n    66\t# 2. Check if summary.csv exists\r\n    67\tcsv_path = os.path.join(solution_dir, \"summary.csv\")\r\n    68\tif not os.path.isfile(csv_path):\r\n    69\t    write_verdict(0, f\"File summary.csv not found at {csv_path}\")\r\n    70\t\r\n    71\t# 3. Read and parse summary.csv\r\n    72\ttry:\r\n    73\t    with open(csv_path, 'r', newline='', encoding='utf-8', errors='ignore') as f:\r\n    74\t        reader = csv.DictReader(f)\r\n    75\t        \r\n    76\t        # Check headers\r\n    77\t        headers = reader.fieldnames\r\n    78\t        if not headers:\r\n    79\t            write_verdict(0, \"summary.csv is empty or has no headers\")\r\n    80\t        \r\n    81\t        # Strip whitespaces from header names just in case\r\n    82\t        headers_stripped = [h.strip() for h in headers if h]\r\n    83\t        required_cols = {'period', 'severity', 'count'}\r\n    84\t        if not required_cols.issubset(set(headers_stripped)):\r\n    85\t            write_verdict(0, f\"Missing required columns. Found headers: {headers_stripped}\")\r\n    86\t            \r\n    87\t        # Map original headers to stripped names for safe lookup\r\n    88\t        header_map = {}\r\n    89\t        for h in headers:\r\n    90\t            if h:\r\n    91\t                header_map[h.strip()] = h\r\n    92\t                \r\n    93\t        col_period = header_map['period']\r\n    94\t        col_severity = header_map['severity']\r\n    95\t        col_count = header_map['count']\r\n    96\t        \r\n"]
[184.320693, "o", "    97\t        # Parse rows\r\n    98\t        parsed_counts = {}\r\n    99\t        for row in reader:\r\n   100\t            p_val = row[col_period]\r\n   101\t            s_val = row[col_severity]\r\n   102\t            c_val = row[col_count]\r\n   103\t            \r\n   104\t            if p_val is None or s_val is None or c_val is None:\r\n   105\t                continue # skip malformed row or empty values\r\n   106\t                \r\n   107\t            p_val = p_val.strip()\r\n   108\t            s_val = s_val.strip()\r\n   109\t            c_val = c_val.strip()\r\n   110\t            \r\n   111\t            # We only record rows matching our required periods and severities\r\n   112\t            if p_val in ground_truth and s_val in ('ERROR', 'WARNING', 'INFO'):\r\n   113\t                # Count must be non-negative integer with no decimal, sign, or thousand separators\r\n   114\t                # i.e., must match ^[0-9]+$\r\n   115\t                if not re.match(r'^[0-9]+$', c_val):\r\n   116\t                    write_verdict(0, f\"Invalid count format: {c_val} for {p_val}, {s_val}\")\r\n   117\t                \r\n   118\t                key = (p_val, s_val)\r\n   119\t                if key in parsed_counts:\r\n   120\t                    write_verdict(0, f\"Duplicate entry for period={p_val}, severity={s_val}\")\r\n   121\t                parsed_counts[key] = int(c_val)\r\n   122\t                \r\n   123\texcept Exception as e:\r\n   124\t    write_verdict(0, f\"Error parsing summary.csv: {e}\")\r\n   125\t\r\n   126\t# 4. Compare with ground truth\r\n   127\t# Ensure all 15 entries are present and correct\r\n   128\tfor period, sevs in ground_truth.items():\r\n   129\t    for sev, expected_count in sevs.items():\r\n   130\t        key = (period, sev)\r\n   131\t        if key not in parsed_counts:\r\n   132\t            write_verdict(0, f\"Missing entry for period={period}, severity={sev}\")\r\n   133\t        \r\n   134\t        actual_count = parsed_counts[key]\r\n   135\t        if actual_count != expected_count:\r\n   136\t            write_verdict(0, f\"Mismatch for period={period}, severity={sev}. Expected {expected_count}, got {actual_count}\")\r\n   137\t\r\n   138\twrite_verdict(1, \"Verification successful!\")\r\n\u001b[?2004hroot@206771236dfe:/app# "]
