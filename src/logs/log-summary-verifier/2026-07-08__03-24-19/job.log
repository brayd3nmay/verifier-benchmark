Sending keys: ['cat << \'EOF\' > /app/get_ground_truth.py\nimport os\nimport re\nimport glob\nfrom datetime import datetime, date\n\nlog_dir = "/app/logs"\nref_date = date(2025, 8, 12)\n\ndef parse_filename_date(filepath):\n    basename = os.path.basename(filepath)\n    match = re.match(r\'^([0-9]{4}-[0-9]{2}-[0-9]{2})_\', basename)\n    if match:\n        return datetime.strptime(match.group(1), "%Y-%m-%d").date()\n    return None\n\nperiods = {\n    \'today\': lambda d: d == date(2025, 8, 12),\n    \'last_7_days\': lambda d: date(2025, 8, 6) <= d <= date(2025, 8, 12),\n    \'last_30_days\': lambda d: date(2025, 7, 14) <= d <= date(2025, 8, 12),\n    \'month_to_date\': lambda d: date(2025, 8, 1) <= d <= date(2025, 8, 12),\n    \'total\': lambda d: True\n}\n\ncounts = {p: {\'ERROR\': 0, \'WARNING\': 0, \'INFO\': 0} for p in periods}\n\n# Let\'s inspect line format to see if we can use simple split.\n# If every line looks like `<timestamp> [SEVERITY] <message>`\n# with <timestamp> having format YYYY-MM-DD HH:MM:SS\n# Then split(\' \') would yield:\n# parts[0]: YYYY-MM-DD\n# parts[1]: HH:MM:SS\n# parts[2]: [SEVERITY]\n\nfilepaths = glob.glob(os.path.join(log_dir, "*.log"))\n\nfor fp in filepaths:\n    d = parse_filename_date(fp)\n    if d is None:\n        continue\n    \n    with open(fp, \'r\', errors=\'ignore\') as f:\n        for line in f:\n            parts = line.strip().split(\' \')\n            if len(parts) >= 3:\n                sev_part = parts[2]\n                if sev_part in (\'[ERROR]\', \'[WARNING]\', \'[INFO]\'):\n                    sev = sev_part[1:-1]\n                    for p, cond in periods.items():\n                        if cond(d):\n                            counts[p][sev] += 1\n\nfor p, sevs in counts.items():\n    for sev, count in sevs.items():\n        print(f"{p},{sev},{count}")\nEOF\npython3 /app/get_ground_truth.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
