[34.964542, "i", "cat << 'EOF' > /tmp/calculate.py\nimport os\nimport re\nfrom datetime import datetime\n\nlog_dir = '/app/logs'\nref_date = datetime.strptime('2025-08-12', '%Y-%m-%d').date()\n\nperiods = {\n    'today': lambda d: d == ref_date,\n    'last_7_days': lambda d: (ref_date - d).days >= 0 and (ref_date - d).days < 7,\n    'last_30_days': lambda d: (ref_date - d).days >= 0 and (ref_date - d).days < 30,\n    'month_to_date': lambda d: d.year == 2025 and d.month == 8 and d.day <= 12,\n    'total': lambda d: True\n}\n\ncounts = {p: {'ERROR': 0, 'WARNING': 0, 'INFO': 0} for p in periods}\n\n# Let's verify line parsing regex:\n# Example line: \"2025-07-03 09:24:57 [ERROR] Unhandled exception: FileNotFoundError\"\n# We want the bracketed token strictly at index 2 (when split by space) or using a clear regex.\nline_re = re.compile(r'^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2} \\[(ERROR|WARNING|INFO)\\]')\n\nfor fname in os.listdir(log_dir):\n    m = re.match(r'^(\\d{4}-\\d{2}-\\d{2})_.*\\.log$', fname)\n    if not m:\n        continue\n    fdate = datetime.strptime(m.group(1), '%Y-%m-%d').date()\n    \n    # Check which periods this file falls into\n    active_periods = [p for p, check in periods.items() if check(fdate)]\n    if not active_periods:\n        continue\n        \n    with open(os.path.join(log_dir, fname), 'r', errors='ignore') as f:\n        for line in f:\n            lm = line_re.match(line)\n            if lm:\n                sev = lm.group(1)\n                for p in active_periods:\n                    counts[p][sev] += 1\n\nprint(\"period,severity,count\")\nfor p in counts:\n    for sev in counts[p]:\n        print(f\"{p},{sev},{counts[p][sev]}\")\nEOF\npython3 /tmp/calculate.py\n"]
