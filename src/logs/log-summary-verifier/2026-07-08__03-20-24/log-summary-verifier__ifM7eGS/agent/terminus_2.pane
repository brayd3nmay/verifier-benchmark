[?2004hroot@a20b5c658574:/app# cat << 'EOF' > /tmp/calculate.py
[?2004l[?2004h> import os
[?2004l[?2004h> import re
[?2004l[?2004h> from datetime import datetime
[?2004l[?2004h> 
[?2004l[?2004h> log_dir = '/app/logs'
[?2004l[?2004h> ref_date = datetime.strptime('2025-08-12', '%Y-%m-%d').date()
[?2004l[?2004h> 
[?2004l[?2004h> periods = {
[?2004l[?2004h>     'today': lambda d: d == ref_date,
[?2004l[?2004h>     'last_7_days': lambda d: (ref_date - d).days >= 0 and (ref_date - d).days < 7,
[?2004l[?2004h>     'last_30_days': lambda d: (ref_date - d).days >= 0 and (ref_date - d).days < 30,
[?2004l[?2004h>     'month_to_date': lambda d: d.year == 2025 and d.month == 8 and d.day <= 12,
[?2004l[?2004h>     'total': lambda d: True
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> counts = {p: {'ERROR': 0, 'WARNING': 0, 'INFO': 0} for p in periods}
[?2004l[?2004h> 
[?2004l[?2004h> # Let's verify line parsing regex:
[?2004l[?2004h> # Example line: "2025-07-03 09:24:57 [ERROR] Unhandled exception: FileNotFoundError"
[?2004l[?2004h> # We want the bracketed token strictly at index 2 (when split by space) or using a clear regex.
[?2004l[?2004h> line_re = re.compile(r'^\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2} \[(ERROR|WARNING|INFO)\]')
[?2004l[?2004h> 
[?2004l[?2004h> for fname in os.listdir(log_dir):
[?2004l[?2004h>     m = re.match(r'^(\d{4}-\d{2}-\d{2})_.*\.log$', fname)
[?2004l[?2004h>     if not m:
[?2004l[?2004h>         continue
[?2004l[?2004h>     fdate = datetime.strptime(m.group(1), '%Y-%m-%d').date()
[?2004l[?2004h>     
[?2004l[?2004h>     # Check which periods this file falls into
[?2004l[?2004h>     active_periods = [p for p, check in periods.items() if check(fdate)]
[?2004l[?2004h>     if not active_periods:
[?2004l[?2004h>         continue
[?2004l[?2004h>         
[?2004l[?2004h>     with open(os.path.join(log_dir, fname), 'r', errors='ignore') as f:
[?2004l[?2004h>         for line in f:
[?2004l[?2004h>             lm = line_re.match(line)
[?2004l[?2004h>             if lm:
[?2004l[?2004h>                 sev = lm.group(1)
[?2004l[?2004h>                 for p in active_periods:
[?2004l[?2004h>                     counts[p][sev] += 1
[?2004l[?2004h> 
[?2004l[?2004h> print("period,severity,count")
[?2004l[?2004h> for p in counts:
[?2004l[?2004h>     for sev in counts[p]:
[?2004l[?2004h>         print(f"{p},{sev},{counts[p][sev]}")
