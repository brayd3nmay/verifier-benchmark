[?2004l[?2004h> 
[?2004l[?2004h> # True counts calculation
[?2004l[?2004h> log_dir = '/app/logs'
[?2004l[?2004h> 
[?2004l[?2004h> today_start = date(2025, 8, 12)
[?2004l[?2004h> today_end = date(2025, 8, 12)
[?2004l[?2004h> 
[?2004l[?2004h> last_7_start = date(2025, 8, 6)
[?2004l[?2004h> last_7_end = date(2025, 8, 12)
[?2004l[?2004h> 
[?2004l[?2004h> last_30_start = date(2025, 7, 14)
[?2004l[?2004h> last_30_end = date(2025, 8, 12)
[?2004l[?2004h> 
[?2004l[?2004h> mtd_start = date(2025, 8, 1)
[?2004l[?2004h> mtd_end = date(2025, 8, 12)
[?2004l[?2004h> 
[?2004l[?2004h> def is_today(d):
[?2004l[?2004h>     return today_start <= d <= today_end
[?2004l[?2004h> 
[?2004l[?2004h> def is_last_7(d):
[?2004l[?2004h>     return last_7_start <= d <= last_7_end
[?2004l[?2004h> 
[?2004l[?2004h> def is_last_30(d):
[?2004l[?2004h>     return last_30_start <= d <= last_30_end
[?2004l[?2004h> 
[?2004l[?2004h> def is_mtd(d):
[?2004l[?2004h>     return mtd_start <= d <= mtd_end
[?2004l[?2004h> 
[?2004l[?2004h> def is_total(d):
[?2004l[?2004h>     return True
[?2004l[?2004h> 
[?2004l[?2004h> periods = {
[?2004l[?2004h>     'today': is_today,
[?2004l[?2004h>     'last_7_days': is_last_7,
[?2004l[?2004h>     'last_30_days': is_last_30,
[?2004l[?2004h>     'month_to_date': is_mtd,
[?2004l[?2004h>     'total': is_total
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> expected = {(p, s): 0 for p in periods for s in ['ERROR', 'WARNING', 'INFO']}
[?2004l[?2004h> 
[?2004l[?2004h> line_re = re.compile(r'^\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2} \[(ERROR|WARNING|INFO)\]')
[?2004l[?2004h> 
[?2004l[?2004h> if os.path.exists(log_dir):
[?2004l[?2004h>     for fname in os.listdir(log_dir):
[?2004l[?2004h>         m = re.match(r'^(\d{4}-\d{2}-\d{2})_.*\.log$', fname)
[?2004l[?2004h>         if not m:
[?2004l[?2004h>             continue
[?2004l[?2004h>         try:
[?2004l[?2004h>             y, m_val, d = map(int, m.group(1).split('-'))
[?2004l[?2004h>             fdate = date(y, m_val, d)
[?2004l[?2004h>         except Exception:
[?2004l[?2004h>             continue
[?2004l[?2004h> 
[?2004l[?2004h>         active_periods = [p for p, check in periods.items() if check(fdate)]
[?2004l[?2004h>         if not active_periods:
[?2004l[?2004h>             continue
[?2004l[?2004h> 
[?2004l[?2004h>         with open(os.path.join(log_dir, fname), 'r', encoding='utf-8', errors='ignore') as f:
[?2004l[?2004h>             for line in f:
[?2004l[?2004h>                 lm = line_re.match(line)
[?2004l[?2004h>                 if lm:
[?2004l[?2004h>                     sev = lm.group(1)
[?2004l[?2004h>                     for p in active_periods:
[?2004l[?2004h>                         expected[(p, sev)] += 1
[?2004l[?2004h> 
[?2004l[?2004h> # Read attempt's CSV
[?2004l[?2004h> csv_path = os.path.join(solution_dir, 'summary.csv')
[?2004l[?2004h> 
[?2004l[?2004h> if not os.path.exists(csv_path):
[?2004l[?2004h>     with open(verdict_file, 'w') as vf:
[?2004l[?2004h>         vf.write('0\n')
[?2004l[?2004h>     sys.exit(0)
[?2004l[?2004h> 
[?2004l[?2004h> try:
[?2004l[?2004h>     with open(csv_path, 'r', encoding='utf-8', errors='ignore') as f:
[?2004l[?2004h>         reader = csv.DictReader(f)
[?2004l[?2004h>         if not reader.fieldnames:
[?2004l[?2004h>             raise ValueError("No headers")
[?2004l[?2004h>         
[?2004l[?2004h>         headers = [h.strip() for h in reader.fieldnames if h]
[?2004l[?2004h>         if 'period' not in headers or 'severity' not in headers or 'count' not in headers:
[?2004l[?2004h>             raise ValueError("Missing headers")
[?2004l[?2004h>         
[?2004l[?2004h>         rows = []
[?2004l[?2004h>         for raw_row in reader:
[?2004l[?2004h>             clean_row = {}
[?2004l[?2004h>             for k, v in raw_row.items():
[?2004l[?2004h>                 if k is not None:
[?2004l[?2004h>                     clean_row[k.strip()] = v.strip() if v is not None else ""
[?2004l[?2004h>             if any(clean_row.values()):
[?2004l[?2004h>                 rows.append(clean_row)
[?2004l[?2004h>             
[?2004l[?2004h>     found = {}
[?2004l[?2004h>     valid = True
[?2004l[?2004h>     for r in rows:
[?2004l[?2004h>         p = r.get('period')
[?2004l[?2004h>         s = r.get('severity')
[?2004l[?2004h>         c_str = r.get('count')
[?2004l[?2004h>         
[?2004l[?2004h>         if (p, s) in expected:
[?2004l[?2004h>             if (p, s) in found:
[?2004l[?2004h>                 valid = False
[?2004l[?2004h>                 break
[?2004l[?2004h>             if not c_str.isdigit():
[?2004l[?2004h>                 valid = False
[?2004l[?2004h>                 break
[?2004l[?2004h>             c_val = int(c_str)
