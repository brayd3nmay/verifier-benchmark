[58.928489, "i", "Rscript -e 'g <- dnorm; D <- c(-Inf, Inf); total <- integrate(g, D[1], D[2])$value; CDF <- function(x) { sapply(x, function(v) { if (v <= D[1]) return(0); if (v >= D[2]) return(1); integrate(g, D[1], v)$value / total }) }; samples <- rnorm(100); print(ks.test(samples, CDF)$p.value)'\n"]
[58.93144, "o", "Rscript -e 'g <- dnorm; D <- c(-Inf, Inf); total <- integrate(g, D[1], D[2])$value; CDF <- function(x) { sapply(x, function(v) { if (v <= D[1]) return(0); if (v >= D[2]) return(1); integrate(g, D[1], v)$value / total }) }; samples <- rnorm(100); print(ks.test(samples, CDF)$p.value)'\r\n\u001b[?2004l\r"]
