[?2004l[?2004h>     setwd(old_wd)
[?2004l[?2004h>   }, error = function(e) {})
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> samples_exist_after <- file.exists(file.path(solution_dir, "normal_samples.txt")) || 
[?2004l[?2004h>                        file.exists(file.path(solution_dir, "exponential_samples.txt"))
[?2004l[?2004h> 
[?2004l[?2004h> if (!test_func_exists || !(samples_exist_before || samples_exist_after)) {
[?2004l[?2004h>   write_verdict(0)
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> # 5. Helper for valid log-concave cases
[?2004l[?2004h> run_test_case <- function(g, D, n, name) {
[?2004l[?2004h>   res <- tryCatch({
[?2004l[?2004h>     # We use integrate to find the normalizer
[?2004l[?2004h>     C <- integrate(g, D[1], D[2])$value
[?2004l[?2004h>     cdf <- function(x) {
[?2004l[?2004h>       sapply(x, function(val) {
[?2004l[?2004h>         if (val <= D[1]) return(0)
[?2004l[?2004h>         if (val >= D[2]) return(1)
[?2004l[?2004h>         integrate(g, D[1], val)$value / C
[?2004l[?2004h>       })
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     passed <- FALSE
[?2004l[?2004h>     for (attempt in 1:2) {
[?2004l[?2004h>       samples <- ars(g, D, n)
[?2004l[?2004h>       if (length(samples) != n) next
[?2004l[?2004h>       if (any(samples < D[1] | samples > D[2])) next
[?2004l[?2004h>       if (any(is.na(samples) | is.nan(samples))) next
[?2004l[?2004h>       
[?2004l[?2004h>       # KS test
[?2004l[?2004h>       ks_res <- ks.test(samples, cdf)
[?2004l[?2004h>       if (ks_res$p.value >= 0.001) {
[?2004l[?2004h>         passed <- TRUE
[?2004l[?2004h>         break
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>     passed
[?2004l[?2004h>   }, error = function(e) {
[?2004l[?2004h>     FALSE
[?2004l[?2004h>   })
[?2004l[?2004h>   return(res) 
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> # 6. Helper for checking that invalid inputs throw error
[?2004l[?2004h> run_invalid_test <- function(expr) {
[?2004l[?2004h>   tryCatch({
[?2004l[?2004h>     eval(expr)
[?2004l[?2004h>     FALSE # Should have thrown error
[?2004l[?2004h>   }, error = function(e) {
[?2004l[?2004h>     TRUE # Successfully threw error
[?2004l[?2004h>   })
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> # 7. Run validations
[?2004l[?2004h> # a) Invalid n
