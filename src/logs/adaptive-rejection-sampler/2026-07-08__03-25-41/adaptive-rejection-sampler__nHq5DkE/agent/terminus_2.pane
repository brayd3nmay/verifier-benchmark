[?2004l[?2004h> if (!run_invalid_test(quote(ars(dnorm, c(-3, 3), -5)))) write_verdict(0)
[?2004l[?2004h> 
[?2004l[?2004h> # b) Non-increasing domain
[?2004l[?2004h> if (!run_invalid_test(quote(ars(dnorm, c(3, -3), 10)))) write_verdict(0)
[?2004l[?2004h> if (!run_invalid_test(quote(ars(dnorm, c(1, 1), 10)))) write_verdict(0)
[?2004l[?2004h> 
