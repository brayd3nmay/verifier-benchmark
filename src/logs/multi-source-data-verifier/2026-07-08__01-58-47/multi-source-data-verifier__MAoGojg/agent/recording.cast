[49.234405, "i", "cat << 'EOF' > /app/test_merge.py\nimport os, glob, json\nimport pandas as pd\n\ndef standardize_df(df, source_name):\n    # Map columns\n    col_map = {}\n    for col in df.columns:\n        if col in ['id', 'user_id', 'userId']:\n            col_map[col] = 'user_id'\n        elif col in ['full_name', 'name', 'userName']:\n            col_map[col] = 'name'\n        elif col in ['email', 'email_address']:\n            col_map[col] = 'email'\n        elif col in ['registration_date', 'created_at', 'joined']:\n            col_map[col] = 'created_date'\n        elif col in ['status', 'is_active', 'active']:\n            col_map[col] = 'status'\n    \n    df = df.rename(columns=col_map)\n    \n    # Keep only relevant columns\n    valid_cols = ['user_id', 'name', 'email', 'created_date', 'status']\n    df = df[[c for c in valid_cols if c in df.columns]].copy()\n    \n    # Standardize data types\n    if 'user_id' in df.columns:\n        df['user_id'] = df['user_id'].astype(int)\n    \n    if 'status' in df.columns:\n        # Map booleans or strings\n        def clean_status(val):\n            if pd.isna(val):\n                return None\n            if isinstance(val, bool):\n                return 'active' if val else 'inactive'\n            if isinstance(val, str):\n                v_lower = val.lower().strip()\n                if v_lower in ('true', '1', 'active'):\n                    return 'active'\n                elif v_lower in ('false', '0', 'inactive'):\n                    return 'inactive'\n            # For any other numeric like 1, 0\n            if val == 1 or val == 1.0:\n                return 'active'\n            if val == 0 or val == 0.0:\n                return 'inactive'\n            return str(val)\n        df['status'] = df['status'].apply(clean_status)\n        \n    if 'created_date' in df.columns:\n        # Convert to string in YYYY-MM-DD\n        df['created_date'] = pd.to_datetime(df['created_date']).dt.strftime('%Y-%m-%d')\n        \n    # Convert other columns to string/clean\n    for col in ['name', 'email']:\n        if col in df.columns:\n            df[col] = df[col].astype(str).str.strip()\n            \n    return df\n\ndef main():\n    sources = sorted(glob.glob('/app/data/source_*'))\n    dfs = {}\n    for s_path in sources:\n        s_name = os.path.basename(s_path)\n        files = glob.glob(os.path.join(s_path, 'users.*'))\n        if not files: continue\n        file_path = files[0]\n        ext = os.path.splitext(file_path)[1].lower()\n        if ext == '.json':\n            df = pd.read_json(file_path)\n        elif ext == '.csv':\n            df = pd.read_csv(file_path)\n        elif ext in ('.parquet', '.pq'):\n            df = pd.read_parquet(file_path)\n        else:\n            continue\n        dfs[s_name] = standardize_df(df, s_name)\n        \n    # Merge and Conflicts calculation\n    # Get all unique user_ids\n    all_user_ids = set()\n    for df in dfs.values():\n        all_user_ids.update(df['user_id'].tolist())\n    all_user_ids = sorted(list(all_user_ids))\n    \n    # Priority order is reverse-sorted sources: source_a, source_b, source_c\n    priority_order = sorted(dfs.keys()) # ['source_a', 'source_b', 'source_c']\n    \n    merged_rows = []\n    conflicts = []\n    \n    for uid in all_user_ids:\n        user_sources = {}\n        for s_name in priority_order:\n            s_df = dfs[s_name]\n            row = s_df[s_df['user_id'] == uid]\n            if not row.empty:\n                user_sources[s_name] = row.iloc[0].to_dict()\n                \n        # Select values based on highest priority\n        selected_record = {}\n        # Priority is source_a > source_b > source_c\n        # So we pick the first available source in priority_order\n        for s_name in priority_order:\n            if s_name in user_sources:\n                selected_record = user_sources[s_name]\n                break\n                \n        merged_rows.append({\n            'user_id': uid,\n            'name': selected_record.get('name'),\n            'email': selected_record.get('email'),\n            'created_date': selected_record.get('created_date'),\n            'status': selec"]
[49.234763, "i", "ted_record.get('status')\n        })\n        \n        # Check conflicts\n        # A conflict exists for a field if the sources containing the user disagree on its value.\n        # Only check fields present in at least one of the sources for this user.\n        fields = ['name', 'email', 'created_date', 'status']\n        for field in fields:\n            vals = {}\n            for s_name, record in user_sources.items():\n                if field in record:\n                    vals[s_name] = record[field]\n            \n            # If there's more than 1 source, and any of them disagree\n            if len(vals) > 1:\n                unique_vals = set(vals.values())\n                if len(unique_vals) > 1:\n                    conflicts.append({\n                        'user_id': uid,\n                        'field': field,\n                        'values': vals,\n                        'selected': selected_record.get(field)\n                    })\n                    \n    merged_df = pd.DataFrame(merged_rows)\n    print(\"--- MERGED DF ---\")\n    print(merged_df)\n    \n    conflicts_json = {\n        'total_conflicts': len(conflicts),\n        'conflicts': conflicts\n    }\n    print(\"--- CONFLICTS JSON ---\")\n    print(json.dumps(conflicts_json, indent=2))\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
[49.238482, "o", "cat << 'EOF' > /app/test_merge.py\r\n\u001b[?2004l\r\u001b[?2004h> import os, glob, json\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def standardize_df(df, source_name):\r\n\u001b[?2004l\r\u001b[?2004h>     # Map columns\r\n\u001b[?2004l\r\u001b[?2004h>     col_map = {}\r\n\u001b[?2004l\r\u001b[?2004h>     for col in df.columns:\r\n\u001b[?2004l\r\u001b[?2004h>         if col in ['id', 'user_id', 'userId']:\r\n\u001b[?2004l\rf\u001b[?2004h>             col_map[col] = 'user_id'\r\n\u001b[?2004l\r\u001b[?2004h>         elif col in ['full_name', 'name', 'userName']:\r\n\u001b[?2004l\r\u001b[?2004h>             col_map[col] = 'name'\r\n\u001b[?2004l\r\u001b[?2004h>         elif col in ['email', 'email_address']:\r\n\u001b[?2004l\r\u001b[?2004h>             col_map[col] = 'email'\r\n\u001b[?2004l\r\u001b[?2004h>         elif col in ['registration_date', 'created_at', 'joined']:\r\n\u001b[?2004l\r\u001b[?2004h>             col_map[col] = 'created_date'\r\n\u001b[?2004l\r\u001b[?2004h>         elif col in ['status', 'is_active', 'active']:\r\n\u001b[?2004l\r\u001b[?2004h>             col_map[col] = 'status'\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\rq\u001b[?2004h>     df = df.rename(columns=col_map)\r\n\u001b[?2004l\r     \u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Keep only relevant columns\r\n\u001b[?2004l\r\u001b[?2004h> "]
