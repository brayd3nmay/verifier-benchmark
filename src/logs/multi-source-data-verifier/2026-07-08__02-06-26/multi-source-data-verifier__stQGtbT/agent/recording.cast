[29.177931, "i", "cat << 'EOF' > /app/verifier/test_solution.py\nimport os\nimport glob\nimport pandas as pd\nimport json\n\ndef load_source(dir_path):\n    # find the users.* file\n    files = glob.glob(os.path.join(dir_path, \"users.*\"))\n    if not files:\n        return None\n    filepath = files[0]\n    ext = os.path.splitext(filepath)[1].lower()\n    \n    if ext == '.csv':\n        df = pd.read_csv(filepath)\n    elif ext == '.json':\n        df = pd.read_json(filepath)\n    elif ext == '.parquet':\n        df = pd.read_parquet(filepath)\n    else:\n        return None\n        \n    # Normalize columns\n    # user id is id, user_id, or userId;\n    id_cols = ['id', 'user_id', 'userId']\n    # name is full_name, name, or userName;\n    name_cols = ['full_name', 'name', 'userName']\n    # email is email or email_address;\n    email_cols = ['email', 'email_address']\n    # created_date is registration_date, created_at, or joined;\n    date_cols = ['registration_date', 'created_at', 'joined']\n    # status is status, is_active, or active\n    status_cols = ['status', 'is_active', 'active']\n    \n    # Map columns\n    col_map = {}\n    for c in df.columns:\n        if c in id_cols:\n            col_map[c] = 'user_id'\n        elif c in name_cols:\n            col_map[c] = 'name'\n        elif c in email_cols:\n            col_map[c] = 'email'\n        elif c in date_cols:\n            col_map[c] = 'created_date'\n        elif c in status_cols:\n            col_map[c] = 'status'\n            \n    df = df.rename(columns=col_map)\n    \n    # Keep only relevant columns\n    relevant = ['user_id', 'name', 'email', 'created_date', 'status']\n    df = df[[c for c in relevant if c in df.columns]]\n    \n    # Normalize user_id to int\n    if 'user_id' in df.columns:\n        df['user_id'] = df['user_id'].astype(int)\n        \n    # Normalize status\n    if 'status' in df.columns:\n        def norm_status(val):\n            if pd.isna(val) or val is None:\n                return None\n            if isinstance(val, bool):\n                return 'active' if val else 'inactive'\n            s = str(val).strip().lower()\n            if s in ['true', 'active', '1']:\n                return 'active'\n            if s in ['false', 'inactive', '0']:\n                return 'inactive'\n            return s\n        df['status'] = df['status'].apply(norm_status)\n        \n    # Normalize created_date to YYYY-MM-DD\n    if 'created_date' in df.columns:\n        df['created_date'] = pd.to_datetime(df['created_date']).dt.strftime('%Y-%m-%d')\n        \n    return df\n\n# Find all source directories and sort them alphabetically\nsource_dirs = sorted(glob.glob(\"/app/data/source_*\"))\nsources = {}\nfor sdir in source_dirs:\n    sname = os.path.basename(sdir)\n    df = load_source(sdir)\n    if df is not None:\n        sources[sname] = df\n\nprint(\"Loaded sources:\")\nfor sname, df in sources.items():\n    print(sname)\n    print(df)\nEOF\npython3 /app/verifier/test_solution.py\n"]
[29.183101, "o", "cat << 'EOF' > /app/verifier/test_solution.py\r\n\u001b[?2004l\r"]
